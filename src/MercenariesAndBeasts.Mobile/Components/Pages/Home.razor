@page "/"

<PageTitle>Mercenaries &amp; Beasts</PageTitle>

<div class="ui-panel ui-anim-fade-up text-center p-4 mb-3">
    <div style="font-size:2.5rem;margin-bottom:.5rem;">⚔️</div>
    <h4 class="fw-bold mb-1">Mercenaries &amp; Beasts</h4>
    <p class="text-muted small mb-0">Mobilní klient pro fantasy RPG — žoldnéři, bestiárium, dungeons a obchod.</p>
</div>

<div class="ui-panel ui-anim-fade-up p-3">
    <div class="d-flex align-items-center gap-3 py-1 border-bottom">
        <i class="bi bi-person-badge text-accent fs-5"></i>
        <div>
            <div class="fw-semibold small">Žoldnéři</div>
