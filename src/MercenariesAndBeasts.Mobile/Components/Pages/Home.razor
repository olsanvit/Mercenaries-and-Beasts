        </div>
    </div>
    <div class="d-flex align-items-center gap-3 py-1 border-bottom">
        <i class="bi bi-door-open text-accent fs-5"></i>
        <div>
            <div class="fw-semibold small">Dungeons</div>
            <div class="text-muted" style="font-size:.75rem">Průzkum kobek a boj s nepřáteli</div>
        </div>
    </div>
    <div class="d-flex align-items-center gap-3 py-1">
        <i class="bi bi-bag text-accent fs-5"></i>
        <div>
            <div class="fw-semibold small">Obchod</div>
            <div class="text-muted" style="font-size:.75rem">Nákup předmětů a vybavení</div>
        </div>
    </div>
