@using MercenariesAndBeasts.Web.Components.Pages
@using MercenariesAndBeasts.Web.Components.Pages.Shared
@using System.Globalization

@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
               <span class="badge rounded-pill bg-info">
                    🔔  @Toasts.Toasts.Count
                </span>
            <div class="d-flex align-items-center gap-3 m-1">
                <LanguageSwitcher />
                <AuthorizeView>
                    <Authorized>
                        <a href="/shop" class="btn btn-sm btn-warning">
                            🛒 Shop
                        </a>
                    </Authorized>
                </AuthorizeView>
            </div>
            
        <AuthorizeView>
                <Authorized>
                    <a class="btn btn-sm btn-outline-light"
                href="/profile"
                title="Profile">
                        👤 @_userName
                </a>

            <UserCountryBadge />
                    <a href="/Identity/Account/Logout" class="ms-2">@S["Logout"]</a>
                </Authorized>

                <NotAuthorized>
                    <a href="/Identity/Account/Login">@S["Login"]</a>
                    <a href="/Identity/Account/Register" class="ms-2">@S["Register"]</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

        <ToastContainer />

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
private string _userName = "Player";


    protected override async Task OnInitializedAsync()
    {
        Toasts.OnToastsUpdated += StateHasChanged;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var principal = authState.User;

        if (principal?.Identity?.IsAuthenticated != true)
            return;

        var appUser = await UserManager.GetUserAsync(principal);
        if (appUser is null)
            return;

        _userName = appUser.UserName ?? appUser.Email ?? "Player";
    }

    public void Dispose()
    {
        Toasts.OnToastsUpdated -= StateHasChanged;
    }
    private void ShowToasts()
    {
        // jednou můžeš otevřít panel toastů nebo scrollovat dolů
    }
private void UpdateCount()
    {
        InvokeAsync(StateHasChanged);
    }
}