@using MercenariesAndBeasts.Web.Components.Pages.Shared
@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
        <AuthorizeView>
                <Authorized>
                    <span>Hello @context.User.Identity?.Name!</span>
                    <a href="/Identity/Account/Logout" class="ms-2">Logout</a>
                </Authorized>

                <NotAuthorized>
                    <a href="/Identity/Account/Login">Login</a>
                    <a href="/Identity/Account/Register" class="ms-2">Register</a>
                </NotAuthorized>
            </AuthorizeView>
            <div class="d-flex align-items-center gap-3">
                <LanguageSwitcher />
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
