<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">MercenariesAndBeasts.Web</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-container">

    <!-- SCROLLABLE NAV -->
    <div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
        <nav class="nav flex-column">

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/">
                    <span class="bi bi-house"></span> @S["Home"]
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="dungeons">
                    <span class="bi bi-fire"></span> @S["Dungeons"]
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="expeditions">
                    <span class="bi bi-compass"></span> @S["Locations"]
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="shop">
                    <span class="bi bi-cart3"></span> Shop
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="profile">
                    <span class="bi bi-person-circle"></span> Profile
                </NavLink>
            </div>

            <AuthorizeView Roles="Admin">
                <Authorized>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="/admin">
                            Admin
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="/locations-admin">
                            @S["Locations"] Admin
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="/dungeons-admin">
                            @S["Dungeons"] Admin
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="/items-admin">
                            Items Admin
                        </NavLink>
                    </div>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="/admin/users">
                            Users Admin
                        </NavLink>
                    </div>
                </Authorized>
            </AuthorizeView>

        </nav>
    </div>

    <!-- FIXED BOTTOM QUESTS -->
    <div class="nav-quests">

        <!-- Daily -->
        <div class="quest-section">
            <div class="quest-title">Daily Quests</div>
            <ul>
                <li>Win 3 fights</li>
                <li>Clear 1 dungeon stage</li>
                <li>Complete 1 expedition</li>
            </ul>
        </div>

        <!-- Weekly -->
        <div class="quest-section">
            <div class="quest-title">Weekly Quests</div>
            <ul>
                <li>Defeat 10 bosses</li>
                <li>Reach win streak 5</li>
                <li>Clear 3 expeditions</li>
            </ul>
        </div>

    </div>
</div>

