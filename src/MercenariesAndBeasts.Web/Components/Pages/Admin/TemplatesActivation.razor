@page "/admin/activation"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]
@using MercenariesAndBeasts.Domain.Utils
@using MercenariesAndBeasts.Domain.Items

<PageTitle>Aktivace šablon — Admin</PageTitle>

<div class="ui-page-header ui-anim-fade-up">
    <div class="d-flex align-items-center gap-3">
        <a href="/admin" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h3 class="m-0"><i class="bi bi-check2-circle me-2"></i>Aktivace šablon</h3>
    </div>
    <button class="btn btn-warning btn-sm" @onclick="ActivateAllAsync" disabled="@_busy">
        @if (_busy)
        {
            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
        }
        Aktivovat vše (drafty)
    </button>
</div>

<div class="ui-panel ui-anim-fade-up">
    <!-- Tab pills -->
    <div class="d-flex gap-2 flex-wrap p-3 pb-0">
        @foreach (var tab in _tabs)
        {
            <button class="btn btn-sm @(tab == _activeTab ? "btn-primary" : "btn-outline-secondary")"
                    @onclick="() => ChangeTabAsync(tab)">
                @tab
            </button>
        }
    </div>

    <div class="px-3 pt-2 pb-1">
        <div class="form-check form-check-inline">
            <input class="form-check-input" type="checkbox" id="showAll" @bind="_showAll" @bind:after="LoadAsync" />
            <label class="form-check-label small" for="showAll">Zobrazit i aktivní</label>
        </div>
    </div>

    @if (_loading)
    {
        <PageLoadingSpinner />
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr><th>Code</th><th>Název</th><th>Level</th><th>Stav</th><th>Akce</th></tr>
                </thead>
                <tbody>
                    @foreach (var row in _rows.Skip((_page - 1) * PageSize).Take(PageSize))
                    {
                        <tr style="@(row.IsActive ? "" : "background:rgba(251,191,36,0.07)")" >
                            <td>@row.Code</td>
                            <td>@row.NameEn</td>
                            <td>@row.BaseLevel</td>
                            <td>@(row.IsActive ? "Aktivní" : "Draft")</td>
                            <td>
                                @if (!row.IsActive)
                                {
                                    <button class="btn btn-sm btn-success" @onclick="() => ActivateOneAsync(row)">Aktivovat</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => DeactivateOneAsync(row)">Deaktivovat</button>
                                }
                            </td>
                        </tr>
                    }
                    @if (_rows.Count == 0)
                    {
                        <tr><td colspan="5" class="text-muted text-center">Žádné záznamy.</td></tr>
                    }
                </tbody>
            </table>
        </div>
        <Paginator TotalItems="_totalItems" PageSize="PageSize" CurrentPage="_page"
                   OnPageChanged="async p => { _page = p; StateHasChanged(); }" />
        <p class="text-muted small mt-2 mb-0">@_rows.Count záznamů</p>
    }
</div>

@code {
    private readonly string[] _tabs = ["Žoldáci", "Monstra", "Dungeony", "Lokace", "Předměty"];
    private string _activeTab = "Žoldáci";
    private bool _loading = true;
    private bool _busy;
    private bool _showAll;
    private List<MabTemplate> _rows = new();

    private int _page = 1;
    private const int PageSize = 20;
    private int _totalItems;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task ChangeTabAsync(string tab)
    {
        _activeTab = tab;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();
        _rows = await GetRowsAsync();
        _totalItems = _rows.Count;
        _page = 1;
        _loading = false;
    }

    private async Task<List<MabTemplate>> GetRowsAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        return _activeTab switch
        {
            "Žoldáci"  => (await db.MercenaryTemplates
                              .Where(x => _showAll || !x.IsActive).OrderBy(x => x.NameEn).ToListAsync())
                              .Cast<MabTemplate>().ToList(),
            "Monstra"  => (await db.MonsterTemplates
                              .Where(x => _showAll || !x.IsActive).OrderBy(x => x.NameEn).ToListAsync())
                              .Cast<MabTemplate>().ToList(),
            "Dungeony" => (await db.Dungeons
                              .Where(x => _showAll || !x.IsActive).OrderBy(x => x.NameEn).ToListAsync())
                              .Cast<MabTemplate>().ToList(),
            "Lokace"   => (await db.Locations
                              .Where(x => _showAll || !x.IsActive).OrderBy(x => x.NameEn).ToListAsync())
                              .Cast<MabTemplate>().ToList(),
            "Předměty" => (await db.ItemTemplates
                              .Where(x => _showAll || !x.IsActive).OrderBy(x => x.NameEn).ToListAsync())
                              .Cast<MabTemplate>().ToList(),
            _          => new List<MabTemplate>()
        };
    }

    private async Task ActivateOneAsync(MabTemplate row)
    {
        await SetActiveInDbAsync(row.Guid, true);
        row.IsActive = true;
        StateHasChanged();
    }

    private async Task DeactivateOneAsync(MabTemplate row)
    {
        await SetActiveInDbAsync(row.Guid, false);
        row.IsActive = false;
        StateHasChanged();
    }

    private async Task ActivateAllAsync()
    {
        _busy = true;
        StateHasChanged();
        await using var db = await DbFactory.CreateDbContextAsync();
        switch (_activeTab)
        {
            case "Žoldáci":  await db.MercenaryTemplates.Where(x => !x.IsActive).ExecuteUpdateAsync(s => s.SetProperty(x => x.IsActive, true)); break;
            case "Monstra":  await db.MonsterTemplates.Where(x => !x.IsActive).ExecuteUpdateAsync(s => s.SetProperty(x => x.IsActive, true)); break;
            case "Dungeony": await db.Dungeons.Where(x => !x.IsActive).ExecuteUpdateAsync(s => s.SetProperty(x => x.IsActive, true)); break;
            case "Lokace":   await db.Locations.Where(x => !x.IsActive).ExecuteUpdateAsync(s => s.SetProperty(x => x.IsActive, true)); break;
            case "Předměty": await db.ItemTemplates.Where(x => !x.IsActive).ExecuteUpdateAsync(s => s.SetProperty(x => x.IsActive, true)); break;
        }
        _rows = await GetRowsAsync();
        _busy = false;
    }

    private async Task SetActiveInDbAsync(Guid guid, bool active)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        switch (_activeTab)
        {
            case "Žoldáci":
                var merc = await db.MercenaryTemplates.FindAsync(guid);
                if (merc != null) { merc.IsActive = active; await db.SaveChangesAsync(); }
                break;
            case "Monstra":
                var mon = await db.MonsterTemplates.FindAsync(guid);
                if (mon != null) { mon.IsActive = active; await db.SaveChangesAsync(); }
                break;
            case "Dungeony":
                var dng = await db.Dungeons.FindAsync(guid);
                if (dng != null) { dng.IsActive = active; await db.SaveChangesAsync(); }
                break;
            case "Lokace":
                var loc = await db.Locations.FindAsync(guid);
                if (loc != null) { loc.IsActive = active; await db.SaveChangesAsync(); }
                break;
            case "Předměty":
                var itm = await db.ItemTemplates.FindAsync(guid);
                if (itm != null) { itm.IsActive = active; await db.SaveChangesAsync(); }
                break;
        }
    }
}
