@page "/admin"
@using MercenariesAndBeasts.Domain.Items
@using Microsoft.EntityFrameworkCore
@using MercenariesAndBeasts.Infrastructure
@using MercenariesAndBeasts.Domain.Localization
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

<div class="dash-switcher mb-3">
    <h4 class="m-0">Admin</h4>
</div>

<div class="card-like mb-3">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
        <div>
            <div class="fw-bold">Game Seed</div>
            <div class="text-muted small">Run full game seed (locations, dungeons, items, AI generation).</div>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-danger"
                    disabled="@isSeeding"
                    @onclick="() => RunSeedAsync(true)">
                Run FULL Seed
            </button>
            <button class="btn btn-outline-secondary"
                    disabled="@isSeeding"
                    @onclick="() => RunSeedAsync(false)">
                Run Minimal Seed
            </button>
        </div>
    </div>

    @if (isSeeding)
    {
        <div class="d-flex align-items-center gap-2 text-warning">
            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
            <span>Seeding in progress…</span>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(seedResult))
    {
        <div class="alert alert-info mt-2 mb-0">@seedResult</div>
    }
</div>

@if (countsLoaded)
{
    <div class="card-like mb-3">
        <div class="fw-bold mb-2">Database counts</div>
        <div class="dungeons-table-wrap">
            <table class="table table-dark table-stages mb-0">
                <tbody>
                    <tr><td>Dungeons</td><td class="text-end">@dungeonCount</td></tr>
                    <tr><td>Monster templates</td><td class="text-end">@monsterCount</td></tr>
                    <tr><td>Locations</td><td class="text-end">@locationCount</td></tr>
                    <tr><td>Orders (Mercenaries)</td><td class="text-end">@orderCount</td></tr>
                    <tr><td>Item templates</td><td class="text-end">@itemCount</td></tr>
                    <tr><td>Item upgrade resources</td><td class="text-end">@resourceCount</td></tr>
                </tbody>
            </table>
        </div>
    </div>
}

@if (locStats.Count > 0)
{
    <div class="card-like mb-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <div class="fw-bold">Localization coverage</div>
            <div class="text-muted small">Required locales: @requiredLocaleCount</div>
        </div>
        <div class="dungeons-table-wrap">
            <table class="table table-dark table-stages mb-0">
                <thead>
                    <tr>
                        <th>Entity</th>
                        <th class="text-end">Total</th>
                        <th class="text-end">Any</th>
                        <th class="text-end">Full</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in locStats)
                    {
                        <tr>
                            <td>@r.Entity</td>
                            <td class="text-end">@r.Total</td>
                            <td class="text-end">@r.AnyLocalized</td>
                            <td class="text-end @(r.FullyLocalized == r.Total ? "text-success" : "")">@r.FullyLocalized</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<TranslationPanel />

@code
{

    private bool isSeeding = false;
    private string? seedResult;

    // counts
    private bool countsLoaded = false;
    private int dungeonCount;
    private int monsterCount;
    private int locationCount;
    private int orderCount;
    private int itemCount;
    private int resourceCount;

    // localization stats
    private sealed record LocalizationRow(string Entity, int Total, int AnyLocalized, int FullyLocalized);
    private List<LocalizationRow> locStats = new();
    private int requiredLocaleCount;

    protected override async Task OnInitializedAsync()
    {
        await ReloadStatsAsync();
    }

    private async Task RunSeedAsync(bool makeAll)
    {
        isSeeding = true;
        seedResult = null;
        StateHasChanged();

        try
        {
            await GameSeed.SeedAsync(makeAll, CancellationToken.None);
            seedResult = $"Seed finished successfully. MakeAll = {makeAll}";
        }
        catch (Exception ex)
        {
            seedResult = $"Seed FAILED: {ex.Message}";
        }
        finally
        {
            isSeeding = false;
            await ReloadStatsAsync();
        }
    }

    private async Task ReloadStatsAsync()
    {

        await using var Db = await DbFactory.CreateDbContextAsync();
        dungeonCount  = await Db.Dungeons.CountAsync();
        monsterCount  = await Db.MonsterTemplates.CountAsync();
        locationCount = await Db.Locations.CountAsync();
        orderCount    = await Db.MercenaryTemplates.CountAsync();
        itemCount     = await Db.ItemTemplates.CountAsync();
        resourceCount = await Db.ItemUpgradeResources.CountAsync();

        countsLoaded = true;

        await LoadLocalizationStatsAsync();
        StateHasChanged();
    }

    private async Task LoadLocalizationStatsAsync()
    {
        var locales = LocalizationConfig.SupportedLocales;
        requiredLocaleCount = locales.Length;

        await using var Db = await DbFactory.CreateDbContextAsync();
        var localizedCounts = await Db.LocalizedTexts
            .Where(x => locales.Contains(x.Culture) && x.Name != null && x.Name != "")
            .GroupBy(x => new { x.EntityType, x.EntityId })
            .Select(g => new
            {
                g.Key.EntityType,
                g.Key.EntityId,
                CultureCount = g.Select(x => x.Culture).Distinct().Count()
            })
            .ToListAsync();

        (int any, int full) Calc(string entityType)
        {
            var rows = localizedCounts.Where(x => x.EntityType == entityType).ToList();
            var any = rows.Select(x => x.EntityId).Distinct().Count();
            var full = rows.Count(x => x.CultureCount >= requiredLocaleCount);
            return (any, full);
        }

        var (dngAny, dngFull) = Calc(nameof(Dungeon));
        var (monAny, monFull) = Calc(nameof(MonsterTemplate));
        var (locAny, locFull) = Calc(nameof(Location));
        var (ordAny, ordFull) = Calc(nameof(MercenaryTemplate));
        var (itmAny, itmFull) = Calc(nameof(ItemTemplate));
        var (resAny, resFull) = Calc(nameof(ItemUpgradeResource));

        locStats = new()
        {
            new LocalizationRow("Dungeons",              dungeonCount,  dngAny, dngFull),
            new LocalizationRow("MonsterTemplates",      monsterCount,  monAny, monFull),
            new LocalizationRow("Locations",             locationCount, locAny, locFull),
            new LocalizationRow("Orders (Mercenaries)",  orderCount,    ordAny, ordFull),
            new LocalizationRow("Items (ItemTemplates)", itemCount,     itmAny, itmFull),
            new LocalizationRow("ItemUpgradeResources",  resourceCount, resAny, resFull),
        };
    }
}