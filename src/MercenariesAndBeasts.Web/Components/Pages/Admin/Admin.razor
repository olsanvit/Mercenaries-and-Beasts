@page "/admin"
@using MercenariesAndBeasts.Domain.Items
@using Microsoft.EntityFrameworkCore
@using MercenariesAndBeasts.Infrastructure
@using MercenariesAndBeasts.Domain.Localization
@using MercenariesAndBeasts.Domain.Utils
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

<div class="ui-page-header ui-anim-fade-up">
    <h3><i class="bi bi-shield-lock me-2"></i>Admin</h3>
</div>

<div class="ui-panel ui-anim-fade-up">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
        <div>
            <div class="fw-bold">Game Seed</div>
            <div class="text-muted small">Run full game seed (locations, dungeons, items, AI generation).</div>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-danger"
                    disabled="@isSeeding"
                    @onclick="() => RunSeedAsync(true)">
                Run FULL Seed
            </button>
            <button class="btn btn-outline-secondary"
                    disabled="@isSeeding"
                    @onclick="() => RunSeedAsync(false)">
                Run Minimal Seed
            </button>
        </div>
    </div>

    @if (isSeeding)
    {
        <div class="d-flex align-items-center gap-2 text-warning">
            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
            <span>Seeding in progress…</span>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(seedResult))
    {
        <div class="alert alert-info mt-2 mb-0">@seedResult</div>
    }
</div>

<!-- Test seeders -->
<div class="ui-panel ui-anim-fade-up">
    <div class="ui-panel-header">
        <span class="ui-panel-title"><i class="bi bi-database-fill-add text-accent"></i> Testovací data</span>
    </div>
    <div class="p-3 d-flex flex-column gap-3">

        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
            <div>
                <div class="fw-semibold">Lokace + Žoldnéři</div>
                <div class="text-muted small">8 expedičních lokací (10 fází), 24 šablon žoldnéřů. Idempotentní.</div>
            </div>
            <button class="btn btn-outline-success btn-sm" @onclick="SeedLocationsAsync" disabled="@_seedingLocations">
                @if (_seedingLocations) { <span class="spinner-border spinner-border-sm me-1"></span> }
                <i class="bi bi-geo-alt-fill me-1"></i>Seed lokací
            </button>
        </div>
        @if (!string.IsNullOrWhiteSpace(_locationSeedResult))
        { <div class="alert alert-info py-2 small mb-0">@_locationSeedResult</div> }

        <hr class="border-opacity-10" />

        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
            <div>
                <div class="fw-semibold">Dungeony + Bestie</div>
                <div class="text-muted small">8 dungeonů (11 fází), 24 šablon monster. Idempotentní.</div>
            </div>
            <button class="btn btn-outline-danger btn-sm" @onclick="SeedDungeonsAsync" disabled="@_seedingDungeons">
                @if (_seedingDungeons) { <span class="spinner-border spinner-border-sm me-1"></span> }
                <i class="bi bi-door-open me-1"></i>Seed dungeonů
            </button>
        </div>
        @if (!string.IsNullOrWhiteSpace(_dungeonSeedResult))
        { <div class="alert alert-info py-2 small mb-0">@_dungeonSeedResult</div> }

        <hr class="border-opacity-10" />

        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
            <div>
                <div class="fw-semibold">Test Hráči</div>
                <div class="text-muted small">5 hráčů (Novice→Legenda) s progression. Vyžaduje lokace+dungeony.</div>
            </div>
            <button class="btn btn-warning btn-sm" @onclick="SeedTestPlayersAsync" disabled="@_seedingPlayers">
                @if (_seedingPlayers) { <span class="spinner-border spinner-border-sm me-1"></span> }
                <i class="bi bi-people-fill me-1"></i>Seed hráčů
            </button>
        </div>
        @if (!string.IsNullOrWhiteSpace(_playerSeedResult))
        { <div class="alert alert-info py-2 small mb-0">@_playerSeedResult</div> }

    </div>
</div>

@if (countsLoaded)
{
    <div class="ui-panel ui-anim-fade-up">
        <div class="fw-bold mb-2">Database counts</div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <tbody>
                    <tr><td>Dungeons</td><td class="text-end">@dungeonCount</td></tr>
                    <tr><td>Monster templates</td><td class="text-end">@monsterCount</td></tr>
                    <tr><td>Locations</td><td class="text-end">@locationCount</td></tr>
                    <tr><td>Orders (Mercenaries)</td><td class="text-end">@orderCount</td></tr>
                    <tr><td>Item templates</td><td class="text-end">@itemCount</td></tr>
                    <tr><td>Item upgrade resources</td><td class="text-end">@resourceCount</td></tr>
                </tbody>
            </table>
        </div>
    </div>
}

@if (locStats.Count > 0)
{
    <div class="ui-panel ui-anim-fade-up">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <div class="fw-bold">Localization coverage</div>
            <div class="text-muted small">Required locales: @requiredLocaleCount</div>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Entity</th>
                        <th class="text-end">Total</th>
                        <th class="text-end">Any</th>
                        <th class="text-end">Full</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in locStats)
                    {
                        <tr>
                            <td>@r.Entity</td>
                            <td class="text-end">@r.Total</td>
                            <td class="text-end">@r.AnyLocalized</td>
                            <td class="text-end @(r.FullyLocalized == r.Total ? "text-success" : "")">@r.FullyLocalized</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="ui-panel ui-anim-fade-up">
    <div class="ui-panel-header">
        <span class="ui-panel-title">
            <i class="bi bi-clock-history text-amber"></i>
            Draft záznamy čekající na aktivaci
        </span>
        <a href="/admin/activation" class="btn btn-sm btn-outline-primary">Správa aktivací</a>
    </div>
    <div class="p-3">
    @if (_draftMercenaries.Count > 0)
    {
        <div class="text-muted small mb-1">Žoldáci (@_draftMercenaries.Count)</div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-2">
                <thead><tr><th>Code</th><th>Název</th><th>Level</th><th>Akce</th></tr></thead>
                <tbody>
                    @foreach (var m in _draftMercenaries.Take(10))
                    {
                        <tr>
                            <td>@m.Code</td>
                            <td>@m.NameEn</td>
                            <td>@m.BaseLevel</td>
                            <td><button class="btn btn-sm btn-success" @onclick="() => ActivateMercenaryAsync(m.Guid)">Aktivovat</button></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    @if (_draftMonsters.Count > 0)
    {
        <div class="text-muted small mb-1 mt-2">Monstra (@_draftMonsters.Count)</div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-2">
                <thead><tr><th>Code</th><th>Název</th><th>Level</th><th>Akce</th></tr></thead>
                <tbody>
                    @foreach (var m in _draftMonsters.Take(10))
                    {
                        <tr>
                            <td>@m.Code</td>
                            <td>@m.NameEn</td>
                            <td>@m.BaseLevel</td>
                            <td><button class="btn btn-sm btn-success" @onclick="() => ActivateMonsterAsync(m.Guid)">Aktivovat</button></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    @if (_draftMercenaries.Count == 0 && _draftMonsters.Count == 0)
    {
        <p class="text-muted mb-0">Žádné drafty.</p>
    }
    </div>
</div>

<TranslationPanel />

@code
{

    private bool isSeeding = false;
    private string? seedResult;
    private bool _seedingPlayers = false;
    private bool _seedingLocations = false;
    private bool _seedingDungeons = false;
    private string? _playerSeedResult;
    private string? _locationSeedResult;
    private string? _dungeonSeedResult;

    [Inject] MercenariesAndBeasts.Web.Services.TestPlayerSeeder TestSeeder { get; set; } = default!;
    [Inject] MercenariesAndBeasts.Web.Services.TestLocationsAndMercenariesSeeder LocationSeeder { get; set; } = default!;
    [Inject] MercenariesAndBeasts.Web.Services.TestDungeonsAndBeastsSeeder DungeonSeeder { get; set; } = default!;

    private async Task SeedTestPlayersAsync()
    {
        _seedingPlayers = true; _playerSeedResult = null;
        try   { _playerSeedResult = await TestSeeder.SeedAsync(); }
        catch (Exception ex) { _playerSeedResult = $"❌ {ex.Message}"; }
        finally { _seedingPlayers = false; }
    }

    private async Task SeedLocationsAsync()
    {
        _seedingLocations = true; _locationSeedResult = null;
        try   { _locationSeedResult = await LocationSeeder.SeedAsync(); }
        catch (Exception ex) { _locationSeedResult = $"❌ {ex.Message}"; }
        finally { _seedingLocations = false; }
    }

    private async Task SeedDungeonsAsync()
    {
        _seedingDungeons = true; _dungeonSeedResult = null;
        try   { _dungeonSeedResult = await DungeonSeeder.SeedAsync(); }
        catch (Exception ex) { _dungeonSeedResult = $"❌ {ex.Message}"; }
        finally { _seedingDungeons = false; }
    }

    // drafts
    private List<MercenaryTemplate> _draftMercenaries = new();
    private List<MonsterTemplate> _draftMonsters = new();

    // counts
    private bool countsLoaded = false;
    private int dungeonCount;
    private int monsterCount;
    private int locationCount;
    private int orderCount;
    private int itemCount;
    private int resourceCount;

    // localization stats
    private sealed record LocalizationRow(string Entity, int Total, int AnyLocalized, int FullyLocalized);
    private List<LocalizationRow> locStats = new();
    private int requiredLocaleCount;

    protected override async Task OnInitializedAsync()
    {
        await ReloadStatsAsync();
        await LoadDraftsAsync();
    }

    private async Task LoadDraftsAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        _draftMercenaries = await db.MercenaryTemplates.Where(m => !m.IsActive).Take(20).ToListAsync();
        _draftMonsters    = await db.MonsterTemplates.Where(m => !m.IsActive).Take(20).ToListAsync();
    }

    private Task ActivateMercenaryAsync(Guid guid) => ActivateAsync("Mercenary", guid);
    private Task ActivateMonsterAsync(Guid guid)   => ActivateAsync("Monster",   guid);

    private async Task ActivateAsync(string type, Guid guid)
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        if (type == "Mercenary")
        {
            var m = await db.MercenaryTemplates.FindAsync(guid);
            if (m != null) { m.IsActive = true; await db.SaveChangesAsync(); }
            _draftMercenaries.RemoveAll(x => x.Guid == guid);
        }
        else if (type == "Monster")
        {
            var m = await db.MonsterTemplates.FindAsync(guid);
            if (m != null) { m.IsActive = true; await db.SaveChangesAsync(); }
            _draftMonsters.RemoveAll(x => x.Guid == guid);
        }
        StateHasChanged();
    }

    private async Task RunSeedAsync(bool makeAll)
    {
        isSeeding = true;
        seedResult = null;
        StateHasChanged();

        try
        {
            await GameSeed.SeedAsync(makeAll, CancellationToken.None);
            seedResult = $"Seed finished successfully. MakeAll = {makeAll}";
        }
        catch (Exception ex)
        {
            seedResult = $"Seed FAILED: {ex.Message}";
        }
        finally
        {
            isSeeding = false;
            await ReloadStatsAsync();
        }
    }

    private async Task ReloadStatsAsync()
    {

        await using var Db = await DbFactory.CreateDbContextAsync();
        dungeonCount  = await Db.Dungeons.CountAsync();
        monsterCount  = await Db.MonsterTemplates.CountAsync();
        locationCount = await Db.Locations.CountAsync();
        orderCount    = await Db.MercenaryTemplates.CountAsync();
        itemCount     = await Db.ItemTemplates.CountAsync();
        resourceCount = await Db.ItemUpgradeResources.CountAsync();

        countsLoaded = true;

        await LoadLocalizationStatsAsync();
        StateHasChanged();
    }

    private async Task LoadLocalizationStatsAsync()
    {
        var locales = LocalizationConfig.SupportedLocales;
        requiredLocaleCount = locales.Length;

        await using var Db = await DbFactory.CreateDbContextAsync();
        var localizedCounts = await Db.LocalizedTexts
            .Where(x => locales.Contains(x.Culture) && x.Name != null && x.Name != "")
            .GroupBy(x => new { x.EntityType, x.EntityId })
            .Select(g => new
            {
                g.Key.EntityType,
                g.Key.EntityId,
                CultureCount = g.Select(x => x.Culture).Distinct().Count()
            })
            .ToListAsync();

        (int any, int full) Calc(string entityType)
        {
            var rows = localizedCounts.Where(x => x.EntityType == entityType).ToList();
            var any = rows.Select(x => x.EntityId).Distinct().Count();
            var full = rows.Count(x => x.CultureCount >= requiredLocaleCount);
            return (any, full);
        }

        var (dngAny, dngFull) = Calc(nameof(Dungeon));
        var (monAny, monFull) = Calc(nameof(MonsterTemplate));
        var (locAny, locFull) = Calc(nameof(Location));
        var (ordAny, ordFull) = Calc(nameof(MercenaryTemplate));
        var (itmAny, itmFull) = Calc(nameof(ItemTemplate));
        var (resAny, resFull) = Calc(nameof(ItemUpgradeResource));

        locStats = new()
        {
            new LocalizationRow("Dungeons",              dungeonCount,  dngAny, dngFull),
            new LocalizationRow("MonsterTemplates",      monsterCount,  monAny, monFull),
            new LocalizationRow("Locations",             locationCount, locAny, locFull),
            new LocalizationRow("Orders (Mercenaries)",  orderCount,    ordAny, ordFull),
            new LocalizationRow("Items (ItemTemplates)", itemCount,     itmAny, itmFull),
            new LocalizationRow("ItemUpgradeResources",  resourceCount, resAny, resFull),
        };
    }
}