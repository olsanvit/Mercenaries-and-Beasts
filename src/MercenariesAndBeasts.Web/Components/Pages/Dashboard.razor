// ---------------- Equip methods ----------------
private async Task EquipBeastAsync(Guid targetSlotId, Guid playerItemId)
{
    if (_profile is null) throw new InvalidOperationException("Profile not loaded.");

    await using var Db = await DbFactory.CreateDbContextAsync();

    var slot = await Db.Set<PlayerBeastSlot>()
        .FirstOrDefaultAsync(s => s.Id == targetSlotId && s.PlayerProfileId == _profile.Id);

    if (slot is null)
        throw new InvalidOperationException("Target beast slot not found.");

    var item = await Db.PlayerItems
        .Include(i => i.Template)
        .FirstOrDefaultAsync(i => i.Id == playerItemId && i.PlayerId == _profile.Id);

    if (item is null)
        throw new InvalidOperationException("Item not found in inventory.");

    if (item.Template.OwnerKind != ItemOwnerKind.Beast)
        throw new InvalidOperationException("Item is not a Beast unit item.");

    if (item.LinkedMonsterInstanceId is null)
        throw new InvalidOperationException("Unit item is not linked to a beast instance.");

    var beastExists = await Db.PlayerMonsters
        .AnyAsync(b => b.Id == item.LinkedMonsterInstanceId && b.PlayerId == _profile.Id);

    if (!beastExists)
        throw new InvalidOperationException("Linked beast instance does not exist (or does not belong to you).");

    slot.BeastInstanceId = item.LinkedMonsterInstanceId;
    await Db.SaveChangesAsync();
}

private async Task EquipMercenaryAsync(Guid targetSlotId, Guid playerItemId)
{
    if (_profile is null) throw new InvalidOperationException("Profile not loaded.");

    await using var Db = await DbFactory.CreateDbContextAsync();

    var slot = await Db.PlayerMercenarySlots
        .FirstOrDefaultAsync(s => s.Id == targetSlotId && s.PlayerProfileId == _profile.Id);

    if (slot is null)
        throw new InvalidOperationException("Target mercenary slot not found.");

    var item = await Db.PlayerItems
        .Include(i => i.Template)
        .FirstOrDefaultAsync(i => i.Id == playerItemId && i.PlayerId == _profile.Id);

    if (item is null)
        throw new InvalidOperationException("Item not found in inventory.");

    if (item.Template.OwnerKind != ItemOwnerKind.Mercenary)
        throw new InvalidOperationException("Item is not a Mercenary unit item.");

    if (item.LinkedMercenaryInstanceId is null)
        throw new InvalidOperationException("Unit item is not linked to a mercenary instance.");

    var mercExists = await Db.PlayerMercenaries
        .AnyAsync(m => m.Id == item.LinkedMercenaryInstanceId && m.PlayerId == _profile.Id);

    if (!mercExists)
        throw new InvalidOperationException("Linked mercenary instance does not exist (or does not belong to you).");

    slot.MercenaryInstanceId = item.LinkedMercenaryInstanceId;
    await Db.SaveChangesAsync();
}

private async Task MoveOrSwapBeastSlotAsync(Guid fromSlotId, Guid toSlotId)
{
    if (_profile is null) throw new InvalidOperationException("Profile not loaded.");
    if (fromSlotId == toSlotId) return;

    await using var Db = await DbFactory.CreateDbContextAsync();

    var slots = await Db.Set<PlayerBeastSlot>()
        .Where(s => s.PlayerProfileId == _profile.Id && (s.Id == fromSlotId || s.Id == toSlotId))
        .ToListAsync();

    var from = slots.FirstOrDefault(s => s.Id == fromSlotId);
    var to = slots.FirstOrDefault(s => s.Id == toSlotId);

    if (from is null || to is null)
        throw new InvalidOperationException("Beast slot not found.");

    var tmp = from.BeastInstanceId;
    from.BeastInstanceId = to.BeastInstanceId;
    to.BeastInstanceId = tmp;

    await Db.SaveChangesAsync();
}

private async Task MoveOrSwapMercSlotAsync(Guid fromSlotId, Guid toSlotId)
{
    if (_profile is null) throw new InvalidOperationException("Profile not loaded.");
    if (fromSlotId == toSlotId) return;

    await using var Db = await DbFactory.CreateDbContextAsync();

    var slots = await Db.Set<PlayerMercenarySlot>()
        .Where(s => (s.Id == fromSlotId || s.Id == toSlotId) && s.PlayerProfileId == _profile.Id)
        .ToListAsync();

    var from = slots.First(s => s.Id == fromSlotId);
    var to = slots.First(s => s.Id == toSlotId);

    (from.MercenaryInstanceId, to.MercenaryInstanceId) = (to.MercenaryInstanceId, from.MercenaryInstanceId);
    await Db.SaveChangesAsync();
}
