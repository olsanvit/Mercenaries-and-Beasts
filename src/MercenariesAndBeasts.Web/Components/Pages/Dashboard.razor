    private async Task EquipBeastAsync(Guid targetSlotId, Guid playerItemId)
    {
        if (_profile is null) throw new InvalidOperationException("Profile not loaded.");

        await using var Db = await DbFactory.CreateDbContextAsync();

        var targetSlot = await Db.PlayerBeastSlots
            .FirstOrDefaultAsync(s => s.Id == targetSlotId && s.PlayerProfileId == _profile.Id);

        if (targetSlot is null)
            throw new InvalidOperationException("Target beast slot not found.");

        var item = await Db.PlayerItems
            .Include(i => i.Template)
            .FirstOrDefaultAsync(i => i.Id == playerItemId && i.PlayerId == _profile.Id);

        if (item?.Template is null)
            throw new InvalidOperationException("Item not found in inventory.");

        if (item.Template.OwnerKind != ItemOwnerKind.Beast)
            throw new InvalidOperationException("Item is not a Beast unit item.");

        if (item.Template.MonsterTemplateId is null)
            throw new InvalidOperationException("Item template is not a beast unit template.");

        if (item.LinkedMonsterInstanceId is null)
        {
            var beast = new PlayerMonster
            {
                Id = Guid.NewGuid(),
                PlayerId = _profile.Id,
                TemplateId = item.Template.MonsterTemplateId.Value,
                Level = item.Level
            };

            beast.Equipment = new List<BeastEquipmentSlot>();
            Db.PlayerMonsters.Add(beast);
            item.LinkedMonsterInstanceId = beast.Id;
        }
        else
        {
            var beast = await Db.PlayerMonsters
                .FirstOrDefaultAsync(b => b.Id == item.LinkedMonsterInstanceId && b.PlayerId == _profile.Id);

            if (beast is null)
                throw new InvalidOperationException("Linked beast instance not found.");

            beast.Level = item.Level;
        }

        var incomingInstanceId = item.LinkedMonsterInstanceId!.Value;

        var allSlots = await Db.PlayerBeastSlots
            .Where(s => s.PlayerProfileId == _profile.Id)
            .ToListAsync();

        var fromSlot = allSlots.FirstOrDefault(s => s.BeastInstanceId == incomingInstanceId);

        if (targetSlot.BeastInstanceId == incomingInstanceId)
        {
            await Db.SaveChangesAsync();
            return;
        }

        var targetOldInstanceId = targetSlot.BeastInstanceId;
        targetSlot.BeastInstanceId = incomingInstanceId;

        if (fromSlot is not null && fromSlot.Id != targetSlot.Id)
            fromSlot.BeastInstanceId = targetOldInstanceId;

        await Db.SaveChangesAsync();
    }

