    // ---------------- Stats UI ----------------
    private sealed record StatCol(string Header, Func<StatBlock?, object?> GetValue, Func<object?, string>? Format = null);
    private static readonly IReadOnlyList<StatCol> _statColumns = BuildStatColumns();

    private static List<StatCol> BuildStatColumns()
    {
        var t = typeof(StatBlock);

        var props = t.GetProperties(BindingFlags.Instance | BindingFlags.Public)
            .Where(p => p.CanRead && (p.PropertyType == typeof(int) || p.PropertyType == typeof(long) ||
                                     p.PropertyType == typeof(float) || p.PropertyType == typeof(double) ||
                                     p.PropertyType.IsEnum))
            .OrderBy(p => p.Name)
            .ToList();

        var cols = new List<StatCol>(props.Count);

        foreach (var p in props)
        {
            cols.Add(new StatCol(
                Header: HumanizeStatName(p.Name),
                GetValue: sb => sb is null ? null : p.GetValue(sb),
                Format: v => FormatStatValue(p, v)
            ));
        }

        return cols;
    }

    private static string HumanizeStatName(string name)
        => name switch
        {
            "MaxHp" => "HP",
            "Attack" => "ATK",
            "Defense" => "DEF",
            "Speed" => "SPD",
            "CritChance" => "Crit %",
            "CritMultiplier" => "Crit x",
            "ArmorPenetration" => "Pen",
            "Accuracy" => "Acc",
            "Evasion" => "Eva",
            "BlockChance" => "Block %",
            "DamageBonus" => "DMG +",
            "DamageReduction" => "DMG -",
            "TrueDamageBonus" => "True +",
            "TurnMeterGain" => "TM +",
            "CooldownReduction" => "CDR",
            "ActionCostReduction" => "Cost -",
            "LifeSteal" => "LS",
            "HpRegen" => "Regen",
            "EnergyRegen" => "E.Regen",
            "StatusDurationBonus" => "Status +",
            "StatusResistance" => "Status Res",
            _ => name
        };

    private static string FormatStatValue(PropertyInfo p, object? value)
    {
        if (value is null) return "-";

        if (p.PropertyType.IsEnum)
            return value.ToString()!;

        if (p.Name.EndsWith("Chance") || p.Name.EndsWith("Bonus") || p.Name.EndsWith("Reduction") || p.Name.EndsWith("Gain"))
        {
            var d = Convert.ToDouble(value);
            return (d * 100).ToString("0.##") + "%";
        }

        return value switch
        {
            float f => f.ToString("0.##", CultureInfo.InvariantCulture),
            double d => d.ToString("0.##", CultureInfo.InvariantCulture),
            _ => value.ToString()!
        };
    }

    private StatBlock GetFinalStats(PlayerItem it)
    {
        if (it?.Template is null) return StatBlock.Zero;
        return it.Template.CalculateStats(it);
    }

    private static bool IsStatZero(object? v)
    {
        if (v is null) return true;
        return v switch
        {
            int i => i == 0,
            long l => l == 0,
            float f => Math.Abs(f) < 0.000001f,
            double d => Math.Abs(d) < 0.000001,
            _ => false
        };
    }

