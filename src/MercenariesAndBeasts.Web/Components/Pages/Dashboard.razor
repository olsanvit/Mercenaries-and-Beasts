@page "/"
@attribute [Authorize]
@rendermode InteractiveServer

@using MercenariesAndBeasts.Domain.Items
@using MercenariesAndBeasts.Domain.Localization
@using MercenariesAndBeasts.Domain.Utils
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using MercenariesAndBeasts.Domain.Players
@using System.Security.Claims
@using System.Reflection
@using System.Globalization
@using static MercenariesAndBeasts.Domain.Items.ItemTemplate

@inject UserManager<AppUser> UserManager
@inject ToastService Toasts

@if (_isLoading)
{
    <p>Loading...</p>
}
else if (_profile is null)
{
    <div class="card-like">
        <h4>No profile</h4>
        <p>PlayerProfile was not created yet.</p>
    </div>
}
else
{
    <div class="card-like mb-3 player-bar">
        <div class="player-bar-left">
            <span class="player-email">@_userEmail</span>

            <span class="player-stat">
                <b>Lv</b> @_profile.Level
            </span>

            <span class="player-stat">
                <b>XP</b> @_profile.Experience
            </span>

            <span class="player-stat">
                <b>Energy</b> @_profile.Energy / @_profile.MaxEnergy
            </span>
        </div>

        <div class="player-bar-right">
            <span class="currency soft">
                <b>Soft:</b> @_profile.SoftCurrency
            </span>
            <span class="currency premium">
                <b>Premium:</b> @_profile.PremiumCurrency
            </span>
        </div>
    </div>

    <ul class="nav nav-pills mb-3">
        <li class="nav-item">
            <button class="nav-link @(ActiveTab == Tab.Mercenaries ? "active" : "")"
                    @onclick="() => ActiveTab = Tab.Mercenaries">
                Orders (@_mercSlots.Count(s => s.MercenaryInstanceId != null))/5
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(ActiveTab == Tab.Beasts ? "active" : "")"
                    @onclick="() => ActiveTab = Tab.Beasts">
                Beasts (@_beastSlots.Count(s => s.BeastInstanceId != null))/5
            </button>
        </li>
    </ul>

    @if (ActiveTab == Tab.Mercenaries)
    {
        <div class="row g-3">
            <div class="col-12 col-lg-2">
                <div class="card-like">
                    <div class="text-secondary mb-2">Order Slots</div>

                    <div class="d-grid" style="gap:10px;">
                        @foreach (var s in _mercSlots.OrderBy(x => x.SlotIndex))
                        {
                            var tpl = s.Mercenary?.Template;
                            var name = tpl == null ? null : GetLocalizedName(tpl);
                            var isActive = s.SlotIndex == _activeMercSlotIndex;

                            <button class="btn @(isActive ? "btn-primary" : "btn-outline-secondary")"
                                    @ondragover:preventDefault
                                    @ondrop="() => OnDropToMercSlot(s)"
                                    @onclick="() => SelectMercSlot(s.SlotIndex)">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span>@s.SlotIndex</span>

                                    @if (s.Mercenary?.Template is null)
                                    {
                                        <span class="badge bg-secondary">Empty</span>
                                    }
                                    else
                                    {
                                        <span class="slot-name">@name</span>
                                    }
                                </div>
                            </button>
                        }
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-10">
                @if (ActiveMercSlot is null)
                {
                    <div class="card-like">
                        <div class="text-secondary">No slot selected.</div>
                    </div>
                }
                else
                {
                    var slot = ActiveMercSlot;

                    <div class="card-like"
                         @ondragover:preventDefault
                         @ondrop="() => OnDropToMercSlot(slot)">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div>
                                <div class="text-secondary">Active slot</div>
                            </div>

                            @if (slot.MercenaryInstanceId is null)
                            {
                                <span class="badge bg-secondary">Empty</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Equipped</span>
                            }
                        </div>

                        @if (slot?.Mercenary?.Template is null)
                        {
                            <div class="text-secondary">
                                No order equipped. Drag an <b>Order</b> here (or click equip in inventory).
                            </div>
                        }
                        else
                        {
                            var m = slot.Mercenary;
                            var t = m.Template;

                            <div class="d-flex gap-3">
                                @if (!string.IsNullOrWhiteSpace(t.ImagePath))
                                {
                                    <img src="@t.ImagePath" style="width:72px;height:72px;object-fit:cover;border-radius:14px;" />
                                }
                                else
                                {
                                    <div style="width:72px;height:72px;border-radius:14px;background:rgba(255,255,255,0.06);"></div>
                                }

                                <div style="min-width:0;">
                                    <div style="font-weight:800;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                        @GetLocalizedName(slot.Mercenary.Template)
                                    </div>
                                    <div class="text-secondary">
                                        Lv @m.BaseLevel · @t.Element
                                    </div>
                                </div>
                            </div>

                            <hr />

                            <div class="row g-3">
                                <div class="col-12 col-lg-6">
                                    <div class="detail-section-title">Equipment</div>

                                    @if (m.Equipment is null || m.Equipment.Count == 0)
                                    {
                                        <div class="text-secondary">No equipment slots.</div>
                                    }
                                    else
                                    {
                                        <div class="equip-grid">
                                            @foreach (MercenaryEquipmentSlot eq in m.Equipment.OrderBy(e => (int)e.Slot))
                                            {
                                                <div class="equip-slot">
                                                    <div class="equip-slot-name">@eq.Slot</div>

                                                    @if (eq.PlayerItem is null)
                                                    {
                                                        <div class="equip-slot-item text-secondary">Empty</div>
                                                    }
                                                    else
                                                    {
                                                        var it = eq.PlayerItem;
                                                        var tIt = it.Template;

                                                        <div class="equip-slot-item">
                                                            <div class="equip-item-title">
                                                                @(tIt?.NameEn ?? "Item")
                                                            </div>
                                                            <div class="equip-item-meta text-secondary">
                                                                Lv @it.Level · @it.Quality
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>

                                <div class="col-12 col-lg-6">
                                    <div class="detail-section-title">Stats</div>

                                    <div class="stats-grid">
                                        @foreach (var col in _statColumns)
                                        {
                                            var raw = col.GetValue(t.BaseStats);
                                            if (raw is null) { continue; }

                                            <div class="stat-row">
                                                <span class="k">@col.Header</span>
                                                <span class="v">
                                                    @(col.Format?.Invoke(raw) ?? raw.ToString())
                                                </span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="row g-3">
            <div class="col-12 col-lg-2">
                <div class="card-like">
                    <div class="text-secondary mb-2">Beast Slots</div>

                    <div class="d-grid" style="gap:10px;">
                        @foreach (var s in _beastSlots.OrderBy(x => x.SlotIndex))
                        {
                            var tpl = s.Beast?.Template;
                            var name = tpl == null ? null : GetLocalizedName(tpl);
                            var isActive = s.SlotIndex == _activeBeastSlotIndex;

                            <button class="btn @(isActive ? "btn-primary" : "btn-outline-secondary")"
                                    @ondragover:preventDefault
                                    @ondrop="() => OnDropToBeastSlot(s)"
                                    @onclick="() => SelectBeastSlot(s.SlotIndex)">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span>@s.SlotIndex</span>
                                    @if (s.BeastInstanceId is null)
                                    {
                                        <span class="badge bg-secondary">Empty</span>
                                    }
                                    else
                                    {
                                        <span class="slot-name">@name</span>
                                    }
                                </div>
                            </button>
                        }
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-10">
                @if (ActiveBeastSlot is null)
                {
                    <div class="card-like">
                        <div class="text-secondary">No slot selected.</div>
                    </div>
                }
                else
                {
                    var slot = ActiveBeastSlot;

                    <div class="card-like"
                         @ondragover:preventDefault
                         @ondrop="() => OnDropToBeastSlot(slot)">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div>
                                <div class="text-secondary">Active slot</div>
                            </div>

                            @if (slot.BeastInstanceId is null)
                            {
                                <span class="badge bg-secondary">Empty</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Equipped</span>
                            }
                        </div>

                        @if (slot.Beast is null)
                        {
                            <div class="text-secondary">
                                No beast equipped. Drag a <b>Beast</b> here (or click equip in inventory).
                            </div>
                        }
                        else
                        {
                            var b = slot.Beast;
                            var t = b.Template;

                            <div class="d-flex gap-3">
                                @if (!string.IsNullOrWhiteSpace(t.ImagePath))
                                {
                                    <img src="@t.ImagePath" style="width:72px;height:72px;object-fit:cover;border-radius:14px;" />
                                }
                                else
                                {
                                    <div style="width:72px;height:72px;border-radius:14px;background:rgba(255,255,255,0.06);"></div>
                                }

                                <div style="min-width:0;">
                                    <div style="font-weight:800;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                        @GetLocalizedName(slot.Beast.Template)
                                    </div>
                                    <div class="text-secondary">
                                        Lv @b.Level · @t.Element · @b.Rank
                                    </div>
                                </div>
                            </div>

                            <hr />

                            <div class="row g-3">
                                <div class="col-12 col-lg-6">
                                    <div class="detail-section-title">Equipment</div>

                                    @if (b.Equipment is null || b.Equipment.Count == 0)
                                    {
                                        <div class="text-secondary">No equipment slots.</div>
                                    }
                                    else
                                    {
                                        <div class="equip-grid">
                                            @foreach (var eq in b.Equipment.OrderBy(e => (int)e.Slot))
                                            {
                                                <div class="equip-slot">
                                                    <div class="equip-slot-name">@eq.Slot</div>

                                                    @if (eq.PlayerItem is null)
                                                    {
                                                        <div class="equip-slot-item text-secondary">Empty</div>
                                                    }
                                                    else
                                                    {
                                                        var it = eq.PlayerItem;
                                                        var tIt = it.Template;

                                                        <div class="equip-slot-item">
                                                            <div class="equip-item-title">
                                                                @(tIt?.NameEn ?? "Item")
                                                            </div>
                                                            <div class="equip-item-meta text-secondary">
                                                                Lv @it.Level · @it.Quality
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>

                                <div class="col-12 col-lg-6">
                                    <div class="detail-section-title">Stats</div>

                                    <div class="stats-grid">
                                        @foreach (var col in _statColumns)
                                        {
                                            var raw = col.GetValue(t.BaseStats);
                                            if (raw is null) { continue; }

                                            <div class="stat-row">
                                                <span class="k">@col.Header</span>
                                                <span class="v">
                                                    @(col.Format?.Invoke(raw) ?? raw.ToString())
                                                </span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }

    <hr class="my-4" />

    <div class="card-like">
        <div class="d-flex justify-content-between align-items-center">
            <h3 class="m-0">Inventory</h3>
            @*
            @if (ActiveTab == Tab.Mercenaries)
            {
                <div class="text-secondary">Orders: @FilterOrderInventoryByTab().Count</div>
            }
            else
            {
                <div class="text-secondary">Beasts: @FilterBeastInventoryByTab().Count</div>
            }*@
        </div>

        @if (ActiveTab == Tab.Mercenaries)
        {
            <div class="inv-tabs">
                @foreach (var tab in _orderTabs)
                {
                    var active = tab.Key == _activeOrderTab.Key;

                    <div class="inv-tab @(active ? "active" : "")"
                         @onclick="() => _activeOrderTab = tab">
                        <div class="inv-tab-title">@tab.Label</div>
                        <div class="inv-tab-sub">@CountOrderTab(tab)</div>
                    </div>
                }
            </div>

            var items = FilterOrderInventoryByTab()
                .OrderByDescending(x => x.Quality)
                .ThenByDescending(x => x.Level)
                .ToList();

            @if (items.Count == 0)
            {
                <div class="text-secondary mt-3">No items in this category.</div>
            }
            else
            {
                <div class="inv-grid inv-grid-5">
                    @foreach (var vm in items.Select(it => _invVmsById.TryGetValue(it.Id, out var v) ? v : null).Where(x => x != null))
                    {
                        var it = vm!.Item;
                        var t = it.Template;

                        <div class="inv-card card-like p-0"
                             draggable="true"
                             @ondragstart="() => DragItem(it)">

                            <div class="inv-card-header px-3 py-2 border-bottom d-flex align-items-start justify-content-between @GetQualityHeaderClass(it.Quality)">
                                <div class="me-2" style="min-width:0; width:100%;">
                                    <div class="fw-bold text-truncate">@t.NameEn</div>

                                    <div class="d-flex justify-content-between align-items-center mt-1">
                                        <span class="badge bg-secondary">@vm.BadgeTier</span>
                                        <div class="text-secondary small mb-1">Badge</div>
                                        <button type="button"
                                                class="btn btn-sm btn-outline-light"
                                                title="Details"
                                                @onclick="() => OpenItemModal(vm)">
                                            👁
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <div class="inv-card-body px-3 py-3 text-center">
                                @if (!string.IsNullOrWhiteSpace(t.ImagePath))
                                {
                                    <img src="@t.ImagePath"
                                         style="width:96px;height:96px;object-fit:cover;border-radius:14px;" />
                                }
                                else
                                {
                                    <div style="width:96px;height:96px;border-radius:14px;background:rgba(255,255,255,0.06);margin:0 auto;"></div>
                                }

                                <div class="text-secondary mt-2 small">
                                    Q@((int)it.Quality) · Lv @it.Level
                                </div>

                                @if (IsGear(it))
                                {
                                    <div class="text-secondary small">
                                        Slot: @(it.Template.MercenarySlot?.ToString() ?? "-")
                                    </div>
                                }
                                else if (IsOrderUnitItem(it))
                                {
                                    <div class="text-secondary small">Order unit</div>
                                }
                            </div>

                            <div class="inv-card-footer px-3 py-2 border-top">
                                <div class="d-flex justify-content-between text-secondary small mb-1">
                                    <span>Wins</span>
                                    <span>@vm.WinsNow / @(vm.WinsNeed == 0 ? vm.WinsNow : vm.WinsNeed)</span>
                                </div>

                                <div class="progress" style="height:10px;">
                                    <div class="progress-bar" style="width:@vm.WinsPct%"></div>
                                </div>

                                @if (vm.Resources.Count > 0)
                                {
                                    <div class="mt-2" style="display:flex;flex-direction:column;gap:4px;">
                                        @foreach (var r in vm.Resources)
                                        {
                                            <div class="d-flex justify-content-between text-secondary small">
                                                <span>@r.Name</span>
                                                <span>@r.Have / @r.Need</span>
                                            </div>
                                            <div class="progress" style="height:10px;">
                                                <div class="progress-bar" style="width:@r.Have / @r.Need%"></div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <div class="inv-tabs">
                @foreach (var tab in _beastTabs)
                {
                    var active = tab.Key == _activeBeastTab.Key;

                    <div class="inv-tab @(active ? "active" : "")"
                         @onclick="() => _activeBeastTab = tab">
                        <div class="inv-tab-title">@tab.Label</div>
                        <div class="inv-tab-sub">@CountBeastTab(tab)</div>
                    </div>
                }
            </div>

            var items = FilterBeastInventoryByTab()
                .OrderByDescending(x => x.Quality)
                .ThenByDescending(x => x.Level)
                .ToList();

            @if (items.Count == 0)
            {
                <div class="text-secondary mt-3">No items in this category.</div>
            }
            else
            {
                <div class="inv-grid inv-grid-5">
                    @foreach (var vm in items.Select(it => _invVmsById.TryGetValue(it.Id, out var v) ? v : null).Where(x => x != null))
                    {
                        var it = vm!.Item;
                        var t = it.Template;

                        <div class="inv-card card-like p-0"
                             draggable="true"
                             @ondragstart="() => DragItem(it)">

                            <div class="inv-card-header px-3 py-2 border-bottom d-flex align-items-start justify-content-between @GetQualityHeaderClass(it.Quality)">
                                <div class="me-2" style="min-width:0; width:100%;">
                                    <div class="fw-bold text-truncate">@t.NameEn</div>

                                    <div class="d-flex justify-content-between align-items-center mt-1">
                                        <div class="badge bg-secondary">@it.BadgeTier</div>
                                        <button type="button"
                                                class="btn btn-sm btn-outline-light"
                                                title="Details"
                                                @onclick="() => OpenItemModal(vm)">
                                            👁
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <div class="inv-card-body px-3 py-3 text-center">
                                @if (!string.IsNullOrWhiteSpace(t.ImagePath))
                                {
                                    <img src="@t.ImagePath"
                                         style="width:96px;height:96px;object-fit:cover;border-radius:14px;" />
                                }
                                else
                                {
                                    <div style="width:96px;height:96px;border-radius:14px;background:rgba(255,255,255,0.06);margin:0 auto;"></div>
                                }

                                <div class="text-secondary mt-2 small">
                                    Q@((int)it.Quality) · Lv @it.Level
                                </div>

                                @if (IsGear(it))
                                {
                                    <div class="text-secondary small">
                                        Slot: @(it.Template.MonsterSlot?.ToString() ?? "-")
                                    </div>
                                }
                                else if (IsBeastUnitItem(it))
                                {
                                    <div class="text-secondary small">Beast unit</div>
                                }
                            </div>

                            <div class="inv-card-footer px-3 py-2 border-top">
                                <div class="d-flex justify-content-between text-secondary small mb-1">
                                    <span>Wins</span>
                                    <span>@vm.WinsNow / @(vm.WinsNeed == 0 ? vm.WinsNow : vm.WinsNeed)</span>
                                </div>

                                <div class="progress" style="height:10px;">
                                    <div class="progress-bar" style="width:@vm.WinsPct%"></div>
                                </div>

                                @if (vm.Resources.Count > 0)
                                {
                                    <div class="mt-2" style="display:flex;flex-direction:column;gap:4px;">
                                        @foreach (var r in vm.Resources)
                                        {
                                            <div class="d-flex justify-content-between text-secondary small">
                                                <span>@r.Name</span>
                                                <span>@r.Have / @r.Need</span>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        }
    </div>

    @if (_showItemModal && _activeItemVm is not null)
{
    var it = _activeItemVm.Item;
    var t = it.Template;

    ItemEquipSlot? slot = t.MercenarySlot ?? t.MonsterSlot;
    var slotName = slot.HasValue ? HumanizeSlot(slot.Value) : null;

    <div class="modal-backdrop-blazor" @onclick="CloseItemModal">
        <div class="modal-card-blazor modal-item" @onclick:stopPropagation>

            <!-- HEADER -->
            <div class="modal-item-head">
                <div class="modal-item-head-left">
                    <div class="modal-title-row">
                        <h3 class="m-0 text-truncate">@t.NameEn</h3>
                    </div>

                    <div class="modal-sub text-secondary text-truncate">

                        <div class="text-secondary small mb-1">@it.BadgeTier</div>

                        Q@((int)it.Quality) · Lvl @it.Level · @t.OwnerKind
                        @if (!string.IsNullOrWhiteSpace(slotName))
                        {
                            <span> · @slotName</span>
                        }
                    </div>
                </div>

                <button type="button" class="btn btn-sm btn-outline-light modal-close"
                        @onclick="CloseItemModal">✕</button>
            </div>

            <hr class="my-3" />

            <!-- BODY -->
            <div class="modal-item-body">

                <div class="modal-item-top">
                    @if (!string.IsNullOrWhiteSpace(t.ImagePath))
                    {
                        <img src="@t.ImagePath" class="modal-item-img" />
                    }
                    else
                    {
                        <div class="modal-item-img placeholder"></div>
                    }

                    @if (_activeItemVm.Resources.Count > 0)
                    {
                        <div class="resources-3col">
                            @foreach (var r in _activeItemVm.Resources.OrderBy(x => x.Type))
                            {
                                <div class="res-card">
                                    <div class="res-title text-secondary small">@r.Name</div>
                                    <div class="res-count fw-bold">@r.Have / @r.Need</div>

                                    <button type="button"
                                            class="btn btn-sm btn-primary w-100 mt-2"
                                            disabled="@(!r.CanUpgrade)"
                                            @onclick="async () => await UpgradeItemAsync(_activeItemVm, r)">
                                        Upgrade
                                    </button>
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- Badge / wins -->
                <div class="mt-3">
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge bg-secondary">@_activeItemVm.BadgeTier</span>
                        <span class="text-secondary small">
                            Wins: @_activeItemVm.WinsNow / @(_activeItemVm.WinsNeed == 0 ? _activeItemVm.WinsNow : _activeItemVm.WinsNeed)
                        </span>
                    </div>

                    <div class="progress mt-2" style="height:10px;">
                        <div class="progress-bar" style="width:@_activeItemVm.WinsPct%"></div>
                    </div>
                </div>

            </div>

            <!-- FOOTER (STATS) -->
            <div class="modal-item-foot">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div class="text-secondary small">Stats</div>
                    <div class="text-secondary small">
                        Lv @it.Level → next Lv @(it.Level + 1)
                    </div>
                </div>

                @{
                    var currSb = GetFinalStats(it);

                    var nextIt = new PlayerItem
                    {
                        Id = it.Id,
                        PlayerId = it.PlayerId,
                        TemplateId = it.TemplateId,
                        Template = it.Template,
                        Level = it.Level + 1,
                        Quality = it.Quality,
                        BonusStats = it.BonusStats,
                        Wins = it.Wins
                    };

                    var nextSb = GetFinalStats(nextIt);
                }

                <div class="stats-grid-cards">
                    @foreach (var col in _statColumns)
                    {
                        var c = col.GetValue(currSb);
                        var n = col.GetValue(nextSb);

                        if (IsStatZero(c) && IsStatZero(n))
                            continue;

                        <div class="stat-card">
