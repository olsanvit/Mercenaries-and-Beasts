    private async Task SaveProfileSetupAsync()
{
    if (_profile is null || string.IsNullOrWhiteSpace(_userId))
        return;

    var cc = (_setup.CountryCode ?? "").Trim().ToUpperInvariant();
    var un = (_setup.UserName ?? "").Trim();

    if (cc.Length != 2)
    {
        Toasts.Error("Pick a valid country.", "Profile");
        return;
    }

    if (!IsValidUserName(un))
    {
        Toasts.Error("Username is invalid.", "Profile");
        return;
    }

    await using (var db = await DbFactory.CreateDbContextAsync())
    {
        var prof = await db.Players.FirstOrDefaultAsync(p => p.UserId == _userId);
        if (prof is null)
        {
            Toasts.Error("Profile not found.", "Profile");
            return;
        }

        prof.CountryCode = cc;
        await db.SaveChangesAsync();
    }

    var authState = await AuthStateProvider.GetAuthenticationStateAsync();
    var principal = authState.User;
    var appUser = await UserManager.GetUserAsync(principal);

    if (appUser is null)
    {
        Toasts.Error("User not found.", "Profile");
        return;
    }

    appUser.UserName = un;
    appUser.NormalizedUserName = UserManager.NormalizeName(un);

    var res = await UserManager.UpdateAsync(appUser);
    if (!res.Succeeded)
    {
        var msg = string.Join("; ", res.Errors.Select(e => e.Description));
        Toasts.Error(msg, "Profile");
        return;
    }

    _showProfileSetupModal = false;
    Toasts.Success("Profile saved.", "Profile");

    await LoadAsync();
}
private static bool IsValidUserName(string s)
{
    if (string.IsNullOrWhiteSpace(s))
        return false;

    if (s.Length < 3 || s.Length > 20)
        return false;

    foreach (var ch in s)
    {
        var ok =
            char.IsLetterOrDigit(ch) ||
            ch == '_' ||
            ch == '-' ||
            ch == '.';

        if (!ok)
            return false;
    }

    return true;
}
