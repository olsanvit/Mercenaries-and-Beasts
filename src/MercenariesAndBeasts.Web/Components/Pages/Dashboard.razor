    private void BuildInventoryVms()
    {
        _invVms = new List<InvItemVm>(_inventory.Count);

        foreach (var it in _inventory)
        {
            var tier = ItemBadgeRules.ComputeTier(it.Wins);

            var winsNow = it.Wins;
            var winsNeed = GetNextTierWinsNeed(tier);
            var pct = winsNeed <= 0 ? 100 : Math.Clamp((int)(winsNow * 100.0 / winsNeed), 0, 100);

            var res = BuildResources(it);

            _invVms.Add(new InvItemVm
            {
                Item = it,
                BadgeTier = tier,
                WinsNow = winsNow,
                WinsNeed = winsNeed,
                WinsPct = pct,
                Resources = res
            });
        }

        _invVmsById = _invVms.ToDictionary(x => x.Item.Id, x => x);
    }

    private List<InvResVm> BuildResources(PlayerItem it)
    {
        var t = it.Template;
        if (t?.UpgradeResources is null || t.UpgradeResources.Count == 0)
            return new();

        var havePieces = _piecesByTemplateId.TryGetValue(t.Id, out var pcs) ? pcs : 0;

        long BaseCost(ItemUpgradeResourceType type)
            => t.UpgradeResources.FirstOrDefault(x => x.Type == type)?.DefaultAmount ?? 0;

        long Need(ItemUpgradeResourceType type)
        {
            var baseCost = BaseCost(type);
            if (baseCost <= 0) return 0;

            return type switch
            {
                ItemUpgradeResourceType.Core =>
                    baseCost * Math.Max(1, it.Level),

                ItemUpgradeResourceType.Catalyst =>
                    baseCost * (1L << Math.Max(0, ((int)it.Quality) - 1)),

                ItemUpgradeResourceType.Essence =>
                    baseCost * Math.Max(1, it.Level / 2),

                _ => 0
            };
        }

        var list = new List<InvResVm>();

        foreach (var r in t.UpgradeResources.OrderBy(x => x.Type))
        {
            var need = Need(r.Type);

            list.Add(new InvResVm
            {
                Type = r.Type,
                Name = r.Type.ToString(),
                Have = havePieces,
                Need = need
            });
        }

        return list;
    }

    private static int GetNextTierWinsNeed(ItemBadgeTier tier)
        => tier switch
        {
            ItemBadgeTier.None => 5,
            ItemBadgeTier.Bronze => 15,
            ItemBadgeTier.Silver => 40,
            ItemBadgeTier.Gold => 100,
            ItemBadgeTier.Platinum => 250,
            _ => 0
        };

