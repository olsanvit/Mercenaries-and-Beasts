@page "/"
@attribute [Authorize]
@rendermode InteractiveServer

@using MercenariesAndBeasts.Domain.Items
@using MercenariesAndBeasts.Domain.Localization
@using MercenariesAndBeasts.Domain.Utils
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using MercenariesAndBeasts.Domain.Players
@using System.Security.Claims
@using System.Reflection
@using System.Globalization
@using static MercenariesAndBeasts.Domain.Items.ItemTemplate
@using MercenariesAndBeasts.Web.Components
@using MercenariesAndBeasts.Infrastructure
@using MercenariesAndBeasts.Infrastructure.Players
@using Microsoft.AspNetCore.Components.Authorization

@inject UserManager<AppUser> UserManager
@inject ToastService Toasts
@inject IDbContextFactory<MercenariesAndBeastsDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject PlayerOnboardingService Onboarding

@if (_isLoading)
{
    <p>Loading...</p>
}
else if (_profile is null)
{
    <div class="card-like">
        <h4>No profile</h4>
        <p>PlayerProfile was not created yet.</p>
    </div>
}
else
{
    <div class="dash-layout">
        <div class="dash-switcher mb-3">
            <ul class="nav nav-pills m-0">
                <li class="nav-item">
                    <button class="nav-link @(ActiveTab == Tab.Mercenaries ? "active" : "")"
                            @onclick="() => ActiveTab = Tab.Mercenaries">
                        Orders @_mercSlots.Count(s => s.MercenaryInstanceId != null)/5
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(ActiveTab == Tab.Beasts ? "active" : "")"
                            @onclick="() => ActiveTab = Tab.Beasts">
                        Beasts @_beastSlots.Count(s => s.BeastInstanceId != null)/5
                    </button>
                </li>
            </ul>
        </div>

        @if (ActiveTab == Tab.Mercenaries)
        {
            <MercenariesPanel
                MercSlots="_mercSlots"
                ActiveMercSlotIndex="_activeMercSlotIndex"
                ActiveMercSlot="ActiveMercSlot"
                OrderTabs="GetOrderTabsForView()"
                ActiveOrderTabKey="_activeOrderTab.Key"
                InventoryItems="GetMercInventoryItems()"
                OnSelectMercSlot="SelectMercSlot"
                OnDropToMercSlot="OnDropToMercSlot"
                OnOrderTabSelected="SetActiveOrderTab"
                OnInventoryDragStart="OnInventoryDragStart"
                OnOpenItemModal="OpenItemModalFromItem"
                GetLocalizedName="GetLocalizedName"
                GetQualityHeaderClass="GetQualityHeaderClass"
                GetBadgeTierText="GetBadgeTierText"
                GetWinsNow="GetWinsNow"
                GetWinsNeed="GetWinsNeed"
                GetWinsPct="GetWinsPct"
                GetResources="GetResourcesTuple"
                CanDragInventoryItem="CanDragInventoryItem" />
        }
        else
        {
            <BeastsPanel
                BeastSlots="_beastSlots"
                ActiveBeastSlotIndex="_activeBeastSlotIndex"
                ActiveBeastSlot="ActiveBeastSlot"
                BeastTabs="GetBeastTabsForView()"
                ActiveBeastTabKey="_activeBeastTab.Key"
                InventoryItems="GetBeastInventoryItems()"
                OnSelectBeastSlot="SelectBeastSlot"
                OnDropToBeastSlot="OnDropToBeastSlot"
                OnBeastTabSelected="SetActiveBeastTab"
                OnInventoryDragStart="OnInventoryDragStart"
                OnOpenItemModal="OpenItemModalFromItem"
                GetLocalizedName="GetLocalizedName"
                GetQualityHeaderClass="GetQualityHeaderClass"
                GetBadgeTierText="GetBadgeTierText"
                GetWinsNow="GetWinsNow"
                GetWinsNeed="GetWinsNeed"
                GetWinsPct="GetWinsPct"
                GetResources="GetResourcesTuple"
                CanDragInventoryItem="CanDragInventoryItem" />
        }
    </div>

    @if (_showItemModal && _activeItemVm is not null)
    {
        var it = _activeItemVm.Item;
        var t = it.Template;

        ItemEquipSlot? slot = t.MercenarySlot ?? t.MonsterSlot;
        var slotName = slot.HasValue ? HumanizeSlot(slot.Value) : null;

        <div class="modal-backdrop-blazor" @onclick="CloseItemModal">
            <div class="modal-card-blazor modal-item" @onclick:stopPropagation>
                <div class="modal-item-head">
                    <div class="modal-head-row-1">
                        <div class="modal-head-left">
                            @if (!string.IsNullOrWhiteSpace(t.ImagePath))
                            {
                                <img src="@t.ImagePath" class="modal-item-img-head" />
                            }
                            else
                            {
                                <div class="modal-item-img-head placeholder"></div>
                            }

                            <div style="min-width:0;">
                                <h3 class="m-0 text-truncate">@t.NameEn</h3>
                                <div class="text-secondary small text-truncate mt-1">
                                    @_activeItemVm.BadgeTier · Q@((int)it.Quality) · Lvl @it.Level · @t.OwnerKind
                                    @if (!string.IsNullOrWhiteSpace(slotName))
                                    {
                                        <span> · @slotName</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="modal-head-row-2">
                        <div class="d-flex align-items-center gap-3 flex-grow-1">
                            <span class="text-secondary small">
                                Wins: @_activeItemVm.WinsNow /
                                @(_activeItemVm.WinsNeed == 0 ? _activeItemVm.WinsNow : _activeItemVm.WinsNeed)
                            </span>

                            <div class="progress flex-grow-1" style="height:8px;">
                                <div class="progress-bar" style="width:@_activeItemVm.WinsPct%"></div>
                            </div>
                        </div>

                        <button type="button"
                                class="btn btn-sm btn-outline-light modal-close ms-3"
                                @onclick="CloseItemModal">✕</button>
                    </div>
                </div>

                <hr class="my-2" />

                <div class="modal-item-body modal-body-scroll">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="text-secondary small">Stats</div>
                        <div class="text-secondary small">
                            Lv @it.Level → next Lv @(it.Level + 1)
                        </div>
                    </div>

                    @{
                        var currSb = GetFinalStats(it);

                        var nextIt = new PlayerItem
                        {
                            Id = it.Id,
                            PlayerId = it.PlayerId,
                            TemplateId = it.TemplateId,
                            Template = it.Template,
                            Level = it.Level + 1,
                            Quality = it.Quality,
                            BonusStats = it.BonusStats,
                            Wins = it.Wins
                        };

                        var nextSb = GetFinalStats(nextIt);
                    }

                    <div class="stats-grid-cards">
                        @foreach (var col in _statColumns)
                        {
                            var c = col.GetValue(currSb);
                            var n = col.GetValue(nextSb);

                            if (IsStatZero(c) && IsStatZero(n))
                                continue;

                            <div class="stat-card">
                                <div class="stat-card-k">@col.Header</div>
                                <div class="stat-card-v">
                                    <span class="fw-bold">
                                        @(col.Format?.Invoke(c) ?? c?.ToString() ?? "-")
                                    </span>
                                    <span class="text-secondary ms-2">
                                        (next: @(col.Format?.Invoke(n) ?? n?.ToString() ?? "-"))
                                    </span>
                                </div>
                            </div>
                        }
                    </div>

                    @if (it.BonusStats is not null)
                    {
                        <div class="text-secondary small mt-2">
                            Includes BonusStats (prefix/suffix/enchant).
                        </div>
                    }
                </div>

                <div class="modal-item-foot">
                    @if (_activeItemVm.Resources.Count > 0)
                    {
                        <div class="resources-3col">
                            @foreach (var r in _activeItemVm.Resources.OrderBy(x => x.Type))
                            {
                                <div class="res-card">
                                    <div class="res-title text-secondary small">@r.Name</div>
                                    <div class="res-count fw-bold">@r.Have / @r.Need</div>

                                    <button type="button"
                                            class="btn btn-sm btn-primary w-100 mt-2"
                                            disabled="@(!r.CanUpgrade)"
                                            @onclick="async () => await UpgradeItemAsync(_activeItemVm, r)">
                                        Upgrade
                                    </button>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @if (_showProfileSetupModal)
    {
        <div class="modal-backdrop-blazor">
            <div class="modal-card-blazor">
                <h3>Complete your profile</h3>
                <p class="text-secondary">
                    Choose your country and set a public username.
                </p>

                <EditForm Model="_setup" OnValidSubmit="SaveProfileSetupAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-2">
                        <label class="form-label">Country</label>
                        <InputSelect class="form-select" @bind-Value="_setup.CountryCode">
                            <option value="">-- select --</option>
                            @foreach (var c in Countries)
                            {
                                <option value="@c.Code">@c.Name (@c.Code)</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Username</label>
                        <InputText class="form-control" @bind-Value="_setup.UserName" />
                        <div class="form-text">
                            3–20 chars, letters/numbers/._-
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <button class="btn btn-primary" type="submit">Save</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }
}

@code {
    private enum Tab { Mercenaries, Beasts }
    private Tab ActiveTab = Tab.Mercenaries;

    private bool _isLoading = true;
    private PlayerProfile? _profile;
    private string _userEmail = "";
    private ClaimsPrincipal? _user;
    private string? _userId;

    private List<PlayerItem> _inventory = new();
    private List<PlayerMercenarySlot> _mercSlots = new();
    private List<PlayerBeastSlot> _beastSlots = new();

    private int _activeMercSlotIndex = 1;
    private int _activeBeastSlotIndex = 1;

    private Guid? _draggedItemId;
    private Guid? _draggedFromSlotId;
    private Guid? _draggedFromBeastSlotId;

    private bool _showProfileSetupModal;

    private Dictionary<Guid, InvItemVm> _invVmsById = new();
    private List<InvItemVm> _invVms = new();

    private bool _showItemModal;
    private InvItemVm? _activeItemVm;

    private Dictionary<Guid, long> _piecesByTemplateId = new();

    private bool _itemUpgrading;

    private sealed class InvItemVm
    {
        public PlayerItem Item { get; init; } = null!;
        public ItemBadgeTier BadgeTier { get; init; }
        public int WinsNow { get; init; }
        public int WinsNeed { get; init; }
        public int WinsPct { get; init; }
        public List<InvResVm> Resources { get; init; } = new();
    }

    public sealed class InvResVm
    {
        public ItemUpgradeResourceType Type { get; init; }
        public string Name { get; init; } = "";
        public long Have { get; init; }
        public long Need { get; init; }
        public bool CanUpgrade => Need > 0 && Have >= Need;
    }

    private enum InvFilterKind { All, Units, GearSlot }
    private sealed record InvTabVm(string Key, string Label, InvFilterKind Kind, ItemEquipSlot? Slot = null);

    private IReadOnlyList<InvTabVm> _orderTabs = BuildOrderTabs();
    private IReadOnlyList<InvTabVm> _beastTabs = BuildBeastTabs();

    private InvTabVm _activeOrderTab = BuildOrderTabs().First();
    private InvTabVm _activeBeastTab = BuildBeastTabs().First();

    private PlayerBeastSlot? ActiveBeastSlot => _beastSlots?.FirstOrDefault(s => s.SlotIndex == _activeBeastSlotIndex);
    private PlayerMercenarySlot? ActiveMercSlot => _mercSlots?.FirstOrDefault(s => s.SlotIndex == _activeMercSlotIndex);

    private IReadOnlyList<(string Key, string Label, int Count)> GetOrderTabsForView()
        => _orderTabs.Select(x => (x.Key, x.Label, CountOrderTab(x))).ToList();

    private IReadOnlyList<(string Key, string Label, int Count)> GetBeastTabsForView()
        => _beastTabs.Select(x => (x.Key, x.Label, CountBeastTab(x))).ToList();

    private void SetActiveOrderTab(string key)
    {
        var tab = _orderTabs.FirstOrDefault(x => x.Key == key);
        if (tab is not null) _activeOrderTab = tab;
    }

    private void SetActiveBeastTab(string key)
    {
        var tab = _beastTabs.FirstOrDefault(x => x.Key == key);
        if (tab is not null) _activeBeastTab = tab;
    }

    private List<PlayerItem> GetMercInventoryItems() =>
        FilterOrderInventoryByTab()
            .OrderByDescending(x => x.Quality)
            .ThenByDescending(x => x.Level)
            .ToList();

    private List<PlayerItem> GetBeastInventoryItems() =>
        FilterBeastInventoryByTab()
            .OrderByDescending(x => x.Quality)
            .ThenByDescending(x => x.Level)
            .ToList();

    private string GetBadgeTierText(PlayerItem it)
        => _invVmsById.TryGetValue(it.Id, out var vm) ? vm.BadgeTier.ToString() : "-";

    private int GetWinsNow(PlayerItem it)
        => _invVmsById.TryGetValue(it.Id, out var vm) ? vm.WinsNow : 0;

    private int GetWinsNeed(PlayerItem it)
        => _invVmsById.TryGetValue(it.Id, out var vm) ? vm.WinsNeed : 0;

    private int GetWinsPct(PlayerItem it)
        => _invVmsById.TryGetValue(it.Id, out var vm) ? vm.WinsPct : 0;

    private IEnumerable<(string Name, long Have, long Need)> GetResourcesTuple(PlayerItem it)
        => _invVmsById.TryGetValue(it.Id, out var vm)
            ? vm.Resources.Select(r => (r.Name, r.Have, r.Need))
            : Enumerable.Empty<(string Name, long Have, long Need)>();

    private void OpenItemModal(InvItemVm vm)
    {
        _activeItemVm = vm;
        _showItemModal = true;
    }

    private void OpenItemModalFromItem(PlayerItem item)
    {
        if (_invVmsById.TryGetValue(item.Id, out var vm))
            OpenItemModal(vm);
    }

    private void CloseItemModal()
    {
        _showItemModal = false;
        _activeItemVm = null;
    }

    private void SelectBeastSlot(int idx) => _activeBeastSlotIndex = idx;
    private void SelectMercSlot(int idx) => _activeMercSlotIndex = idx;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private bool IsGear(PlayerItem it)
        => it.Template.MercenarySlot.HasValue || it.Template.MonsterSlot.HasValue;

    private bool IsOrderUnitItem(PlayerItem it)
        => it.Template.OwnerKind == ItemOwnerKind.Mercenary
           && (it.Template.IsUnitItem || it.Template.MercenaryTemplateId.HasValue);

    private bool IsBeastUnitItem(PlayerItem it)
        => it.Template.OwnerKind == ItemOwnerKind.Beast
           && (it.Template.IsUnitItem || it.Template.MonsterTemplateId.HasValue);

    private bool IsItemActiveInMercSlots(PlayerItem it)
        => IsOrderUnitItem(it)
           && it.LinkedMercenaryInstanceId.HasValue
           && _mercSlots.Any(s => s.MercenaryInstanceId == it.LinkedMercenaryInstanceId);

    private bool IsItemActiveInBeastSlots(PlayerItem it)
        => IsBeastUnitItem(it)
           && it.LinkedMonsterInstanceId.HasValue
           && _beastSlots.Any(s => s.BeastInstanceId == it.LinkedMonsterInstanceId);

    private bool CanDragInventoryItem(PlayerItem it)
    {
        if (IsOrderUnitItem(it))
            return !IsItemActiveInMercSlots(it);

        if (IsBeastUnitItem(it))
            return !IsItemActiveInBeastSlots(it);

        return true;
    }

    private void OnInventoryDragStart(PlayerItem it)
    {
        if (!CanDragInventoryItem(it))
            return;

        DragItem(it);
    }

    private static IReadOnlyList<InvTabVm> BuildOrderTabs()
    {
        var tabs = new List<InvTabVm>
        {
            new("all", "All", InvFilterKind.All)
        };

        var slots = Enum.GetValues<ItemEquipSlot>()
            .Where(s => s != ItemEquipSlot.None)
            .Where(ItemEquipSlotRules.IsMercSlot)
            .OrderBy(s => (int)s);

        foreach (var s in slots)
            tabs.Add(new InvTabVm(s.ToString(), HumanizeSlot(s), InvFilterKind.GearSlot, s));

        return tabs;
    }

    private static IReadOnlyList<InvTabVm> BuildBeastTabs()
    {
        var tabs = new List<InvTabVm>
        {
            new("all", "All", InvFilterKind.All)
        };

        var slots = Enum.GetValues<ItemEquipSlot>()
            .Where(s => s != ItemEquipSlot.None)
            .Where(ItemEquipSlotRules.IsBeastSlot)
            .OrderBy(s => (int)s);

        foreach (var s in slots)
            tabs.Add(new InvTabVm(s.ToString(), HumanizeSlot(s), InvFilterKind.GearSlot, s));

        return tabs;
    }

    private static string HumanizeSlot(ItemEquipSlot s)
    {
        var name = s.ToString();
        var idx = name.IndexOf('_');
        return idx >= 0 && idx < name.Length - 1 ? name[(idx + 1)..] : name;
    }

    private List<PlayerItem> FilterOrderInventoryByTab()
    {
        var baseList = _inventory
            .Where(i => i.Template.OwnerKind == ItemOwnerKind.Mercenary || i.Template.OwnerKind == ItemOwnerKind.None)
            .ToList();

        return _activeOrderTab.Kind switch
        {
            InvFilterKind.All => baseList,

            InvFilterKind.Units => baseList
                .Where(i => i.Template.OwnerKind == ItemOwnerKind.Mercenary)
                .Where(i => i.Template.IsUnitItem || i.Template.MercenaryTemplateId.HasValue)
                .ToList(),

            InvFilterKind.GearSlot when _activeOrderTab.Slot is null => baseList.Where(i => i.Template.MercenarySlot.HasValue).ToList(),

            InvFilterKind.GearSlot => baseList.Where(i => i.Template.MercenarySlot == _activeOrderTab.Slot).ToList(),

            _ => baseList
        };
    }

    private List<PlayerItem> FilterBeastInventoryByTab()
    {
        var baseList = _inventory
            .Where(i => i.Template.OwnerKind == ItemOwnerKind.Beast || i.Template.OwnerKind == ItemOwnerKind.None)
            .ToList();

        return _activeBeastTab.Kind switch
        {
            InvFilterKind.All => baseList,

            InvFilterKind.Units => baseList
                .Where(i => i.Template.OwnerKind == ItemOwnerKind.Beast)
                .Where(i => i.Template.IsUnitItem || i.Template.MonsterTemplateId.HasValue)
                .ToList(),

            InvFilterKind.GearSlot when _activeBeastTab.Slot is null => baseList.Where(i => i.Template.MonsterSlot.HasValue).ToList(),

            InvFilterKind.GearSlot => baseList.Where(i => i.Template.MonsterSlot == _activeBeastTab.Slot).ToList(),

            _ => baseList
        };
    }

    private int CountOrderTab(InvTabVm tab)
    {
        var prev = _activeOrderTab;
        _activeOrderTab = tab;
        var count = FilterOrderInventoryByTab().Count;
        _activeOrderTab = prev;
        return count;
    }

    private int CountBeastTab(InvTabVm tab)
    {
        var prev = _activeBeastTab;
        _activeBeastTab = tab;
        var count = FilterBeastInventoryByTab().Count;
        _activeBeastTab = prev;
        return count;
    }

    private void DragItem(PlayerItem it)
    {
        _draggedItemId = it.Id;
        _draggedFromSlotId = null;
        _draggedFromBeastSlotId = null;
        Toasts.Info($"Dragging: {it.Template.NameEn}", "Drag");
    }

    private async Task LoadAsync()
    {
        _isLoading = true;

        await using var Db = await DbFactory.CreateDbContextAsync();
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            _user = authState.User;

            if (!(_user?.Identity?.IsAuthenticated ?? false))
            {
                Toasts.Warning("Not authenticated", "Dashboard");
                return;
            }

            _userId = _user.FindFirstValue(ClaimTypes.NameIdentifier);
            _userEmail = _user.FindFirstValue(ClaimTypes.Email) ?? _user.Identity?.Name;

            if (string.IsNullOrWhiteSpace(_userId))
            {
                Toasts.Error("Missing user id claim", "Dashboard");
                return;
            }

            await Onboarding.EnsurePlayerInitializedAsync(_userId);

            _profile = await Db.Players
                .Include(p => p.MercenarySlots).ThenInclude(s => s.Mercenary).ThenInclude(m => m.Template)
                .Include(p => p.BeastSlots).ThenInclude(s => s.Beast).ThenInclude(b => b.Template)
                .Include(p => p.Inventory).ThenInclude(i => i.Template).ThenInclude(t => t.UpgradeResources)
                .FirstOrDefaultAsync(p => p.UserId == _userId);

            if (_profile is null)
            {
                Toasts.Error("PlayerProfile not found. Register flow did not initialize the player.", "Dashboard");
                return;
            }

            _piecesByTemplateId = await Db.Set<PlayerItemPieces>()
                .AsNoTracking()
                .Where(x => x.PlayerId == _profile.Id)
                .ToDictionaryAsync(x => x.TemplateId, x => x.Pieces);

            _mercSlots = await Db.PlayerMercenarySlots
                .AsNoTracking()
                .Where(s => s.PlayerProfileId == _profile.Id)
                .Include(s => s.Mercenary)!.ThenInclude(m => m.Template)
                .Include(s => s.Mercenary)!.ThenInclude(m => m.Equipment)
                    .ThenInclude(eq => eq.PlayerItem)!.ThenInclude(pi => pi.Template)
                        .ThenInclude(t => t.UpgradeResources)
                .OrderBy(s => s.SlotIndex)
                .ToListAsync();

            Toasts.Info(
                string.Join(" | ", _mercSlots.Select(s =>
                    $"{s.SlotIndex}: fk={(s.MercenaryInstanceId.HasValue ? "Y" : "N")} nav={(s.Mercenary is null ? "NULL" : "OK")}")),
                "Merc slots"
            );

            _beastSlots = await Db.PlayerBeastSlots
                .AsNoTracking()
                .Where(s => s.PlayerProfileId == _profile.Id)
                .Include(s => s.Beast)!.ThenInclude(b => b.Template)
                .Include(s => s.Beast)!.ThenInclude(b => b.Equipment)
                    .ThenInclude(eq => eq.PlayerItem)!.ThenInclude(pi => pi.Template)
                        .ThenInclude(t => t.UpgradeResources)
                .OrderBy(s => s.SlotIndex)
                .ToListAsync();

            Toasts.Info(
                string.Join(" | ", _beastSlots.Select(s =>
                    $"{s.SlotIndex}: fk={(s.BeastInstanceId.HasValue ? "Y" : "N")} beast={(s.Beast is null ? "NULL" : "OK")} tpl={(s.Beast?.Template is null ? "NULL" : s.Beast.Template.NameEn)}")),
                "Beast slots"
            );

            _inventory = _profile.Inventory?.ToList() ?? new();

            BuildInventoryVms();

            _showProfileSetupModal = string.IsNullOrWhiteSpace(_profile.CountryCode);
        }
        catch (Exception ex)
        {
            Toasts.Error(ex.Message, "Dashboard");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private void BuildInventoryVms()
    {
        _invVms = new List<InvItemVm>(_inventory.Count);

        foreach (var it in _inventory)
        {
            var tier = ItemBadgeRules.ComputeTier(it.Wins);

            var winsNow = it.Wins;
            var winsNeed = GetNextTierWinsNeed(tier);
            var pct = winsNeed <= 0 ? 100 : Math.Clamp((int)(winsNow * 100.0 / winsNeed), 0, 100);

            var res = BuildResources(it);

            _invVms.Add(new InvItemVm
            {
                Item = it,
                BadgeTier = tier,
                WinsNow = winsNow,
                WinsNeed = winsNeed,
                WinsPct = pct,
                Resources = res
            });
        }

        _invVmsById = _invVms.ToDictionary(x => x.Item.Id, x => x);
    }

    private List<InvResVm> BuildResources(PlayerItem it)
    {
        var t = it.Template;
        if (t?.UpgradeResources is null || t.UpgradeResources.Count == 0)
            return new();

        var havePieces = _piecesByTemplateId.TryGetValue(t.Id, out var pcs) ? pcs : 0;

        long BaseCost(ItemUpgradeResourceType type)
            => t.UpgradeResources.FirstOrDefault(x => x.Type == type)?.DefaultAmount ?? 0;

        long Need(ItemUpgradeResourceType type)
        {
            var baseCost = BaseCost(type);
            if (baseCost <= 0) return 0;

            return type switch
            {
                ItemUpgradeResourceType.Core => baseCost * Math.Max(1, it.Level),
                ItemUpgradeResourceType.Catalyst => baseCost * (1L << Math.Max(0, ((int)it.Quality) - 1)),
                ItemUpgradeResourceType.Essence => baseCost * Math.Max(1, it.Level / 2),
                _ => 0
            };
        }

        var list = new List<InvResVm>();

        foreach (var r in t.UpgradeResources.OrderBy(x => x.Type))
        {
            var need = Need(r.Type);

            list.Add(new InvResVm
            {
                Type = r.Type,
                Name = r.Type.ToString(),
                Have = havePieces,
                Need = need
            });
        }

        return list;
    }

    private static int GetNextTierWinsNeed(ItemBadgeTier tier)
        => tier switch
        {
            ItemBadgeTier.None => 5,
