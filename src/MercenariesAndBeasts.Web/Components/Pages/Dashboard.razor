    private sealed record StatCol(string Header, Func<StatBlock?, object?> GetValue, Func<object?, string>? Format = null);
    private static readonly IReadOnlyList<StatCol> _statColumns = BuildStatColumns();

    private static List<StatCol> BuildStatColumns()
    {
        var t = typeof(StatBlock);

        var props = t.GetProperties(BindingFlags.Instance | BindingFlags.Public)
            .Where(p => p.CanRead && (p.PropertyType == typeof(int) || p.PropertyType == typeof(long) ||
                                     p.PropertyType == typeof(float) || p.PropertyType == typeof(double) ||
                                     p.PropertyType.IsEnum))
            .OrderBy(p => p.Name)
            .ToList();

        var cols = new List<StatCol>(props.Count);

        foreach (var p in props)
        {
            cols.Add(new StatCol(
                Header: HumanizeStatName(p.Name),
                GetValue: sb => sb is null ? null : p.GetValue(sb),
                Format: v => FormatStatValue(p, v)
            ));
        }

        return cols;
    }

    private static string HumanizeStatName(string name)
        => name switch
        {
            "MaxHp" => "HP",
            "Attack" => "ATK",
            "Defense" => "DEF",
            "Speed" => "SPD",
            "CritChance" => "Crit %",
            "CritMultiplier" => "Crit x",
            "ArmorPenetration" => "Pen",
            "Accuracy" => "Acc",
            "Evasion" => "Eva",
            "BlockChance" => "Block %",
            "DamageBonus" => "DMG +",
            "DamageReduction" => "DMG -",
            "TrueDamageBonus" => "True +",
            "TurnMeterGain" => "TM +",
            "CooldownReduction" => "CDR",
            "ActionCostReduction" => "Cost -",
            "LifeSteal" => "LS",
            "HpRegen" => "Regen",
            "EnergyRegen" => "E.Regen",
            "StatusDurationBonus" => "Status +",
            "StatusResistance" => "Status Res",
            _ => name
        };

    private static string FormatStatValue(PropertyInfo p, object? value)
    {
        if (value is null) return "-";

        if (p.PropertyType.IsEnum)
            return value.ToString()!;

        if (p.Name.EndsWith("Chance") || p.Name.EndsWith("Bonus") || p.Name.EndsWith("Reduction") || p.Name.EndsWith("Gain"))
        {
            var d = Convert.ToDouble(value);
            return (d * 100).ToString("0.##") + "%";
        }

        return value switch
        {
            float f => f.ToString("0.##", CultureInfo.InvariantCulture),
            double d => d.ToString("0.##", CultureInfo.InvariantCulture),
            _ => value.ToString()!
        };
    }

    private StatBlock GetFinalStats(PlayerItem it)
    {
        if (it?.Template is null) return StatBlock.Zero;
        return it.Template.CalculateStats(it);
    }

    private static bool IsStatZero(object? v)
    {
        if (v is null) return true;
        return v switch
        {
            int i => i == 0,
            long l => l == 0,
            float f => Math.Abs(f) < 0.000001f,
            double d => Math.Abs(d) < 0.000001,
            _ => false
        };
    }

    private async Task UpgradeItemAsync(InvItemVm vm, InvResVm r)
    {
        if (_profile is null) return;
        if (_itemUpgrading) return;
        if (!r.CanUpgrade) return;

        _itemUpgrading = true;
        try
        {
            Toasts.Success("Upgraded", $"{vm.Item.Template.NameEn} ({r.Type})");

            await LoadAsync();
            if (_invVmsById.TryGetValue(vm.Item.Id, out var newVm))
                _activeItemVm = newVm;
        }
        catch (Exception ex)
        {
            Toasts.Error("Upgrade failed", ex.Message);
        }
        finally
        {
            _itemUpgrading = false;
            StateHasChanged();
        }
    }

    private ProfileSetupModel _setup = new();

    private sealed class ProfileSetupModel
    {
        public string CountryCode { get; set; } = "";
        public string UserName { get; set; } = "";
    }

    private static readonly IReadOnlyList<CountryCatalog.CountryOpt> Countries = CountryCatalog.GetAll();

    private async Task SaveProfileSetupAsync()
    {
        if (_profile is null || string.IsNullOrWhiteSpace(_userId))
            return;

        var cc = (_setup.CountryCode ?? "").Trim().ToUpperInvariant();
        var un = (_setup.UserName ?? "").Trim();

        if (cc.Length != 2)
        {
            Toasts.Error("Pick a valid country.", "Profile");
            return;
        }

        if (!IsValidUserName(un))
        {
            Toasts.Error("Username is invalid.", "Profile");
            return;
        }

        await using (var db = await DbFactory.CreateDbContextAsync())
        {
            var prof = await db.Players.FirstOrDefaultAsync(p => p.UserId == _userId);
            if (prof is null)
            {
                Toasts.Error("Profile not found.", "Profile");
                return;
            }

            prof.CountryCode = cc;
            await db.SaveChangesAsync();
        }

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var principal = authState.User;
        var appUser = await UserManager.GetUserAsync(principal);

        if (appUser is null)
        {
            Toasts.Error("User not found.", "Profile");
            return;
        }

        appUser.UserName = un;
        appUser.NormalizedUserName = UserManager.NormalizeName(un);

        var res = await UserManager.UpdateAsync(appUser);
        if (!res.Succeeded)
        {
            var msg = string.Join("; ", res.Errors.Select(e => e.Description));
            Toasts.Error(msg, "Profile");
            return;
        }

        _showProfileSetupModal = false;
        Toasts.Success("Profile saved.", "Profile");

        await LoadAsync();
    }

    private static bool IsValidUserName(string s)
    {
        if (string.IsNullOrWhiteSpace(s))
            return false;

        if (s.Length < 3 || s.Length > 20)
            return false;

        foreach (var ch in s)
        {
            var ok =
                char.IsLetterOrDigit(ch) ||
                ch == '_' ||
                ch == '-' ||
                ch == '.';

            if (!ok)
                return false;
        }

        return true;
    }

    private async Task OnDropToMercSlot(PlayerMercenarySlot slot)
    {
        try
        {
            if (_draggedItemId.HasValue)
            {
                await EquipMercenaryAsync(slot.Id, _draggedItemId.Value);
                Toasts.Success("Order equipped.", "Dashboard");
            }
            else if (_draggedFromSlotId.HasValue)
            {
                await MoveOrSwapMercSlotAsync(_draggedFromSlotId.Value, slot.Id);
                Toasts.Success("Slot updated.", "Dashboard");
            }

            await LoadAsync();
        }
        catch (Exception ex)
        {
            Toasts.Error(ex.Message, "Dashboard");
        }
        finally
        {
            _draggedItemId = null;
            _draggedFromSlotId = null;
        }
    }

