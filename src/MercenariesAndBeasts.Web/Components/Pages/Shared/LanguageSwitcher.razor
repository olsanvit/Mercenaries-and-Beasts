@using System.Globalization
@inject NavigationManager Nav
@rendermode InteractiveServer

<select class="form-select form-select-sm"
        @bind="currentCulture"
        @bind:after="OnCultureChanged">

    @foreach (var opt in _options)
    {
        <option value="@opt.Culture">
            @opt.Flag @opt.Label
        </option>
    }
</select>

@code {
    private sealed record LangOption(string Culture, string Flag, string Label);

    private readonly LangOption[] _options =
    [
        new("en", "🇬🇧", "English"),
        new("cs", "🇨🇿", "Čeština"),
        new("de", "🇩🇪", "Deutsch")
    ];

    private string currentCulture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;

    private void OnCultureChanged()
    {
        var culture = currentCulture ?? "en";

        var uri = new Uri(Nav.Uri);
        var returnUrl = Uri.EscapeDataString(uri.GetLeftPart(UriPartial.Path));

        // nastaví cookie a vrátí zpět na stránku
        var target = $"/set-culture?culture={culture}&returnUrl={returnUrl}";

        Nav.NavigateTo(target, forceLoad: true);
    }
}