@inject AlertService AlertService
@implements IDisposable

@if (_lastMessage is not null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>@_lastMessage</strong>
        @if (!string.IsNullOrEmpty(_lastDetails))
        {
            <div class="small text-muted mt-1">@_lastDetails</div>
        }
        <button type="button" class="btn-close" @onclick="Clear"></button>
    </div>
}

@code {
    private string? _lastMessage;
    private string? _lastDetails;

    protected override void OnInitialized()
    {
        AlertService.OnError += HandleError;
    }

    private void HandleError(string message, string? details)
    {
        _lastMessage = message;
        _lastDetails = details;
        InvokeAsync(StateHasChanged);
    }

    private void Clear()
    {
        _lastMessage = null;
        _lastDetails = null;
    }

    public void Dispose()
    {
        AlertService.OnError -= HandleError;
    }
}
