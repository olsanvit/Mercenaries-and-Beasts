@page "/dungeons"
@using System.Globalization
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using MercenariesAndBeasts.Infrastructure
@using MercenariesAndBeasts.Domain
@using MercenariesAndBeasts.Domain.Players
@using MercenariesAndBeasts.Domain.Progress

@inject IDbContextFactory<AppDbContextMercenariesAndBeasts> DbFactory
@inject UserManager<AppUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider

@attribute [Authorize]
@rendermode InteractiveServer

@if (isLoading)
{
    <PageLoadingSpinner />
}
else if (player is null)
{
    <div class="card-like">
        <div class="alert alert-danger mb-0">No player profile found.</div>
    </div>
}
else
{
    <div class="dng-fight-layout">

        <!-- ================= TOP 80% ================= -->
        <div class="dng-fight-top">
            <div class="dng-fight-top-grid">

                <!-- LEFT: list -->
                <div class="card-like dng-panel">
                    <div class="dng-panel-head">
                        <h3 class="m-0">Available dungeons</h3>
                        <p class="text-muted mb-0 small">Last 5 unlocked + next 2 locked.</p>
                    </div>

                    <div class="dng-panel-body panel-scroll">
                        <ul class="list-group list-group-flush">
                            @foreach (var row in leftList)
                            {
                                var isSelected = row.Dungeon?.Guid == selectedDungeonId;
                                var isLocked = row.IsLocked;

                                <li class="list-group-item bg-transparent text-light"
                                    style="opacity:@(isLocked ? "0.45" : "1");">
                                    <div class="d-flex justify-content-between align-items-center gap-2">
                                        <div style="min-width:0;">
                                            <strong class="text-truncate d-block">@row.Title</strong>
                                            <div class="text-muted small">@row.Subtitle</div>

                                            @if (!isLocked && row.Progress is null)
                                            {
                                                <span class="badge bg-secondary mt-1">Not started</span>
                                            }
                                            else if (!isLocked && row.Progress?.IsCompleted == true)
                                            {
                                                <span class="badge bg-success mt-1">Completed</span>
                                            }
                                            else if (!isLocked && row.Progress is not null)
                                            {
                                                <span class="badge bg-warning text-dark mt-1">
                                                    Stage @row.Progress.CurrentStage / @(row.Dungeon?.Stages?.Count > 0 ? row.Dungeon.Stages.Count : 11)
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-dark mt-1">Locked</span>
                                            }
                                        </div>

                                        <button class="btn btn-sm @(isSelected ? "btn-primary" : "btn-outline-secondary")"
                                                disabled="@isLocked"
                                                @onclick="() => SelectDungeon(row.Dungeon!.Guid)">
                                            @(isSelected ? "Selected" : "Open")
                                        </button>
                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                </div>

                <!-- RIGHT: detail -->
                <div class="card-like dng-panel">
                    <div class="dng-panel-head">
                        @if (selectedDungeon is null)
                        {
                            <h3 class="m-0">Dungeon</h3>
                            <p class="text-muted m-0 small">Pick a dungeon on the left.</p>
                        }
                        else
                        {
                            <h3 class="m-0">@DungeonName(selectedDungeon)</h3>
                            <div class="text-muted small">
                                Recommended level @selectedDungeon.MinLevel–@selectedDungeon.MaxLevel
                                · @selectedDungeon.Element
                            </div>
                        }
                    </div>

                    <div class="dng-panel-body panel-scroll">
                        @if (selectedDungeon is null)
                        {
                            <div class="text-muted">—</div>
                        }
                        else
                        {
                            <div class="mt-2">
                                @if (selectedProgress is null)
                                {
                                    <span class="badge bg-secondary">Not started</span>
                                }
                                else if (selectedProgress.IsCompleted)
                                {
                                    <span class="badge bg-success">Completed</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">
                                        Stage @currentStageUi / @TotalStages
                                    </span>
                                }
                            </div>

                            <hr />

                            <h5>Current enemy</h5>

                            @if (currentEnemy is null)
                            {
                                <div class="text-muted">No enemy data for this stage.</div>
                            }
                            else
                            {
                                <div class="d-flex align-items-center gap-3 mb-3">
                                    @if (!string.IsNullOrWhiteSpace(currentEnemy.ImagePath))
                                    {
                                        <img src="@currentEnemy.ImagePath"
                                             style="width:64px;height:64px;object-fit:cover;border-radius:10px;" />
                                    }
                                    else
                                    {
                                        <div style="width:64px;height:64px;border-radius:10px;background:rgba(255,255,255,0.06);flex-shrink:0;"></div>
                                    }
                                    <div style="min-width:0;">
                                        <div class="fw-bold text-truncate">@MonsterName(currentEnemy)</div>
                                        <div class="text-muted small">Stage @currentStageUi / @TotalStages · @currentEnemy.Element</div>
                                    </div>
                                </div>
                            }

                            <div class="d-flex gap-2">
                                @if (selectedProgress?.IsCompleted == true)
                                {
                                    <button class="btn btn-secondary" disabled>Completed</button>
                                }
                                else
                                {
                                    <a class="btn btn-primary"
                                       href="@($"/dungeons/{selectedDungeon.Guid}/fight")">
                                        Fight
                                    </a>
                                }
                            </div>

                            @if (!string.IsNullOrWhiteSpace(DungeonDescription(selectedDungeon)))
                            {
                                <hr />
                                <div class="text-muted small">@DungeonDescription(selectedDungeon)</div>
                            }
                        }
                    </div>
                </div>

            </div>
        </div>

        <!-- ================= BOTTOM 20% ================= -->
        <div class="dng-fight-bottom">
            <div class="card-like dng-panel">
                <div class="dng-panel-head">
                    <div class="fw-bold">Achievements</div>
                    <div class="text-muted small">
                        @(selectedDungeon is null ? "Pick a dungeon above." : $"For: {DungeonName(selectedDungeon)}")
                    </div>
                </div>

                <div class="dng-panel-body panel-scroll">
                    @if (selectedDungeon is null)
                    {
                        <div class="text-muted">—</div>
                    }
                    else if (dungeonAchievements.Count == 0)
                    {
                        <div class="text-muted">No achievements defined for this dungeon.</div>
                    }
                    else
                    {
                        @foreach (var a in dungeonAchievements)
                        {
                            <div class="ach-row">
                                <div class="ach-title">@a.Title</div>

                                @if (!string.IsNullOrWhiteSpace(a.Description))
                                {
                                    <div class="ach-meta text-muted small">@a.Description</div>
                                }

                                @if (a.IsCompleted)
                                {
                                    <span class="badge bg-success mt-2">Completed</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark mt-2">
                                        @a.Current / @a.Required
                                    </span>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

    </div>
}

@code {
    private bool isLoading = true;
    private PlayerProfile? player;

    private List<Dungeon> _allDungeons = new();
    private List<PlayerDungeonProgress> progress = new();

    private Guid? selectedDungeonId;
    private Dungeon? selectedDungeon;
    private PlayerDungeonProgress? selectedProgress;

    private int currentStageUi = 1;
    private MonsterTemplate? currentEnemy;

    private int TotalStages => selectedDungeon?.Stages?.Count > 0 ? selectedDungeon.Stages.Count : 11;

    private List<LeftDungeonRow> leftList = new();

    private sealed class LeftDungeonRow
    {
        public Dungeon? Dungeon { get; set; }
        public PlayerDungeonProgress? Progress { get; set; }
        public bool IsLocked { get; set; }
        public string Title { get; set; } = "";
        public string Subtitle { get; set; } = "";
    }

    private List<AchievementVm> dungeonAchievements = new();

    private sealed record AchievementVm(
        string Title,
        string? Description,
        bool IsCompleted,
        int Current,
        int Required
    );

    private readonly Dictionary<(string, Guid, string), LocalizedText> _locByKey = new();

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;

        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = await UserManager.GetUserAsync(auth.User);
            if (user is null) return;

            await using var db = await DbFactory.CreateDbContextAsync();

            player = await db.Players.FirstOrDefaultAsync(p => p.UserId == user.Id);
            if (player is null) return;

            progress = await db.PlayerDungeonProgresses
                .Where(p => p.PlayerId == player.Guid)
                .ToListAsync();

            _allDungeons = await db.Dungeons
                .Include(d => d.Stages)
                .OrderBy(d => d.UnlockOrder)
                .ToListAsync();

            var maxCompleted = progress
                .Where(p => p.IsCompleted)
                .Join(_allDungeons, p => p.DungeonId, d => d.Guid, (p, d) => d.UnlockOrder)
                .DefaultIfEmpty(0)
                .Max();

            var maxUnlockedOrder = maxCompleted + 1;

            var unlocked = _allDungeons
                .Where(d => d.UnlockOrder <= maxUnlockedOrder)
                .OrderBy(d => d.UnlockOrder)
                .ToList();

            var last5 = unlocked.TakeLast(5).ToList();

            var nextLocked = _allDungeons
                .Where(d => d.UnlockOrder > maxUnlockedOrder)
                .OrderBy(d => d.UnlockOrder)
                .Take(2)
                .ToList();

            var leftIds = last5.Concat(nextLocked).Select(x => x.Guid).Distinct().ToList();
            await LoadLocalizationsAsync(db, nameof(Dungeon), leftIds);

            leftList = new();

            foreach (var d in last5)
            {
                var pr = progress.FirstOrDefault(p => p.DungeonId == d.Guid);
                leftList.Add(new LeftDungeonRow
                {
                    Dungeon = d,
                    Progress = pr,
                    IsLocked = false,
                    Title = DungeonName(d),
                    Subtitle = $"Recommended level {d.MinLevel}–{d.MaxLevel}"
                });
            }

            foreach (var d in nextLocked)
            {
                leftList.Add(new LeftDungeonRow
                {
                    Dungeon = d,
                    Progress = null,
                    IsLocked = true,
                    Title = DungeonName(d),
                    Subtitle = "Locked"
                });
            }

            var first = last5.FirstOrDefault();
            if (first is not null)
                await SelectDungeonWithDb(db, first.Guid);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SelectDungeon(Guid id)
    {
        selectedDungeonId = id;
        await using var db = await DbFactory.CreateDbContextAsync();
        await SelectDungeonWithDb(db, id);
    }

    private async Task SelectDungeonWithDb(AppDbContextMercenariesAndBeasts db, Guid id)
    {
        selectedDungeonId = id;

        selectedDungeon = await db.Dungeons
            .Include(d => d.Stages)
                .ThenInclude(s => s.MonsterTemplate)
            .AsNoTracking()
            .FirstOrDefaultAsync(d => d.Guid == id);

        if (selectedDungeon is null)
        {
            dungeonAchievements = new();
            StateHasChanged();
            return;
        }

        var monsterIds = selectedDungeon.Stages?
            .Select(s => s.MonsterTemplateId)
            .Distinct()
            .ToList() ?? new();

        await LoadLocalizationsAsync(db, nameof(MonsterTemplate), monsterIds);

        var pr = await GetOrCreateProgressAsync(db, player!.Guid, id, selectedDungeon.Stages?.Count ?? 11);
        selectedProgress = pr;
        currentStageUi = Math.Max(1, pr.CurrentStage);

        currentEnemy = PickEnemy(selectedDungeon, currentStageUi);
        dungeonAchievements = BuildAchievementVms(pr.Achievements);

        StateHasChanged();
    }

    private async Task<PlayerDungeonProgress> GetOrCreateProgressAsync(
        AppDbContextMercenariesAndBeasts db,
        Guid playerId,
        Guid dungeonId,
        int totalStages)
    {
        var pr = await db.PlayerDungeonProgresses
            .Include(p => p.Achievements)
                .ThenInclude(a => a.Achievement)
            .FirstOrDefaultAsync(p => p.PlayerId == playerId && p.DungeonId == dungeonId);

        if (pr is null)
        {
            pr = new PlayerDungeonProgress
            {
PlayerId = playerId,
                DungeonId = dungeonId,
                CurrentStage = 1,
                MaxStageReached = 1,
                IsCompleted = false,
                WinStreak = 0,
                LastUpdatedUtc = DateTime.UtcNow
            };
            db.PlayerDungeonProgresses.Add(pr);
            await db.SaveChangesAsync();
        }

        // Seed achievements from DB definitions if none yet
        if (pr.Achievements.Count == 0)
        {
            var defs = await db.DungeonAchievements
                .Where(d => d.DungeonId == dungeonId)
                .OrderBy(d => d.Index)
                .Take(5)
                .ToListAsync();

            if (defs.Count > 0)
            {
                var rng = new Random(pr.Guid.GetHashCode());
                foreach (var def in defs)
                {
                    var tier = rng.Next(1, 6);
                    pr.Achievements.Add(new PlayerDungeonAchievement
                    {
ProgressId = pr.Guid,
                        PlayerId = playerId,
                        AchievementId = def.Guid,
                        Code = def.Code,
                        DifficultyTier = tier,
                        Required = 1 + tier,
                        Current = 0,
                        IsCompleted = false
                    });
                }
                await db.SaveChangesAsync();
            }
        }

        return pr;
    }

    private static MonsterTemplate? PickEnemy(Dungeon d, int stage)
    {
        if (d.Stages is null || d.Stages.Count == 0)
            return null;

        var clamp = Math.Clamp(stage, 1, d.Stages.Count);

        // exact match first, then nearest lower, then first
        return d.Stages.OrderBy(s => s.StageIndex).ElementAtOrDefault(clamp - 1)?.MonsterTemplate
            ?? d.Stages.Where(s => s.StageIndex <= stage)
                       .OrderByDescending(s => s.StageIndex)
                       .FirstOrDefault()?.MonsterTemplate
            ?? d.Stages.OrderBy(s => s.StageIndex).FirstOrDefault()?.MonsterTemplate;
    }

    private List<AchievementVm> BuildAchievementVms(IEnumerable<PlayerDungeonAchievement> achievements)
    {
        return achievements.Select(a => new AchievementVm(
            Title: a.Achievement?.NameEn is { Length: > 0 } n ? n : a.Code,
            Description: a.Achievement?.DescriptionEn is { Length: > 0 } d
                ? $"{d} (Tier {a.DifficultyTier})"
                : $"Tier {a.DifficultyTier}",
            IsCompleted: a.IsCompleted,
            Current: a.Current,
            Required: a.Required
        )).ToList();
    }

    // ===== Localization helpers =====

    private async Task LoadLocalizationsAsync(AppDbContextMercenariesAndBeasts db, string entityType, List<Guid> ids)
    {
        if (ids.Count == 0) return;
        var locs = await db.LocalizedTexts
            .Where(x => x.EntityType == entityType && ids.Contains(x.EntityId))
            .ToListAsync();
        foreach (var l in locs)
            _locByKey[(l.EntityType, l.EntityId, l.Culture)] = l;
    }

    private string DungeonName(Dungeon d)       => Localize(nameof(Dungeon),        d.Guid,  "Name",        d.NameEn);
    private string DungeonDescription(Dungeon d) => Localize(nameof(Dungeon),        d.Guid,  "Description", d.DescriptionEn ?? "");
    private string MonsterName(MonsterTemplate m) => Localize(nameof(MonsterTemplate), m.Guid, "Name",        m.NameEn);

    private string Localize(string entityType, Guid entityId, string field, string fallback)
    {
        var culture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
        if (!_locByKey.TryGetValue((entityType, entityId, culture), out var loc))
            return fallback;
        var text = field == "Name" ? loc.Name : field == "Description" ? loc.Description : null;
        return string.IsNullOrWhiteSpace(text) ? fallback : text!;
    }
}
