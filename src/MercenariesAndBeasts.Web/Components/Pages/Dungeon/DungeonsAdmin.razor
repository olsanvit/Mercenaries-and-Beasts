@page "/dungeons-admin"
@using MercenariesAndBeasts.Domain.Utils
@using System.Globalization
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

<h1>@S["Dungeons"]</h1>
<ImagePreviewer @ref="imagePreviewer" />
@if (isLoading)
{
    <p>Loading...</p>
}
else
{
    <div class="mb-3">
        <button class="btn btn-primary" @onclick="NewDungeon">@S["NewDungeon"]</button>
    <button class="btn btn-secondary ms-2" @onclick="() => GenerateNextDungeon(false)">
            @S["AiGenLocation"]
</button>
<!-- Vlastní název pro ruční generaci -->
    <div class="input-group">
        <input class="form-control dungeon-input"
       @bind="manualDungeonName"
       placeholder="Enter dungeon name…" />

        <button class="btn btn-primary"
                disabled="@IsManualGenerateDisabled"
                @onclick="async () => await GenerateNextDungeon(true)">
            Generate Dungeon (Manual)
        </button>
    </div>

</div>
    @if (!dungeons.Any())
    {
        <p>No dungeons yet.</p>
    }
    else
    {
        <div class="dungeons-table-wrap">
    <table class="table table-dark table-stages">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Element</th>
                    <th>Unlock Order</th>
                    <th>Level range</th>
        <th>Stages</th> @* nový sloupec *@
        <th>Preview</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var d in dungeons)
            {
                <tr>
                        <td title="@d.Code">@d.Code</td>
                        <td title="@LocalizationExtensions.NameForCurrentCulture(d)" class="location-name ellipsis">@LocalizationExtensions.NameForCurrentCulture(d)</td>
                        <td>@d.Element</td>
                        <td>@d.UnlockOrder</td>
                    <td>@d.MinLevel - @d.MaxLevel</td>
        <td>
            @(d.Stages?.Count ?? 0)
            <button class="btn btn-sm btn-outline-info ms-2"
                    @onclick="() => ToggleDungeonStages(d.Id)">
                @(expandedDungeonIds.Contains(d.Id) ? "Hide" : "Show")
            </button>
        </td>
        <td style="width:150px;">
    @if (!string.IsNullOrWhiteSpace(d.ImagePath))
    {
        <img src="@d.ImagePath"
             class="img-thumbnail"
             style="max-height: 80px; cursor:pointer;"
             @onclick="() => ShowImage(d.ImagePath)" />
    }
    else
    {
        <span class="text-muted">No image</span>
    }

    <button class="btn btn-sm btn-outline-warning mt-1"
            @onclick="() => GenerateDungeonImage(d)">
        Generate Image
    </button>
</td>
                    <td>
                        <button class="btn btn-sm btn-secondary me-1" @onclick="() => EditDungeon(d)">Edit</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteDungeon(d.Id)">Delete</button>
                    </td>
                </tr>
                @if (expandedDungeonIds.Contains(d.Id))
    {
                    <tr class="table-secondary dungeon-detail-row">
            <td colspan="8">
                        <td class="location-name">@LocalizationExtensions.DescriptionForCurrentCulture(d)</td>
                @if (d.Stages == null || d.Stages.Count == 0)
                {
                    <em>No stages defined.</em>
                }
                else
                {
                    <div class="accordion" id="acc-@d.Id">
                        <div class="accordion-item bg-dark text-light">
                            <h2 class="accordion-header" id="heading-@d.Id">
                                <button class="accordion-button collapsed"
                                        type="button"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#collapse-@d.Id"
                                        aria-expanded="false"
                                        aria-controls="collapse-@d.Id">
                                    Stages &amp; monsters
                                </button>
                            </h2>
                            <div id="collapse-@d.Id"
                                 class="accordion-collapse collapse show"
                                 aria-labelledby="heading-@d.Id">
                                <div class="accordion-body">
                                    <table class="table table-sm table-dark mb-0 table-stages">
                                        <thead>
                                            <tr>
            <th class="num">#</th>
            <th class="stage-type">Stage type</th>
            <th class="wrap">Monster</th>
            <th class="num">Level</th>
            <th class="wrap">Element</th>
            <th class="num">HP</th>
            <th class="num">Attack</th>
            <th class="num">Defense</th>
            <th class="num">Speed</th>
            <th class="num">CritChance</th>
            <th class="num">CritMultiplier</th>
            <th class="num">ElementalDamageBonus</th>
            <th class="num">ElementalResistance</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                        @foreach (var s in d.Stages.OrderBy(s => s.StageIndex))
                                        {
                                            <tr>
                                               <td class="num">@s.StageIndex</td>
                                                <td class="stage-type">@s.StageType</td>

                                                <td class="wrap" 
                                                    title="@LocalizationExtensions.NameForCurrentCulture(s.MonsterTemplate)">
                                                    @LocalizationExtensions.NameForCurrentCulture(s.MonsterTemplate)
                                                </td>

                                                <td class="num">@s.MonsterTemplate?.BaseLevel</td>
                                                <td class="wrap">@s.MonsterTemplate?.Element</td>

                                                <td class="num">@s.MonsterTemplate?.BaseStats?.MaxHp</td>
                                                <td class="num">@s.MonsterTemplate?.BaseStats?.Attack</td>
                                                <td class="num">@s.MonsterTemplate?.BaseStats?.Defense</td>
                                                <td class="num">@s.MonsterTemplate?.BaseStats?.Speed</td>
                                                <td class="num">@s.MonsterTemplate?.BaseStats?.CritChance</td>
                                                <td class="num">@s.MonsterTemplate?.BaseStats?.CritMultiplier</td>
                                                <td class="num">@s.MonsterTemplate?.BaseStats?.ElementalDamageBonus</td>
                                                <td class="num">@s.MonsterTemplate?.BaseStats?.ElementalResistance</td>
                                            </tr>
                                        }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </td>
        </tr>
    }
            }
            </tbody>
        </table>
</div>
    }
}

@if (editModel is not null)
{
    <hr />
    <h2>@(editModel.Id == Guid.Empty ? "Create dungeon" : "Edit dungeon")</h2>

    <EditForm Model="@editModel" OnValidSubmit="Save">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-2">
            <label class="form-label">Code</label>
            <InputText class="form-control" @bind-Value="editModel.Code" />
        </div>

        <div class="mb-2">
            <label class="form-label">Name (EN)</label>
            <InputText class="form-control" @bind-Value="editModel.NameEn" />
        </div>

        <div class="mb-2">
            <label class="form-label">Min level</label>
            <InputNumber class="form-control" @bind-Value="editModel.MinLevel" />
        </div>

        <div class="mb-3">
            <label class="form-label">Max level</label>
            <InputNumber class="form-control" @bind-Value="editModel.MaxLevel" />
        </div>

        <button type="submit" class="btn btn-success me-2">Save</button>
        <button type="button" class="btn btn-outline-secondary" @onclick="CancelEdit">Cancel</button>
    </EditForm>
}

@code {
    private bool isLoading = true;
    private List<Dungeon> dungeons = new();
    private Dungeon? editModel;
    private string manualDungeonName = string.Empty;
    private bool IsManualGenerateDisabled =>
        isLoading || string.IsNullOrWhiteSpace(manualDungeonName);

    protected override async Task OnInitializedAsync()
    {
        await LoadDungeons();
    }

    private async Task LoadDungeons()
    {
      isLoading = true;

    try
    {
        dungeons = await Db.Dungeons
            .Include(x => x.Stages).ThenInclude(x => x.MonsterTemplate)
            .OrderBy(d => d.MinLevel)
            .ThenBy(d => d.Code)
            .ToListAsync();

        await EnsureLocalizationAsync();

        Toasts.Success("Dungeons loaded", $"Loaded {dungeons.Count} dungeons.");
    }
    catch (Exception ex)
    {
        Toasts.Error("Failed to load dungeons", ex.Message);
    }
    finally
    {
        isLoading = false;
        StateHasChanged();
    }
    }

private async Task EnsureLocalizationAsync()
{
    try
    {
        bool anyChanges = false;

        foreach (var dungeon in dungeons)
        {
            bool needsDungeonLocalization =
                string.IsNullOrWhiteSpace(dungeon.NameCs) ||
                string.IsNullOrWhiteSpace(dungeon.NameDe);

            if (needsDungeonLocalization)
            {
                var loc = await DungeonAi.GenerateLocalizedNamesAsync(
                    entityKind: "dungeon",
                    nameEn: dungeon.NameEn,
                    descriptionEn: dungeon.DescriptionEn
                );

                if (loc != null)
                {
                    dungeon.NameEn        = loc.NameEn;
                    dungeon.NameCs        = loc.NameCs;
                    dungeon.NameDe        = loc.NameDe;
                    dungeon.DescriptionEn = loc.DescriptionEn;
                    dungeon.DescriptionCs = loc.DescriptionCs;
                    dungeon.DescriptionDe = loc.DescriptionDe;

                    Db.Dungeons.Update(dungeon);
                    anyChanges = true;
                }
            }

            // monstra v dungeon stages
            foreach (var stage in dungeon.Stages)
            {
                var m = stage.MonsterTemplate;
                if (m == null) continue;

                bool needsMonsterLocalization =
                    string.IsNullOrWhiteSpace(m.NameCs) ||
                    string.IsNullOrWhiteSpace(m.NameDe);

                if (needsMonsterLocalization)
                {
                    var locM = await DungeonAi.GenerateLocalizedNamesAsync(
                        entityKind: "monster",
                        nameEn: m.NameEn,
                        descriptionEn: m.DescriptionEn
                    );

                    if (locM != null)
                    {
                        m.NameEn        = locM.NameEn;
                        m.NameCs        = locM.NameCs;
                        m.NameDe        = locM.NameDe;
                        m.DescriptionEn = locM.DescriptionEn;
                        m.DescriptionCs = locM.DescriptionCs;
                        m.DescriptionDe = locM.DescriptionDe;

                        Db.MonsterTemplates.Update(m);
                        anyChanges = true;
                    }
                }
            }
        }

        if (anyChanges)
        {
            await Db.SaveChangesAsync();
            Toasts.Success("Localization updated", "Some dungeon names/monsters were translated.");
        }
    }
    catch (Exception ex)
    {
        // nepadat kvůli lokalizaci
        Toasts.Error("Dungeon localization failed", ex.Message);
    }
}
    private void NewDungeon()
    {
        editModel = new Dungeon
        {
            MinLevel = 1,
            MaxLevel = 5
        };
    }

    private void EditDungeon(Dungeon d)
    {
        editModel = new Dungeon
        {
            Id = d.Id,
            Code = d.Code,
            NameEn = d.NameEn,
            MinLevel = d.MinLevel,
            MaxLevel = d.MaxLevel
        };
    }

    private async Task Save()
    {
        if (editModel is null)
        return;

    try
    {
        if (editModel.Id == Guid.Empty)
        {
            editModel.Id = Guid.NewGuid();
            Db.Dungeons.Add(editModel);
        }
        else
        {
            var existing = await Db.Dungeons.FirstOrDefaultAsync(x => x.Id == editModel.Id);
            if (existing is null)
            {
                Toasts.Error("Save failed", "Dungeon not found.");
                return;
            }

            existing.Code     = editModel.Code;
            existing.NameEn   = editModel.NameEn;
            existing.MinLevel = editModel.MinLevel;
            existing.MaxLevel = editModel.MaxLevel;
        }

        await Db.SaveChangesAsync();
        editModel = null;
        await LoadDungeons();

        Toasts.Success("Dungeon saved", "The dungeon has been saved successfully.");
    }
    catch (Exception ex)
    {
        Toasts.Error("Failed to save dungeon", ex.Message);
    }
    }
    private HashSet<Guid> expandedDungeonIds = new();

    private void ToggleDungeonStages(Guid dungeonId)
    {
        if (expandedDungeonIds.Contains(dungeonId))
            expandedDungeonIds.Remove(dungeonId);
        else
            expandedDungeonIds.Add(dungeonId);
    }
    private async Task DeleteDungeon(Guid id)
    {
       try
    {
        var d = await Db.Dungeons.FirstOrDefaultAsync(x => x.Id == id);
        if (d is null)
        {
            Toasts.Error("Delete failed", "Dungeon not found.");
            return;
        }

        Db.Dungeons.Remove(d);
        await Db.SaveChangesAsync();
        await LoadDungeons();

        Toasts.Success("Dungeon deleted", d.NameEn);
    }
    catch (Exception ex)
    {
        Toasts.Error("Failed to delete dungeon", ex.Message);
    }
    }

    private void CancelEdit()
    {
        editModel = null;
    }
    private async Task GenerateNextDungeon(bool current)
    {
        isLoading = true;

    try
    {
        string dungeonName;
        var newDungeon = new Dungeon();

        // 1) poslední dungeon
        var lastDungeon = await Db.Dungeons
            .OrderByDescending(d => d.UnlockOrder)
            .FirstOrDefaultAsync();

        if (lastDungeon is null)
        {
            newDungeon.MinLevel = 1;
            newDungeon.MaxLevel = 5;
        }
        else
        {
            newDungeon.MinLevel = lastDungeon.MinLevel;
            newDungeon.MaxLevel = lastDungeon.MaxLevel;
        }

        if (!current)
        {
            dungeonName = lastDungeon?.NameEn ?? "Bausia";
        }
        else
        {
            dungeonName = manualDungeonName.Trim();
            newDungeon.NameEn = dungeonName;
        }

        var options = new DungeonGenerationOptions
        {
            Name = dungeonName
        };

        var generated = await DungeonAi.GenerateNextDungeonAsync(lastDungeon, newDungeon, current);
        if (generated is null)
        {
            Toasts.Error("AI generation failed", "No dungeon was generated.");
            return;
        }

        int nextUnlockOrder = lastDungeon is null
            ? 1
            : lastDungeon.UnlockOrder + 1;

        var dungeon = new Dungeon
        {
            Id           = Guid.NewGuid(),
            Code         = $"DUN_{generated.NameEn.ToUpper()}",
            NameEn       = generated.NameEn,
            DescriptionEn = generated.DescriptionEn,
            Element      = Enum.TryParse<ElementType>(generated.Element.ToString(), true, out var el)
                            ? el
                            : ElementType.None,
            MinLevel     = generated.MinLevel,
            MaxLevel     = generated.MaxLevel,
            UnlockOrder  = nextUnlockOrder
        };

        Db.Dungeons.Add(dungeon);

        foreach (var st in generated.Stages.OrderBy(s => s.StageNumber))
        {
            var m = st.Monster;

            var monster = new MonsterTemplate
            {
                Id          = Guid.NewGuid(),
                Code        = $"{dungeon.Code}_{m.NameEn.ToUpper()}",
                NameEn      = m.NameEn,
                DescriptionEn = m.DescriptionEn,
                Element     = Enum.TryParse<ElementType>(m.Element.ToString(), true, out var el2)
                                ? el2
                                : ElementType.Void,
                BaseLevel   = m.BaseLevel,
                BaseStats   = new StatBlock
                {
                    MaxHp                = m.Stats.MaxHp,
                    Attack               = m.Stats.Attack,
                    Defense              = m.Stats.Defense,
                    Speed                = m.Stats.Speed,
                    CritChance           = m.Stats.CritChance,
                    CritMultiplier       = m.Stats.CritMultiplier,
                    ElementalDamageBonus = m.Stats.ElementalDamageBonus,
                    ElementalResistance  = m.Stats.ElementalResistance
                }
            };

            Db.MonsterTemplates.Add(monster);

            var stage = new DungeonStage
            {
                Id               = Guid.NewGuid(),
                Code             = $"{dungeon.Code}_{st.StageNumber}",
                DungeonId        = dungeon.Id,
                StageIndex       = st.StageNumber,
                StageType        = Enum.TryParse<DungeonStageType>(
                                        st.StageType.ToString(),
                                        ignoreCase: true,
                                        out var stType)
                                        ? stType
                                        : DungeonStageType.DS1_Feeble,
                MonsterTemplateId = monster.Id
            };

            Db.DungeonStages.Add(stage);
        }

        await Db.SaveChangesAsync();
        await LoadDungeons();

        Toasts.Success("Dungeon created", dungeon.NameEn);
    }
    catch (Exception ex)
    {
        Toasts.Error("Failed to generate dungeon", ex.Message);
    }
    finally
    {
        isLoading = false;
    }
}
    private static ElementType ParseElement(string raw)
  {
      raw = (raw ?? "").Trim();

      if (Enum.TryParse<ElementType>(raw, ignoreCase: true, out var parsed))
          return parsed;

      // jednoduchý fallback – když AI hodí kravinu
      return ElementType.Void; // nebo nějaký tvůj "Unknown"
  }
  private ImagePreviewer? imagePreviewer;
  private void ShowImage(string? url)
{
    if (!string.IsNullOrWhiteSpace(url))
        imagePreviewer?.Open(url);
}
private async Task GenerateDungeonImage(Dungeon d)
{
    isLoading = true;
    StateHasChanged();

    try
    {
        var path = await ImageAi.GenerateDungeonImageAsync(d);

        if (string.IsNullOrWhiteSpace(path))
        {
            Toasts.Error("Image generation failed", "AI did not return any image.");
            return;
        }

        d.ImagePath = path;
        Db.Dungeons.Update(d);

        await Db.SaveChangesAsync();
        await LoadDungeons();

        Toasts.Success("Dungeon image generated", d.NameEn);
    }
    catch (Exception ex)
    {
        Toasts.Error("Failed to generate dungeon image", ex.Message);
        Console.WriteLine("Image generation failed: " + ex);
    }
    finally
    {
        isLoading = false;
        StateHasChanged();
    }
}
}