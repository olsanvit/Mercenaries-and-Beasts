@page "/dungeons-admin"
@using System.Globalization
@using System.Reflection
@using MercenariesAndBeasts.Domain.Localization
@using Microsoft.EntityFrameworkCore
@using MercenariesAndBeasts.Domain.Utils
@using MercenariesAndBeasts.Domain.Combat
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

<div class="dash-switcher mb-3">
    <h4 class="m-0">@S["Dungeons"]</h4>
</div>

<div class="card-like mb-3">
    <div class="fw-bold mb-2">Localization coverage <span class="text-muted small fw-normal">(locales: @_localeCount)</span></div>
    <div class="row g-2">
        <div class="col-md-6">
            <div class="text-muted small mb-1">Dungeons</div>
            <div>@_dungeonHaveRows / @_dungeonMaxRows rows
                (@(_dungeonMaxRows == 0 ? "0" : ((100.0 * _dungeonHaveRows / _dungeonMaxRows).ToString("0.0")))%)
                — full: <span class="@(_dungeonFullyLocalized == _dungeonTotal ? "text-success" : "text-warning")">@_dungeonFullyLocalized / @_dungeonTotal</span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="text-muted small mb-1">Beasts (MonsterTemplates)</div>
            <div>@_beastHaveRows / @_beastMaxRows rows
                (@(_beastMaxRows == 0 ? "0" : ((100.0 * _beastHaveRows / _beastMaxRows).ToString("0.0")))%)
                — full: <span class="@(_beastFullyLocalized == _beastTotal ? "text-success" : "text-warning")">@_beastFullyLocalized / @_beastTotal</span>
                — items: @_beastWithItemTemplates / @_beastTotal
            </div>
        </div>
    </div>
</div>

<ImagePreviewer @ref="imagePreviewer" />

@if (isLoading)
{
    <div class="card-like d-flex align-items-center gap-2 text-muted mb-3">
        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
        <span>Loading…</span>
    </div>
}
else
{
    <div class="mb-3">
        <button class="btn btn-secondary" @onclick="() => GenerateNextDungeon(false)">
            Generate Next Dungeon (AI)
        </button>

        <div class="input-group mt-2">
            <input class="form-control dungeon-input"
                   @bind="manualDungeonName"
                   placeholder="Enter dungeon name…" />

            <button class="btn btn-primary"
                    disabled="@IsManualGenerateDisabled"
                    @onclick="async () => await GenerateNextDungeon(true)">
                Generate Dungeon (Manual)
            </button>
        </div>
    </div>

    @if (!dungeons.Any())
    {
        <p>No dungeons yet.</p>
    }
    else
    {
        <div class="table-scroll-x">
    <table class="table table-dark table-stages table-fixed w-100">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Name</th>
                        <th>Element</th>
                        <th>Unlock Order</th>
                        <th>Level range</th>
                        <th>Stages</th>
                        <th>Preview</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var d in dungeons)
                    {
                        <tr>
                            <td title="@d.Code">@d.Code</td>

                            <td title="@d.NameForCurrentCulture(_dungeonLocs)"
                                class="location-name ellipsis">
                                @d.NameForCurrentCulture(_dungeonLocs)
                            </td>

                            <td>@d.Element</td>
                            <td>@d.UnlockOrder</td>
                            <td>@d.MinLevel - @d.MaxLevel</td>

                            <td>
                                @(d.Stages?.Count ?? 0)
                                <button class="btn btn-sm btn-outline-info ms-2"
                                        @onclick="() => ToggleDungeonStages(d.Id)">
                                    @(expandedDungeonIds.Contains(d.Id) ? "Hide" : "Show")
                                </button>
                            </td>

                            <td style="width:150px;">
                                @if (!string.IsNullOrWhiteSpace(d.ImagePath))
                                {
                                    <img src="@d.ImagePath"
                                         class="img-thumbnail"
                                         style="max-height: 80px; cursor:pointer;"
                                         @onclick="() => ShowImage(d.ImagePath)" />
                                }
                                else
                                {
                                    <span class="text-muted">No image</span>
                                }

                                <button class="btn btn-sm btn-outline-warning mt-1"
                                        @onclick="() => GenerateDungeonImage(d)">
                                    Generate Image
                                </button>
                            </td>
                        </tr>

                        @if (expandedDungeonIds.Contains(d.Id))
{
    <tr class="table-secondary dungeon-detail-row">
        <td colspan="7" style="max-width:0;">
            <div class="mb-2 dungeon-description">
                @d.DescriptionForCurrentCulture(_dungeonLocs)
            </div>

            @if (d.Stages == null || d.Stages.Count == 0)
            {
                <em>No stages defined.</em>
            }
            else
            {
                <div class="accordion" id="acc-@d.Id">
                    <div class="accordion-item bg-dark text-light">
                        <h2 class="accordion-header" id="heading-@d.Id">
                            <button class="accordion-button collapsed"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#collapse-@d.Id"
                                    aria-expanded="false"
                                    aria-controls="collapse-@d.Id">
                                Stages &amp; monsters
                            </button>
                        </h2>

                        <div id="collapse-@d.Id"
                             class="accordion-collapse collapse show"
                             aria-labelledby="heading-@d.Id">
                            <div class="accordion-body">

                                <!-- ✅ scroll wrapper for INNER stats table -->
                                <div class="table-scroll-x inner-scroll">
                <table class="table table-sm table-dark align-middle text-nowrap mb-0 inner-wide">
                                        <thead>
                                            <tr>
                                                <th class="">#</th>
                                                <th class="">Stage type</th>
                                                <th class="">Monster</th>
                                                <th class="">Level</th>
                                                <th class="">Element</th>

                                                @foreach (var col in StatColumns)
                                                {
                                                    <th class="">@col.Header</th>
                                                }
                                            </tr>
                                        </thead>

                                        <tbody>
                                            @foreach (var s in d.Stages.OrderBy(s => s.StageIndex))
                                            {
                                                var mt = s.MonsterTemplate;
                                                <tr>
                                                    <td class="">@s.StageIndex</td>
                                                    <td class="">@s.StageType</td>

                                                    <td class=""
                                                        title="@(mt is null ? "" : mt.NameForCurrentCulture(_monsterLocs))">
                                                        @(mt is null ? "-" : mt.NameForCurrentCulture(_monsterLocs))
                                                    </td>

                                                    <td class="">@mt?.BaseLevel</td>
                                                    <td class="">@mt?.Element</td>

                                                    @foreach (var col in StatColumns)
                                                    {
                                                        <td class="">@FormatStat(col.GetValue(mt?.BaseStats))</td>
                                                    }
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            }
        </td>
    </tr>
}
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    private bool isLoading = true;

    private List<Dungeon> dungeons = new();

    private string manualDungeonName = string.Empty;
    private bool IsManualGenerateDisabled => isLoading || string.IsNullOrWhiteSpace(manualDungeonName);

    private HashSet<Guid> expandedDungeonIds = new();

    // localizations loaded in bulk
    private List<LocalizedText> _dungeonLocs = new();
    private List<LocalizedText> _monsterLocs = new();

    private ImagePreviewer? imagePreviewer;

    // ===== Coverage metrics =====
    private int _localeCount;

    private int _dungeonHaveRows;
    private int _dungeonMaxRows;
    private int _dungeonFullyLocalized;
    private int _dungeonTotal;

    private int _beastHaveRows;
    private int _beastMaxRows;
    private int _beastFullyLocalized;
    private int _beastTotal;
    private int _beastWithItemTemplates;

    // kolik "polí" počítáš za 1 LocalizedText řádek (Name + Description)
    private const int LocFieldsPerCulture = 2;

    protected override async Task OnInitializedAsync()
    {
        await LoadDungeons();
    }

    private async Task LoadDungeons()
    {
        isLoading = true;

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            dungeons = await db.Dungeons
                .Include(x => x.Stages).ThenInclude(x => x.MonsterTemplate)
                .OrderBy(d => d.MinLevel)
                .ThenBy(d => d.Code)
                .ToListAsync();

            // načti lokalizace + spočítej coverage (v separátním kontextu)
            await using var db2 = await DbFactory.CreateDbContextAsync();
            await LoadLocalizationsAndCoverageAsync(db2);

            Toasts.Success("Dungeons loaded", $"Loaded {dungeons.Count} dungeons.");
        }
        catch (Exception ex)
        {
            Toasts.Error("Failed to load dungeons", ex.Message);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadLocalizationsAndCoverageAsync(MercenariesAndBeastsDbContext db)
    {
        _localeCount = LocalizationConfig.SupportedLocales.Length;

        var dungeonIds = dungeons.Select(x => x.Id).ToList();

        var monsterIds = dungeons
            .SelectMany(d => d.Stages ?? new List<DungeonStage>())
            .Select(s => s.MonsterTemplateId)
            .Distinct()
            .ToList();

        _dungeonLocs = dungeonIds.Count == 0
            ? new()
            : await db.LocalizedTexts
                .Where(x => x.EntityType == nameof(Dungeon) && dungeonIds.Contains(x.EntityId))
                .ToListAsync();

        _monsterLocs = monsterIds.Count == 0
            ? new()
            : await db.LocalizedTexts
                .Where(x => x.EntityType == nameof(MonsterTemplate) && monsterIds.Contains(x.EntityId))
                .ToListAsync();

        // ===== DUNGEONS coverage =====
        _dungeonTotal = dungeonIds.Count;
        _dungeonMaxRows = _dungeonTotal * _localeCount * LocFieldsPerCulture;
        _dungeonHaveRows = CountHaveRows_NameDesc(_dungeonLocs);
        _dungeonFullyLocalized = CountFullyLocalized_NameDesc_Strict(dungeonIds, _dungeonLocs);

        // ===== BEASTS coverage =====
        _beastTotal = monsterIds.Count;
        _beastMaxRows = _beastTotal * _localeCount * LocFieldsPerCulture;
        _beastHaveRows = CountHaveRows_NameDesc(_monsterLocs);
        _beastFullyLocalized = CountFullyLocalized_NameDesc_Strict(monsterIds, _monsterLocs);

        // has ItemTemplate (pro beasty)
        _beastWithItemTemplates = _beastTotal == 0
            ? 0
            : await db.ItemTemplates
                .Where(t => t.MonsterTemplateId != null && monsterIds.Contains(t.MonsterTemplateId.Value))
                .Select(t => t.MonsterTemplateId!.Value)
                .Distinct()
                .CountAsync();
    }

    private static int CountHaveRows_NameDesc(List<LocalizedText> rows)
    {
        var supported = LocalizationConfig.SupportedLocales.ToHashSet(StringComparer.OrdinalIgnoreCase);

        int count = 0;
        foreach (var r in rows)
        {
            if (!supported.Contains(r.Culture))
                continue;

            if (!string.IsNullOrWhiteSpace(r.Name))
                count++;

            if (!string.IsNullOrWhiteSpace(r.Description))
                count++;
        }

        return count;
    }

    /// <summary>
    /// Fully localized (STRICT) = pro každou SupportedLocale existuje řádek a má vyplněné Name i Description.
    /// Pokud chceš mírnější variantu (jen Name), změň podmínku na kontrolu jen Name.
    /// </summary>
    private static int CountFullyLocalized_NameDesc_Strict(List<Guid> entityIds, List<LocalizedText> rows)
    {
        if (entityIds.Count == 0) return 0;

        var locales = LocalizationConfig.SupportedLocales;

        var byEntity = rows
            .GroupBy(x => x.EntityId)
            .ToDictionary(g => g.Key, g => g.ToList());

        int full = 0;

        foreach (var id in entityIds)
        {
            if (!byEntity.TryGetValue(id, out var list))
                continue;

            bool ok = true;

            foreach (var loc in locales)
            {
                var hit = list.FirstOrDefault(x => x.Culture.Equals(loc, StringComparison.OrdinalIgnoreCase));
                if (hit is null)
                {
                    ok = false;
                    break;
                }

                if (string.IsNullOrWhiteSpace(hit.Name) || string.IsNullOrWhiteSpace(hit.Description))
                {
                    ok = false;
                    break;
                }
            }

            if (ok) full++;
        }

        return full;
    }

    private void ToggleDungeonStages(Guid dungeonId)
    {
        if (expandedDungeonIds.Contains(dungeonId))
            expandedDungeonIds.Remove(dungeonId);
        else
            expandedDungeonIds.Add(dungeonId);
    }

    private void ShowImage(string? url)
    {
        if (!string.IsNullOrWhiteSpace(url))
            imagePreviewer?.Open(url);
    }

    private async Task GenerateNextDungeon(bool current)
    {
        isLoading = true;
        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            var newDungeon = new Dungeon();

            var lastDungeon = await db.Dungeons
                .OrderByDescending(d => d.UnlockOrder)
                .FirstOrDefaultAsync();

            if (lastDungeon is null)
            {
                newDungeon.MinLevel = 1;
                newDungeon.MaxLevel = 5;
            }
            else
            {
                newDungeon.MinLevel = lastDungeon.MinLevel;
                newDungeon.MaxLevel = lastDungeon.MaxLevel;
            }

            if (current)
                newDungeon.NameEn = manualDungeonName.Trim();

            var dungeon = await DungeonAi.GenerateNextDungeonAsync(lastDungeon, newDungeon, current, "", CancellationToken.None);
            if (dungeon is null)
            {
                Toasts.Error("AI generation failed", "No dungeon was generated.");
                return;
            }

            await db.SaveChangesAsync();
            await LoadDungeons();

            Toasts.Success("Dungeon created", dungeon.NameEn);
        }
        catch (Exception ex)
        {
            Toasts.Error("Failed to generate dungeon", ex.Message);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task GenerateDungeonImage(Dungeon d)
    {
        isLoading = true;
        StateHasChanged();

        await using var db = await DbFactory.CreateDbContextAsync();
        try
        {
            var path = await ImageAi.GenerateDungeonImageAsync(d);
            if (string.IsNullOrWhiteSpace(path))
            {
                Toasts.Error("Image generation failed", "AI did not return any image.");
                return;
            }

            // reload tracked entity and update
            var dbDungeon = await db.Dungeons.FirstAsync(x => x.Id == d.Id);
            dbDungeon.ImagePath = path;

            await db.SaveChangesAsync();
            await LoadDungeons();

            Toasts.Success("Dungeon image generated", d.NameEn);
        }
        catch (Exception ex)
        {
            Toasts.Error("Failed to generate dungeon image", ex.Message);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    // ===========================
    // STAT TABLE (reflection)
    // ===========================
    private sealed record StatCol(string Header, Func<StatBlock?, object?> GetValue);
    private static readonly List<StatCol> StatColumns = BuildStatColumns();

    private static List<StatCol> BuildStatColumns()
    {
        var t = typeof(StatBlock);

        var props = t.GetProperties(BindingFlags.Instance | BindingFlags.Public)
            .Where(p => p.CanRead &&
                        (p.PropertyType == typeof(int) ||
                         p.PropertyType == typeof(long) ||
                         p.PropertyType == typeof(float) ||
                         p.PropertyType == typeof(double)) &&
                        p.Name != nameof(StatBlock.Element)) // element máš jako vlastní sloupec
            .OrderBy(p => p.Name)
            .ToList();

        var cols = new List<StatCol>(props.Count);
        foreach (var p in props)
        {
            cols.Add(new StatCol(
                Header: p.Name,
                GetValue: sb => sb is null ? null : p.GetValue(sb)
            ));
        }

        return cols;
    }

    private static string FormatStat(object? v)
    {
        if (v is null) return "-";

        if (v is int i && i == 0) return "-";
        if (v is long l && l == 0) return "-";
        if (v is float f && Math.Abs(f) < 0.0001f) return "-";
        if (v is double d && Math.Abs(d) < 0.0001) return "-";

        return v switch
        {
            double d2 => d2.ToString("0.###", CultureInfo.InvariantCulture),
            float f2 => f2.ToString("0.###", CultureInfo.InvariantCulture),
            _ => v.ToString() ?? "-"
        };
    }
}