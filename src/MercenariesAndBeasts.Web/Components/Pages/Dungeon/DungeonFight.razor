@* AUDIT:FIXED|byl: IDOR – vstup do neodemčeného dungeonu; přidána unlock validation *@
@page "/dungeons/{DungeonId:guid}/fight"
@using System.Globalization
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity

@using MercenariesAndBeasts.Infrastructure
@using MercenariesAndBeasts.Infrastructure.Fights
@using MercenariesAndBeasts.Domain
@using MercenariesAndBeasts.Domain.Players
@using MercenariesAndBeasts.Domain.Progress
@using MercenariesAndBeasts.Domain.Enums
@using MercenariesAndBeasts.Domain.User
@using MercenariesAndBeasts.Infrastructure.Players

@inject IDbContextFactory<AppDbContextMercenariesAndBeasts> DbFactory
@inject UserManager<AppUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject IFightService FightService
@inject FightHistoryService FightHistoryService
@inject MercenariesAndBeasts.Web.Services.LevelUpService LevelUpService

@attribute [Authorize]
@rendermode InteractiveServer

<PageTitle>Dungeon Fight — Mercenaries & Beasts</PageTitle>

@if (isLoading)
{
    <PageLoadingSpinner />
}
else if (errorMessage is not null)
{
    <div class="card-like">
        <div class="alert alert-warning mb-0">@errorMessage</div>
        <a href="/dungeons" class="btn btn-secondary btn-sm mt-2">← Zpět na dungeony</a>
    </div>
}
else if (player is null || dungeon is null)
{
    <div class="ui-panel">
        <div class="alert alert-danger mb-0">Missing player or dungeon.</div>
    </div>
}
else
{
    <div class="ui-panel">
        <div class="d-flex justify-content-between align-items-start gap-3">
            <div>
                <h3 class="m-0">@DngName(dungeon)</h3>
                <div class="text-muted small">Stage @currentStage / 11</div>
                <div class="text-muted small">
                    Enemy: <b class="text-light">@(enemy is null ? "—" : MonsterName(enemy))</b>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-primary"
                        disabled="@hasResolved || enemy is null"
                        @onclick="RunFightAsync">
                    Simulate Fight
                </button>
                <a class="btn btn-outline-secondary" href="/dungeons">Back</a>
            </div>
        </div>

        @if (hasResolved)
        {
            <hr />
            <h4 class="m-0 @(didWin ? "text-success" : "text-danger")">
                @(didWin ? "⚔️ Victory" : "💀 Defeat")
            </h4>
            <div class="text-muted small mt-1">@resultText</div>

            @if (fightLog.Count > 0)
            {
                <hr />
                <div class="fw-bold mb-2">Fight log</div>
                <ul class="mb-0 text-muted small">
                    @foreach (var line in fightLog)
                    {
                        <li>@line</li>
                    }
                </ul>
            }

            <div class="mt-3">
                <div class="text-muted small"><b class="text-light">New stage:</b> @newStage / 11</div>
                @if (progress?.IsCompleted == true)
                {
                    <span class="badge bg-success mt-2">Dungeon Completed</span>
                }
            </div>

            <hr />
            <h5>Loot</h5>
            <ul class="mb-0">
                @foreach (var l in lootLines)
                {
                    <li>@l</li>
                }
            </ul>
        }
    </div>
}

@code {
    [Parameter] public Guid DungeonId { get; set; }

    private bool isLoading = true;
    private string? errorMessage;

    private string? _userId; // ASP.NET Identity user ID for inventory writes
    private PlayerProfile? player;
    private Dungeon? dungeon;
    private PlayerDungeonProgress? progress;

    private int currentStage = 1;
    private MonsterTemplate? enemy;

    private bool hasResolved = false;
    private bool didWin = false;
    private string resultText = "";
    private int newStage = 1;
    private List<string> lootLines = new();
    private List<string> fightLog = new();

    // ===== LocalizedText cache =====
    private List<LocalizedText> _dngLocs = new();
    private List<LocalizedText> _monsterLocs = new();

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;

        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = await UserManager.GetUserAsync(auth.User);
            if (user is null) return;

            _userId = user.Id;

            await using var db = await DbFactory.CreateDbContextAsync();

            player = await db.Players.FirstOrDefaultAsync(p => p.UserId == user.Id);
            if (player is null) return;

            dungeon = await db.Dungeons
                .Include(d => d.Stages)
                    .ThenInclude(s => s.MonsterTemplate)
                .FirstOrDefaultAsync(d => d.Guid == DungeonId);

            if (dungeon is null) return;

            // Ověření že dungeon je odemčen pro hráče
            var maxCompleted = await db.PlayerDungeonProgresses
                .Where(p => p.PlayerId == player.Guid && p.IsCompleted)
                .Join(db.Dungeons, p => p.DungeonId, d => d.Guid, (p, d) => d.UnlockOrder)
                .DefaultIfEmpty(0)
                .MaxAsync();
            if (dungeon.UnlockOrder > maxCompleted + 1)
            {
                errorMessage = "Tento dungeon ještě není odemčen.";
                return;
            }

            progress = await db.PlayerDungeonProgresses
                .FirstOrDefaultAsync(p => p.PlayerId == player.Guid && p.DungeonId == dungeon.Guid);

            if (progress is null)
            {
                progress = new PlayerDungeonProgress
                {
PlayerId = player.Guid,
                    DungeonId = dungeon.Guid,
                    MaxStageReached = 0,
                    IsCompleted = false,
                    LastUpdatedUtc = DateTime.UtcNow
                };

                db.PlayerDungeonProgresses.Add(progress);
                await db.SaveChangesAsync();
            }

            currentStage = Math.Max(1, progress.MaxStageReached == 0 ? 1 : progress.MaxStageReached);

            var maxStageDefined = dungeon.Stages?.Count > 0
                ? dungeon.Stages.Max(s => s.StageIndex)
                : 11;

            currentStage = Math.Clamp(currentStage, 1, Math.Max(1, maxStageDefined));

            await LoadDungeonLocalizationsAsync(db, new List<Guid> { dungeon.Guid });

            enemy = PickDungeonEnemy(dungeon, currentStage);

            if (enemy is not null)
                await LoadMonsterLocalizationsAsync(db, new List<Guid> { enemy.Guid });
        }
        finally
        {
            isLoading = false;
        }
    }

    private static MonsterTemplate? PickDungeonEnemy(Dungeon dng, int stage)
    {
        var st = dng.Stages?
            .OrderBy(s => s.StageIndex)
            .FirstOrDefault(s => s.StageIndex == stage);

        if (st?.MonsterTemplate is not null)
            return st.MonsterTemplate;

        var nearest = dng.Stages?
            .Where(s => s.StageIndex <= stage)
            .OrderByDescending(s => s.StageIndex)
            .FirstOrDefault();

        if (nearest?.MonsterTemplate is not null)
            return nearest.MonsterTemplate;

        return dng.Stages?
            .OrderBy(s => s.StageIndex)
            .FirstOrDefault()
            ?.MonsterTemplate;
    }

    private async Task RunFightAsync()
    {
        if (hasResolved || player is null || dungeon is null || enemy is null)
            return;

        hasResolved = true;
        fightLog = new();
        lootLines = new();

        await using var db = await DbFactory.CreateDbContextAsync();

        // reload progress tracked in THIS db
        var pr = await db.PlayerDungeonProgresses
            .FirstOrDefaultAsync(p => p.PlayerId == player.Guid && p.DungeonId == dungeon.Guid);

        if (pr is null)
        {
            didWin = false;
            resultText = "Progress not found.";
            return;
        }

        // ===========================
        // Build fight input
        // ===========================

        // Enemy stats (fallback safe)
        var enemyStats = (enemy.BaseStats ?? StatBlock.Zero).Clone();

        // Load player party from mercenary and beast slots
        var playerUnits = new List<FightUnitInput>();

        var mercSlots = await db.PlayerMercenarySlots
            .Where(s => s.PlayerProfileId == player.Guid && s.MercenaryInstanceId != null)
            .Include(s => s.Mercenary)
                .ThenInclude(m => m!.Template)
            .OrderBy(s => s.SlotIndex)
            .ToListAsync();

        var beastSlots = await db.PlayerBeastSlots
            .Where(s => s.PlayerProfileId == player.Guid && s.BeastInstanceId != null)
            .Include(s => s.Beast)
                .ThenInclude(b => b!.Template)
            .OrderBy(s => s.SlotIndex)
            .ToListAsync();

        foreach (var slot in mercSlots)
        {
            if (slot.Mercenary?.Template is null) continue;
            var m = slot.Mercenary;
            var stats = m.Template.BaseStats.Clone();
            ApplyLevelScaling(stats, m.Level);
            stats.AddInPlace(m.BonusStats);
            playerUnits.Add(new FightUnitInput(m.Guid, m.Template.NameEn, stats));
        }

        foreach (var slot in beastSlots)
        {
            if (slot.Beast?.Template is null) continue;
            var b = slot.Beast;
            var stats = b.Template.BaseStats.Clone();
            ApplyLevelScaling(stats, b.Level);
            stats.AddInPlace(b.BonusStats);
            playerUnits.Add(new FightUnitInput(b.Guid, b.Template.NameEn, stats));
        }

        if (playerUnits.Count == 0)
        {
            didWin = false;
            resultText = "No units assigned to party slots. Add mercenaries or beasts to your party first.";
            return;
        }

        var fightInput = new FightRequest
        {
            PlayerId = player.Guid,
            DungeonId = dungeon.Guid,
            Stage = currentStage,
            Seed = HashCode.Combine(player.Guid, dungeon.Guid, currentStage, enemy.Guid),
            PlayerUnits = playerUnits,
            Enemy = new FightUnitInput(enemy.Guid, enemy.NameEn ?? "Enemy", enemyStats)
        };

        // ===========================
        // Run FightService
        // ===========================
        FightResult fightResult;
        try
        {
            fightResult = await FightService.ResolveDungeonFightAsync(fightInput, CancellationToken.None);
        }
        catch (Exception ex)
        {
            didWin = false;
            resultText = $"FightService error: {ex.Message}";
            return;
        }

        didWin = fightResult.DidWin;
        resultText = fightResult.Summary ?? (didWin ? "Victory." : "Defeat.");
        fightLog = fightResult.LogLines?.Take(200).ToList() ?? new();

        // ===========================
        // Apply dungeon progress
        // ===========================
        if (didWin)
        {
            newStage = Math.Min(11, currentStage + 1);

            if (currentStage >= 11)
            {
                pr.IsCompleted = true;
                newStage = 11;
            }

            pr.MaxStageReached = Math.Max(pr.MaxStageReached, newStage);
        }
        else
        {
            newStage = Math.Max(1, currentStage - 1);
        }

        pr.CurrentStage = newStage;
        pr.LastUpdatedUtc = DateTime.UtcNow;

        await db.SaveChangesAsync();

        // Record fight in history + award item points per equipped item on win
        _ = await FightHistoryService.RecordDungeonFightAsync(
            player.Guid,
            DungeonId,          // nearest available context reference (DungeonId, not stage row)
            fightResult,
            fightInput.Seed);

        // Apply loot items to player inventory
        if (didWin && _userId is not null && fightResult.LootItems?.Count > 0)
            await ApplyLootAsync(db, _userId, fightResult.LootItems);

        // Loot display lines
        foreach (var line in fightResult.LootLines ?? Enumerable.Empty<string>())
            lootLines.Add(line);

        if (lootLines.Count == 0)
            lootLines.Add(didWin ? "No specific loot this run." : "No loot.");

        // update UI cache copy
        if (progress is not null)
        {
            progress.MaxStageReached = pr.MaxStageReached;
            progress.IsCompleted = pr.IsCompleted;
            progress.LastUpdatedUtc = pr.LastUpdatedUtc;
        }

        // Level-up check — runs after dungeon completion (win or loss; thresholds decide)
        if (player?.Guid != Guid.Empty)
            await LevelUpService.CheckAndApplyAsync(player!.Guid);

        StateHasChanged();
    }

    // ===========================
    // Inventory helpers
    // ===========================

    private static async Task ApplyLootAsync(
        AppDbContextMercenariesAndBeasts db,
        string userId,
        List<LootItem> lootItems)
    {
        var types = lootItems.Select(x => x.ResourceType).Distinct().ToList();

        // Find upgrade resource definitions (one ItemTemplate per resource type)
        var resources = await db.ItemUpgradeResources
            .Where(r => types.Contains(r.Type))
            .ToListAsync();

        if (resources.Count == 0) return; // no resources seeded in DB yet

        foreach (var loot in lootItems)
        {
            var resource = resources.FirstOrDefault(r => r.Type == loot.ResourceType);
            if (resource is null) continue;

            var inv = await db.UserInventoryItems
                .FirstOrDefaultAsync(x => x.UserId == userId && x.ItemTemplateId == resource.ItemTemplateId);

            if (inv is null)
            {
                db.UserInventoryItems.Add(new UserInventoryItem
                {
UserId = userId,
                    ItemTemplateId = resource.ItemTemplateId,
                    Quantity = loot.Quantity
                });
            }
            else
            {
                inv.Quantity += loot.Quantity;
            }
        }

        await db.SaveChangesAsync();
    }

    // ===========================
    // Localization helpers
    // ===========================
    private async Task LoadDungeonLocalizationsAsync(AppDbContextMercenariesAndBeasts db, List<Guid> dungeonIds)
    {
        if (dungeonIds.Count == 0) { _dngLocs = new(); return; }

        _dngLocs = await db.LocalizedTexts
            .Where(x => x.EntityType == nameof(Dungeon) && dungeonIds.Contains(x.EntityId))
            .ToListAsync();
    }

    private async Task LoadMonsterLocalizationsAsync(AppDbContextMercenariesAndBeasts db, List<Guid> monsterIds)
    {
        if (monsterIds.Count == 0) { _monsterLocs = new(); return; }

        _monsterLocs = await db.LocalizedTexts
            .Where(x => x.EntityType == nameof(MonsterTemplate) && monsterIds.Contains(x.EntityId))
            .ToListAsync();
    }

    private string DngName(Dungeon d)
        => Localize(_dngLocs, nameof(Dungeon), d.Guid, "Name", d.NameEn);

    private string MonsterName(MonsterTemplate m)
        => Localize(_monsterLocs, nameof(MonsterTemplate), m.Guid, "Name", m.NameEn);

    private static string Localize(
        List<LocalizedText> cache,
        string entityType,
        Guid entityId,
        string field,
        string fallback)
    {
        var culture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;

        var loc = cache.FirstOrDefault(x =>
            x.EntityType == entityType &&
            x.EntityId == entityId &&
            x.Culture == culture);

        if (loc is null)
            return fallback;

        string? value = field switch
        {
            "Name" => loc.Name,
            "Description" => loc.Description,
            _ => null
        };

        return string.IsNullOrWhiteSpace(value) ? fallback : value!;
    }

    private static void ApplyLevelScaling(StatBlock s, int level)
    {
        var lvl = Math.Max(1, level);
        var kCore = 1.0 + 0.03 * (lvl - 1);
        s.MaxHp   = (float)(s.MaxHp   * kCore);
        s.Attack  = (float)(s.Attack  * kCore);
        s.Defense = (float)(s.Defense * kCore);
        s.Speed   = (float)(s.Speed   * (1.0 + 0.01 * (lvl - 1)));
    }
}