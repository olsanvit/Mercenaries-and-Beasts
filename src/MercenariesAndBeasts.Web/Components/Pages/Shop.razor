@* AUDIT:PENDING|Střední|Chybí rate limiting na nákup herní měny *@
@page "/shop"
@attribute [Authorize]
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using MercenariesAndBeasts.Domain.Players

@inject IDbContextFactory<AppDbContextMercenariesAndBeasts> DbFactory
@inject UserManager<AppUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Shop — Mercenaries & Beasts</PageTitle>

<div class="ui-page-header ui-anim-fade-up">
    <h3><i class="bi bi-shop"></i> Shop</h3>
</div>

@if (_loading)
{
    <div class="ui-anim-fade-up d-flex align-items-center gap-2 mt-3">
        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
        <span class="text-muted">Loading shop…</span>
    </div>
}
else
{
    <!-- Wallet -->
    <div class="ui-panel ui-anim-fade-up">
        <div class="ui-panel-header">
            <span class="ui-panel-title">
                <i class="bi bi-wallet2 text-accent"></i>
                Your Wallet
            </span>
        </div>
        <div class="p-3">
            <div class="d-flex gap-4">
                <div>
                    <div class="text-muted small mb-1">💰 Soft Currency</div>
                    <div class="fw-bold fs-5">@(_player?.SoftCurrency.ToString("N0") ?? "—")</div>
                </div>
                <div>
                    <div class="text-muted small mb-1">💎 Premium Currency</div>
                    <div class="fw-bold fs-5">@(_player?.PremiumCurrency.ToString("N0") ?? "—")</div>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <div class="ui-anim-fade-up d-flex align-items-center gap-2 mb-2 @(_isError ? "text-danger" : "text-success")">
            <i class="bi @(_isError ? "bi-exclamation-triangle-fill" : "bi-check-circle-fill")"></i>
            <span class="small">@_message</span>
        </div>
    }

    <div class="row g-3">
        <!-- Soft Currency packs -->
        <div class="col-md-6">
            <div class="ui-panel ui-anim-fade-up">
                <div class="ui-panel-header">
                    <span class="ui-panel-title">
                        <span class="icon-bg icon-amber"><i class="bi bi-coin"></i></span>
                        Soft Currency
                    </span>
                </div>
                <div class="p-3">
                    <p class="text-muted small mb-3">Used for upgrades, crafting and rerolls.</p>
                    <div class="d-grid gap-2">
                        <button class="btn btn-primary btn-sm" disabled="@_purchasing"
                                @onclick='() => PurchaseAsync("soft", 1_000, "€1.99")'>
                            Buy 1 000 Soft — €1.99
                        </button>
                        <button class="btn btn-primary btn-sm" disabled="@_purchasing"
                                @onclick='() => PurchaseAsync("soft", 5_000, "€7.99")'>
                            Buy 5 000 Soft — €7.99
                        </button>
                        <button class="btn btn-outline-primary btn-sm" disabled="@_purchasing"
                                @onclick='() => PurchaseAsync("soft", 20_000, "€24.99")'>
                            Buy 20 000 Soft — €24.99
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Premium Currency packs -->
        <div class="col-md-6">
            <div class="ui-panel ui-anim-fade-up">
                <div class="ui-panel-header">
                    <span class="ui-panel-title">
                        <span class="icon-bg icon-purple"><i class="bi bi-gem"></i></span>
                        Premium Currency
                    </span>
                </div>
                <div class="p-3">
                    <p class="text-muted small mb-3">Used for premium packs and special offers.</p>
                    <div class="d-grid gap-2">
                        <button class="btn btn-warning btn-sm" disabled="@_purchasing"
                                @onclick='() => PurchaseAsync("premium", 100, "€4.99")'>
                            Buy 100 Premium — €4.99
                        </button>
                        <button class="btn btn-warning btn-sm" disabled="@_purchasing"
                                @onclick='() => PurchaseAsync("premium", 300, "€12.99")'>
                            Buy 300 Premium — €12.99
                        </button>
                        <button class="btn btn-outline-warning btn-sm" disabled="@_purchasing"
                                @onclick='() => PurchaseAsync("premium", 1_000, "€34.99")'>
                            Buy 1 000 Premium — €34.99
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private bool _purchasing = false;
    private bool _isError = false;
    private string? _message;

    private PlayerProfile? _player;
    private string? _userId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = await UserManager.GetUserAsync(auth.User);
            if (user is null) return;

            _userId = user.Id;

            await using var db = await DbFactory.CreateDbContextAsync();
            _player = await db.Players.FirstOrDefaultAsync(p => p.UserId == user.Id);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task PurchaseAsync(string type, long amount, string price)
    {
        if (_purchasing || _player is null || _userId is null) return;

        _purchasing = true;
        _message = null;
        StateHasChanged();

        try
        {
            // POZNÁMKA: Platební brána není implementována — hra je free-to-play bez microtransakcí.
            // Tato metoda přímo přidává měnu jako odměnu (např. za denní přihlášení, splnění mise apod.).
            await using var db = await DbFactory.CreateDbContextAsync();
            var player = await db.Players.FirstOrDefaultAsync(p => p.UserId == _userId);
            if (player is null)
            {
                _isError = true;
                _message = "Player profile not found.";
                return;
            }

            if (type == "soft")
                player.SoftCurrency += amount;
            else
                player.PremiumCurrency += (int)amount;

            await db.SaveChangesAsync();

            _player = player;
            _isError = false;
            _message = $"Purchase simulated: +{amount:N0} {(type == "soft" ? "💰 Soft" : "💎 Premium")} ({price})";
        }
        catch (Exception ex)
        {
            _isError = true;
            _message = $"Purchase failed: {ex.Message}";
        }
        finally
        {
            _purchasing = false;
            StateHasChanged();
        }
    }
}
