@page "/shop"
@attribute [Authorize]

<div class="dash-switcher mb-3">
    <h4 class="m-0">Shop</h4>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card-like">
            <h5 class="mb-1">💰 Soft Currency</h5>
            <p class="text-muted small mb-3">Used for upgrades, crafting and rerolls.</p>

            <div class="d-grid gap-2">
                <button class="btn btn-primary">Buy 1 000 Soft – €1.99</button>
                <button class="btn btn-primary">Buy 5 000 Soft – €7.99</button>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card-like">
            <h5 class="mb-1">💎 Premium Currency</h5>
            <p class="text-muted small mb-3">Used for premium packs and special offers.</p>

            <div class="d-grid gap-2">
                <button class="btn btn-warning">Buy 100 Premium – €4.99</button>
                <button class="btn btn-warning">Buy 300 Premium – €12.99</button>
            </div>
        </div>
    </div>
</div>