@page "/shop"
@attribute [Authorize]

<h2 class="mb-4">Shop</h2>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card p-3">
            <h4>💰 Soft Currency</h4>
            <p>Used for upgrades, crafting and rerolls.</p>

            <button class="btn btn-outline-primary w-100 mb-2">
                Buy 1 000 Soft – €1.99
            </button>
            <button class="btn btn-outline-primary w-100 mb-2">
                Buy 5 000 Soft – €7.99
            </button>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card p-3">
            <h4>💎 Premium Currency</h4>
            <p>Used for premium packs and special offers.</p>

            <button class="btn btn-warning w-100 mb-2">
                Buy 100 Premium – €4.99
            </button>
            <button class="btn btn-warning w-100 mb-2">
                Buy 300 Premium – €12.99
            </button>
        </div>
    </div>
</div>