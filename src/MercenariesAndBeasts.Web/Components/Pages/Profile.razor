@* AUDIT:OK *@
@page "/profile"
@attribute [Authorize]
@rendermode InteractiveServer

@using MercenariesAndBeasts.Domain.Localization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using MercenariesAndBeasts.Infrastructure
@using MercenariesAndBeasts.Domain
@using MercenariesAndBeasts.Domain.Players
@using System.Threading

@inject UserManager<AppUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject IDbContextFactory<AppDbContextMercenariesAndBeasts> DbFactory

<PageTitle>Profile — Mercenaries & Beasts</PageTitle>

<div class="ui-page-header ui-anim-fade-up">
    <h3><i class="bi bi-person-circle"></i> Profile</h3>
</div>

@if (_loading)
{
    <div class="ui-anim-fade-up d-flex align-items-center gap-2 mt-3">
        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
        <span class="text-muted">Loading profile…</span>
    </div>
}
else if (_player is null)
{
    <div class="ui-panel ui-anim-fade-up p-3">
        <div class="d-flex align-items-center gap-2 text-danger">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>No player profile found.</span>
        </div>
    </div>
}
else
{
    <!-- Account info -->
    <div class="ui-panel ui-anim-fade-up">
        <div class="ui-panel-header">
            <span class="ui-panel-title">
                <i class="bi bi-person text-accent"></i>
                Account
            </span>
        </div>
        <div class="p-3">
            <div class="text-muted small">Username</div>
            <div class="fw-semibold">@_userName</div>
        </div>
    </div>

    <!-- Player stats -->
    <div class="ui-panel ui-anim-fade-up">
        <div class="ui-panel-header">
            <span class="ui-panel-title">
                <i class="bi bi-bar-chart-fill text-accent"></i>
                Statistiky hráče
            </span>
        </div>
        <div class="p-3">
            <div class="row g-3">
                <div class="col-6 col-md-3 text-center">
                    <div class="fw-bold fs-4 text-accent">@_player.Level</div>
                    <div class="text-muted small">Úroveň</div>
                </div>
                <div class="col-6 col-md-3 text-center">
                    <div class="fw-bold fs-4">@_player.Experience.ToString("N0")</div>
                    <div class="text-muted small">Zkušenosti (XP)</div>
                </div>
                <div class="col-6 col-md-3 text-center">
                    <div class="fw-bold fs-4 text-warning">@_player.SoftCurrency.ToString("N0")</div>
                    <div class="text-muted small"><i class="bi bi-coin me-1"></i>Měna</div>
                </div>
                <div class="col-6 col-md-3 text-center">
                    <div class="fw-bold fs-4 text-info">@_player.Energy / @_player.MaxEnergy</div>
                    <div class="text-muted small"><i class="bi bi-lightning-fill me-1"></i>Energie</div>
                </div>
            </div>
            <div class="mt-3">
                <a href="/history" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-journal-text me-1"></i>Historie bitev
                </a>
                <a href="/leaderboard" class="btn btn-outline-secondary btn-sm ms-2">
                    <i class="bi bi-trophy me-1"></i>Žebříček
                </a>
            </div>
        </div>
    </div>

    <!-- Country settings -->
    <div class="ui-panel ui-anim-fade-up">
        <div class="ui-panel-header">
            <span class="ui-panel-title">
                <i class="bi bi-flag text-accent"></i>
                Country
            </span>
        </div>
        <div class="p-3">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-md-4">
                    <label class="form-label small text-muted">Country (ISO2)</label>
                    <select class="form-select form-select-sm"
                            style="background:rgba(255,255,255,0.05);border-color:rgba(255,255,255,0.1);color:var(--ui-text-1)"
                            @bind="_selectedCountry">
                        <option value="">(not set)</option>
                        @foreach (var c in Countries)
                        {
                            <option value="@c.Code">@c.Name (@c.Code)</option>
                        }
                    </select>
                    <div class="text-muted small mt-1">ISO 3166-1 alpha-2 code (e.g. CZ, SK, DE)</div>
                </div>

                <div class="col-12 col-md-4">
                    <div class="text-muted small">Current</div>
                    <div class="fw-semibold">@(_player.CountryCode ?? "(not set)")</div>
                    <div class="text-muted small mt-2">Last change</div>
                    <div class="small">
                        @(_player.CountryChangedUtc is null
                            ? "—"
                            : _player.CountryChangedUtc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm"))
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <div class="text-muted small">Cost</div>
                    <div class="fw-semibold">@_costSoft</div>
                    <div class="text-muted small mt-2">Cooldown</div>
                    <div class="fw-semibold @(_canChange ? "text-success" : "text-warning")">
                        @(_canChange ? "Ready" : "Waiting")
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2 mt-3">
                <button class="btn btn-success btn-sm" @onclick="SaveCountryAsync" disabled="@(!_canSave)">
                    <i class="bi bi-floppy me-1"></i>Save
                </button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="ReloadAsync" disabled="@_loading">
                    <i class="bi bi-arrow-clockwise me-1"></i>Reload
                </button>
            </div>

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="d-flex align-items-center gap-2 text-danger mt-3">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span class="small">@_error</span>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(_ok))
            {
                <div class="d-flex align-items-center gap-2 text-success mt-3">
                    <i class="bi bi-check-circle-fill"></i>
                    <span class="small">@_ok</span>
                </div>
            }
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private PlayerProfile? _player;
    private string _userName = "";

    private string _selectedCountry = "";
    private string _error = "";
    private string _ok = "";

    private bool _canChange;
    private long _costSoft;

    private bool _canSave => _player != null && _canChange && !_loading;

    private readonly SemaphoreSlim _gate = new(1, 1);

    private static readonly IReadOnlyList<CountryCatalog.CountryOpt> Countries = CountryCatalog.GetAll();

    protected override async Task OnInitializedAsync()
        => await ReloadAsync();

    private async Task ReloadAsync()
    {
        await _gate.WaitAsync();
        try
        {
            _loading = true;
            _error = "";
            _ok = "";
            StateHasChanged();

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var principal = authState.User;

            var appUser = await UserManager.GetUserAsync(principal);
            if (appUser is null)
                return;

            _userName = appUser.UserName ?? appUser.Email ?? "Player";

            await using var db = await DbFactory.CreateDbContextAsync();
            _player = await db.Players.AsNoTracking()
                .FirstOrDefaultAsync(p => p.UserId == appUser.Id);

            if (_player is null)
                return;

            _selectedCountry = _player.CountryCode ?? "";
            RecomputeRules();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            _gate.Release();
            StateHasChanged();
        }
    }

    private void RecomputeRules()
    {
        if (_player is null) return;

        var now = DateTime.UtcNow;

        if (string.IsNullOrWhiteSpace(_player.CountryCode) || _player.CountryChangedUtc is null)
            _canChange = true;
        else
            _canChange = (now - _player.CountryChangedUtc.Value).TotalDays >= 7;

        _costSoft = _player.CountryChangeCount <= 0 ? 0 : 1000 * (long)Math.Pow(2, _player.CountryChangeCount - 1);
    }

    private static bool IsValidIso2(string? code)
        => !string.IsNullOrWhiteSpace(code)
           && code.Length == 2
           && code.All(char.IsLetter);

    private async Task SaveCountryAsync()
    {
        await _gate.WaitAsync();
        try
        {
            _loading = true;
            _error = "";
            _ok = "";
            StateHasChanged();

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var principal = authState.User;

            var appUser = await UserManager.GetUserAsync(principal);
            if (appUser is null)
                return;

            var newCode = (_selectedCountry ?? "").Trim().ToUpperInvariant();

            if (!string.IsNullOrWhiteSpace(newCode) && !IsValidIso2(newCode))
            {
                _error = "Invalid ISO2 code.";
                return;
            }

            await using var db = await DbFactory.CreateDbContextAsync();

            var player = await db.Players
                .FirstOrDefaultAsync(p => p.UserId == appUser.Id);

            if (player is null)
            {
                _error = "No player profile found.";
                return;
            }

            var now = DateTime.UtcNow;

            bool canChange;
            if (string.IsNullOrWhiteSpace(player.CountryCode) || player.CountryChangedUtc is null)
                canChange = true;
            else
                canChange = (now - player.CountryChangedUtc.Value).TotalDays >= 7;

            if (!canChange)
            {
                _error = "Country change is on cooldown.";
                return;
            }

            long costSoft = player.CountryChangeCount <= 0
                ? 0
                : 1000 * (long)Math.Pow(2, player.CountryChangeCount - 1);

            if (costSoft > 0 && player.SoftCurrency < costSoft)
            {
                _error = "Not enough currency to change country.";
                return;
            }

            if (costSoft > 0)
                player.SoftCurrency -= costSoft;

            player.CountryCode = string.IsNullOrWhiteSpace(newCode) ? null : newCode;
            player.CountryChangedUtc = now;
            player.CountryChangeCount += 1;

            await db.SaveChangesAsync();

            _ok = "Country updated.";

            _player = player;
            _selectedCountry = player.CountryCode ?? "";
            RecomputeRules();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            _gate.Release();
            StateHasChanged();
        }
    }
}
