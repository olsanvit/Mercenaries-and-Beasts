@page "/expeditions"
@using System.Globalization
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore

@using MercenariesAndBeasts.Infrastructure
@using MercenariesAndBeasts.Domain.Players
@using MercenariesAndBeasts.Domain.Progress
@using MercenariesAndBeasts.Domain.Localization

@inject IDbContextFactory<GameDbContext> DbFactory
@inject UserManager<AppUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider

@attribute [Authorize]
@rendermode InteractiveServer

<h1>@S["Locations"]</h1>

@if (isLoading)
{
    <p>Loading…</p>
}
else if (player is null)
{
    <p class="text-danger">No player profile found.</p>
}
else
{
    <div class="dng-fight-layout">

        <!-- ================= TOP 80% ================= -->
        <div class="dng-fight-top">
            <div class="dng-fight-top-grid">

                <!-- LEFT: list -->
                <div class="card-like dng-panel">
                    <div class="dng-panel-head">
                        <h3 class="m-0">Available expeditions</h3>
                        <p class="text-muted mb-0 small">Last 5 unlocked + next 2 locked.</p>
                    </div>

                    <div class="dng-panel-body panel-scroll">
                        <ul class="list-group list-group-flush">
                            @foreach (var row in leftList)
                            {
                                var isSelected = row.Location?.Id == selectedLocationId;
                                var isLocked = row.IsLocked;

                                <li class="list-group-item bg-transparent text-light"
                                    style="opacity:@(isLocked ? "0.45" : "1");">
                                    <div class="d-flex justify-content-between align-items-center gap-2">
                                        <div style="min-width:0;">
                                            <strong class="text-truncate d-block">@row.Title</strong>
                                            <div class="text-muted small">@row.Subtitle</div>

                                            @if (!isLocked && row.Progress is null)
                                            {
                                                <span class="badge bg-secondary mt-1">Not started</span>
                                            }
                                            else if (!isLocked && row.Progress?.IsCompleted == true)
                                            {
                                                <span class="badge bg-success mt-1">Completed</span>
                                            }
                                            else if (!isLocked && row.Progress is not null)
                                            {
                                                <span class="badge bg-warning text-dark mt-1">
                                                    Stage @row.Progress.MaxStageReached / 10
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-dark mt-1">Locked</span>
                                            }
                                        </div>

                                        <button class="btn btn-sm @(isSelected ? "btn-primary" : "btn-outline-secondary")"
                                                disabled="@isLocked"
                                                @onclick="() => SelectLocation(row.Location!.Id)">
                                            @(isSelected ? "Selected" : "Open")
                                        </button>
                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                </div>

                <!-- RIGHT: detail -->
                <div class="card-like dng-panel">

                    <div class="dng-panel-head">
                        @if (selectedLocation is null)
                        {
                            <h3 class="m-0">Expedition</h3>
                            <p class="text-muted m-0 small">Pick a location on the left.</p>
                        }
                        else
                        {
                            <h3 class="m-0">@LocName(selectedLocation)</h3>
                            <div class="text-muted small">
                                Recommended level @selectedLocation.MinLevel–@selectedLocation.MaxLevel
                            </div>
                        }
                    </div>

                    <div class="dng-panel-body panel-scroll">
                        @if (selectedLocation is null)
                        {
                            <div class="text-muted">—</div>
                        }
                        else
                        {
                            <div class="mt-2">
                                @if (selectedProgress is null)
                                {
                                    <span class="badge bg-secondary">Not started</span>
                                }
                                else if (selectedProgress.IsCompleted)
                                {
                                    <span class="badge bg-success">Completed</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">In progress</span>
                                }
                            </div>

                            <hr />

                            <h5>Enemies (3 Orders)</h5>

                            @if (encounters.Count == 0)
                            {
                                <div class="text-muted">No encounters rolled.</div>
                            }
                            else
                            {
                                <div class="d-flex flex-column gap-2">
                                    @foreach (var e in encounters)
                                    {
                                        <div class="p-3 border rounded d-flex justify-content-between align-items-center">
                                            <div style="min-width:0;">
                                                <div class="text-truncate"><b>@e.Name</b></div>
                                                <div class="text-muted small">Slot @e.SlotIndex</div>
                                            </div>

                                            <a class="btn btn-primary btn-sm"
                                               href="@($"/expeditions/{selectedLocation.Id}/fight/{e.SlotIndex}")">
                                                Attack
                                            </a>
                                        </div>
                                    }
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(LocDesc(selectedLocation)))
                            {
                                <hr />
                                <div class="text-muted">@LocDesc(selectedLocation)</div>
                            }
                        }
                    </div>

                </div>
            </div>
        </div>

        <!-- ================= BOTTOM 20% ================= -->
        <div class="dng-fight-bottom">
            <div class="card-like dng-panel">
                <div class="dng-panel-head">
                    <div class="fw-bold">Achievements</div>
                    <div class="text-muted small">
                        @(selectedLocation is null ? "Pick a location above." : $"For: {LocName(selectedLocation)}")
                    </div>
                </div>

                <div class="dng-panel-body panel-scroll">
                    @if (selectedLocation is null)
                    {
                        <div class="text-muted">—</div>
                    }
                    else if (locationAchievements.Count == 0)
                    {
                        <div class="text-muted">No achievements for this location.</div>
                    }
                    else
                    {
                        @foreach (var a in locationAchievements)
                        {
                            <div class="ach-row">
                                <div class="ach-title">@a.Title</div>

                                @if (!string.IsNullOrWhiteSpace(a.Description))
                                {
                                    <div class="ach-meta text-muted small">@a.Description</div>
                                }

                                @if (!string.IsNullOrWhiteSpace(a.RewardText))
                                {
                                    <div class="ach-meta text-muted small"><b>Reward:</b> @a.RewardText</div>
                                }

                                @if (a.IsCompleted)
                                {
                                    <span class="badge bg-success mt-2">Completed</span>
                                }
                                else if (a.IsLocked)
                                {
                                    <span class="badge bg-dark mt-2">Locked</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark mt-2">In progress</span>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

    </div>
}

@code {
    private bool isLoading = true;
    private PlayerProfile? player;

    private List<Location> unlocked = new();
    private List<PlayerExpeditionProgress> progress = new();

    private Guid? selectedLocationId;
    private Location? selectedLocation;
    private PlayerExpeditionProgress? selectedProgress;

    private List<EncounterVm> encounters = new();

    // Orders pool (MercenaryTemplate)
    private List<MercenaryTemplate> allOrders = new();
    private Dictionary<Guid, MercenaryTemplate> _orderById = new();

    private List<LeftLocationRow> leftList = new();

    private sealed class LeftLocationRow
    {
        public Location? Location { get; set; }
        public PlayerExpeditionProgress? Progress { get; set; }
        public bool IsLocked { get; set; }
        public string Title { get; set; } = "";
        public string Subtitle { get; set; } = "";
    }

    private sealed class EncounterVm
    {
        public int SlotIndex { get; set; }
        public Guid TemplateId { get; set; }
        public string Name { get; set; } = "";
    }

    // ===== Achievements VM =====
    private List<LocationAchievementVm> locationAchievements = new();

    private sealed record LocationAchievementVm(
        string Title,
        string? Description,
        string? RewardText,
        bool IsCompleted,
        bool IsLocked
    );

    // ===== Localization cache (fast lookup) =====
    private readonly Dictionary<(string, Guid, string), LocalizedText> _locByKey = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && selectedLocationId.HasValue)
        {
            await SelectLocation(selectedLocationId.Value);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;

        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = await UserManager.GetUserAsync(auth.User);
            if (user is null) return;

            await using var db = await DbFactory.CreateDbContextAsync();

            player = await db.Players.FirstOrDefaultAsync(p => p.UserId == user.Id);
            if (player is null) return;

            progress = await db.PlayerExpeditionProgresses
                .Where(p => p.PlayerId == player.Id)
                .ToListAsync();

            var allLocations = await db.Locations
                .OrderBy(l => l.UnlockOrder)
                .ToListAsync();

            allOrders = await db.MercenaryTemplates
                .OrderBy(x => x.BaseLevel).ThenBy(x => x.Code)
                .ToListAsync();

            _orderById = allOrders.ToDictionary(x => x.Id, x => x);

            // unlock rule: max completed + 1
            var maxCompleted = progress
                .Where(p => p.IsCompleted)
                .Join(allLocations, p => p.LocationId, l => l.Id, (p, l) => l.UnlockOrder)
                .DefaultIfEmpty(0)
                .Max();

            var maxUnlockedOrder = maxCompleted + 1;

            unlocked = allLocations
                .Where(l => l.UnlockOrder <= maxUnlockedOrder)
                .OrderBy(l => l.UnlockOrder)
                .ToList();

            var last5 = unlocked.TakeLast(5).ToList();

            var nextLocked = allLocations
                .Where(l => l.UnlockOrder > maxUnlockedOrder)
                .OrderBy(l => l.UnlockOrder)
                .Take(2)
                .ToList();

            // preload localization pro left list (Location)
            var leftIds = last5.Concat(nextLocked).Select(x => x.Id).Distinct().ToList();
            await LoadLocalizationsAsync(db, nameof(Location), leftIds);

            leftList = new();

            foreach (var l in last5)
            {
                var pr = progress.FirstOrDefault(p => p.LocationId == l.Id);

                leftList.Add(new LeftLocationRow
                {
                    Location = l,
                    Progress = pr,
                    IsLocked = false,
                    Title = LocName(l),
                    Subtitle = $"Recommended level {l.MinLevel}–{l.MaxLevel}"
                });
            }

            foreach (var l in nextLocked)
            {
                leftList.Add(new LeftLocationRow
                {
                    Location = l,
                    Progress = null,
                    IsLocked = true,
                    Title = LocName(l),
                    Subtitle = "Locked"
                });
            }

            var first = last5.FirstOrDefault();
            selectedLocationId = first?.Id;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SelectLocation(Guid id)
    {
        selectedLocationId = id;

        await using var db = await DbFactory.CreateDbContextAsync();

        selectedLocation =
            unlocked.FirstOrDefault(l => l.Id == id)
            ?? await db.Locations.FirstOrDefaultAsync(l => l.Id == id);

        if (selectedLocation is null)
        {
            encounters = new();
            locationAchievements = new();
            return;
        }

        // ensure loc localization
        await LoadLocalizationsAsync(db, nameof(Location), new List<Guid> { selectedLocation.Id });

        // tracked progress
        var pr = await db.PlayerExpeditionProgresses
            .FirstOrDefaultAsync(p => p.PlayerId == player!.Id && p.LocationId == id);

        if (pr is null)
        {
            pr = new PlayerExpeditionProgress
            {
                Id = Guid.NewGuid(),
                PlayerId = player!.Id,
                LocationId = selectedLocation.Id,
                IsCompleted = false,
                LastUpdatedUtc = DateTime.UtcNow
            };

            db.PlayerExpeditionProgresses.Add(pr);
            await db.SaveChangesAsync();

            progress.Add(pr);
        }

        selectedProgress = pr;

        // ensure 3 encounters exist
        await EnsureEncountersAsync(db, pr);

        // preload localization for selected orders
        var orderIds = new[]
        {
            pr.EncounterOrder1TemplateId,
            pr.EncounterOrder2TemplateId,
            pr.EncounterOrder3TemplateId
        }
        .Where(x => x.HasValue)
        .Select(x => x!.Value)
        .Distinct()
        .ToList();

        await LoadLocalizationsAsync(db, nameof(MercenaryTemplate), orderIds);

        // build UI VMs
        encounters = new();
        AddEncounterVm(1, pr.EncounterOrder1TemplateId);
        AddEncounterVm(2, pr.EncounterOrder2TemplateId);
        AddEncounterVm(3, pr.EncounterOrder3TemplateId);

        // achievements for location
        locationAchievements = BuildLocationAchievementVms(pr.Achievements);

        StateHasChanged();
        // baseTier – klidně dle lokace (min level / unlock order / cokoliv)
var baseTier = Math.Clamp((selectedLocation.MinLevel / 5) + 1, 1, 10);

// progress + achievements (tracked, vytvoří pokud chybí)
var pr1 = await GetOrCreateExpeditionProgressWithAchievementsAsync(db, player!.Id, selectedLocation.Id, baseTier);
selectedProgress = pr;
    }

    private void AddEncounterVm(int slot, Guid? templateId)
    {
        if (!templateId.HasValue) return;

        encounters.Add(new EncounterVm
        {
            SlotIndex = slot,
            TemplateId = templateId.Value,
            Name = OrderName(templateId.Value)
        });
    }
private sealed record ExpAchTemplate(
    string Code,
    string Title,
    string Description,
    Func<int, int> RequiredByTier,
    string RewardText
);

// TODO: doplň na 22 položek (ukázka pár kusů)
private static readonly List<ExpAchTemplate> ExpeditionAchPool = new()
{
    new("Kills", "Defeat enemies", "Defeat enemies in this expedition.", tier => 5 + tier * 3, "+ Supplies"),
    new("WinStreak", "Win streak", "Win consecutive fights without losing.", tier => 2 + (tier / 2), "+ Rare token"),
    new("NoLoss", "Flawless run", "Win without losing any fight.", tier => 1, "+ Bonus chest"),
    new("OrdersBeaten", "Defeat all 3 Orders", "Defeat all 3 encounter slots.", tier => 3, "+ Contract"),
    // ... doplň až do 22
};
private List<PlayerExpeditionAchievement> GenerateFiveExpeditionAchievements(
    Guid progressId,
    int baseTier)
{
    var rng = new Random(progressId.GetHashCode());

    var picked = ExpeditionAchPool
        .OrderBy(_ => rng.Next())
        .Take(5)
        .ToList();

    var list = new List<PlayerExpeditionAchievement>(5);

    foreach (var t in picked)
    {
        // random bump náročnosti
        var tier = Math.Clamp(baseTier + rng.Next(0, 4), 1, 10);
        var required = t.RequiredByTier(tier);

        list.Add(new PlayerExpeditionAchievement
        {
            Id = Guid.NewGuid(),
            ProgressId = progressId,
            Code = t.Code,
            DifficultyTier = tier,
            Required = required,
            Current = 0,
            IsCompleted = false
        });
    }

    return list;
}private async Task<PlayerExpeditionProgress> GetOrCreateExpeditionProgressWithAchievementsAsync(
    GameDbContext db,
    Guid playerId,
    Guid locationId,
    int baseTier)
{
    var pr = await db.PlayerExpeditionProgresses
        .Include(p => p.Achievements)
        .FirstOrDefaultAsync(p => p.PlayerId == playerId && p.LocationId == locationId);

    if (pr is null)
    {
        pr = new PlayerExpeditionProgress
        {
            Id = Guid.NewGuid(),
            PlayerId = playerId,
            LocationId = locationId,
            IsCompleted = false,
            LastUpdatedUtc = DateTime.UtcNow
        };

        db.PlayerExpeditionProgresses.Add(pr);
        await db.SaveChangesAsync();

        // update local cache list (aby levý panel hned ukázal progress)
        progress.Add(pr);
    }

    // musí být přesně 5
    if (pr.Achievements.Count != 5)
    {
        if (pr.Achievements.Count > 0)
            db.RemoveRange(pr.Achievements);

        var rows = GenerateFiveExpeditionAchievements(pr.Id, baseTier);

        foreach (var a in rows)
            pr.Achievements.Add(a);

        await db.SaveChangesAsync();
    }

    return pr;
}
private List<LocationAchievementVm> BuildLocationAchievementVms(
    IEnumerable<PlayerExpeditionAchievement> achievements)
{
    var defByCode = ExpeditionAchPool.ToDictionary(x => x.Code, x => x);

    return achievements.Select(a =>
    {
        defByCode.TryGetValue(a.Code, out var def);

        var title = def?.Title ?? a.Code;
        var desc = def?.Description ?? "";
        var reward = def?.RewardText ?? "";

        // (volitelně) pokud chceš vidět i progress v UI, rozšiř VM o ProgressText
        var decoratedDesc = $"{desc} (Tier {a.DifficultyTier})";

        return new LocationAchievementVm(
            Title: title,
            Description: decoratedDesc,
            RewardText: reward,
            IsCompleted: a.IsCompleted,
            IsLocked: false
        );
    }).ToList();
}
    private async Task EnsureEncountersAsync(GameDbContext db, PlayerExpeditionProgress pr)
    {
        if (pr.EncounterOrder1TemplateId.HasValue &&
            pr.EncounterOrder2TemplateId.HasValue &&
            pr.EncounterOrder3TemplateId.HasValue)
            return;

        if (allOrders.Count < 3)
            throw new InvalidOperationException("Need at least 3 Orders in MercenaryTemplates.");

        var seed = HashCode.Combine(player!.Id, pr.LocationId);
        var rng = new Random(seed);

        var picks = allOrders
            .OrderBy(_ => rng.Next())
            .Take(3)
            .Select(x => x.Id)
            .ToList();

        pr.EncounterOrder1TemplateId = picks[0];
        pr.EncounterOrder2TemplateId = picks[1];
        pr.EncounterOrder3TemplateId = picks[2];
        pr.EncounterRolledUtc = DateTime.UtcNow;
        pr.LastUpdatedUtc = DateTime.UtcNow;

        await db.SaveChangesAsync();
    }

    // ===========================
    // Achievements loader (ADAPT TO YOUR MODEL)
    // ===========================
    private async Task<List<LocationAchievementVm>> LoadLocationAchievementsAsync(GameDbContext db, Guid locationId)
    {
        // TODO: napoj na svůj model
        // Příklad:
        //
        // var rows = await db.LocationAchievements
        //     .Where(x => x.LocationId == locationId)
        //     .OrderBy(x => x.SortOrder)
        //     .AsNoTracking()
        //     .ToListAsync();
        //
        // return rows.Select(x => new LocationAchievementVm(
        //     Title: x.Title,
        //     Description: x.Description,
        //     RewardText: x.RewardText,
        //     IsCompleted: ...,
        //     IsLocked: ...
        // )).ToList();

        return new List<LocationAchievementVm>();
    }

    // ===========================
    // Localization (fast cache)
    // ===========================
    private async Task LoadLocalizationsAsync(GameDbContext db, string entityType, List<Guid> entityIds)
    {
        if (entityIds.Count == 0) return;

        var locs = await db.LocalizedTexts
            .Where(x => x.EntityType == entityType && entityIds.Contains(x.EntityId))
            .ToListAsync();

        foreach (var l in locs)
            _locByKey[(l.EntityType, l.EntityId, l.Culture)] = l;
    }

    private string LocName(Location loc)
        => Localize(nameof(Location), loc.Id, field: "Name", fallback: loc.NameEn);

    private string LocDesc(Location loc)
        => Localize(nameof(Location), loc.Id, field: "Description", fallback: loc.DescriptionEn ?? "");

    private string OrderName(Guid templateId)
    {
        var fallback = _orderById.TryGetValue(templateId, out var mt)
            ? (mt.NameEn ?? "Unknown Order")
            : "Unknown Order";

        return Localize(nameof(MercenaryTemplate), templateId, field: "Name", fallback: fallback);
    }

    private string Localize(string entityType, Guid entityId, string field, string fallback)
    {
        var culture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;

        if (!_locByKey.TryGetValue((entityType, entityId, culture), out var loc) || loc is null)
            return fallback;

        string? text = field switch
        {
            "Name" => loc.Name,
            "Description" => loc.Description,
            _ => null
        };

        return string.IsNullOrWhiteSpace(text) ? fallback : text!;
    }
}