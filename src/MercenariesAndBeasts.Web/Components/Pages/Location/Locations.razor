@page "/expeditions"
@using System.Globalization
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using MercenariesAndBeasts.Infrastructure
@using MercenariesAndBeasts.Domain
@using MercenariesAndBeasts.Domain.Players
@using MercenariesAndBeasts.Domain.Progress

@inject IDbContextFactory<AppDbContextMercenariesAndBeasts> DbFactory
@inject UserManager<AppUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider

@attribute [Authorize]
@rendermode InteractiveServer

@if (isLoading)
{
    <div class="card-like d-flex align-items-center gap-2 text-muted">
        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
        <span>Loading…</span>
    </div>
}
else if (player is null)
{
    <div class="card-like">
        <div class="alert alert-danger mb-0">No player profile found.</div>
    </div>
}
else
{
    <div class="dng-fight-layout">

        <!-- ================= TOP 80% ================= -->
        <div class="dng-fight-top">
            <div class="dng-fight-top-grid">

                <!-- LEFT: list -->
                <div class="card-like dng-panel">
                    <div class="dng-panel-head">
                        <h3 class="m-0">Available locations</h3>
                        <p class="text-muted mb-0 small">Last 5 unlocked + next 2 locked.</p>
                    </div>

                    <div class="dng-panel-body panel-scroll">
                        <ul class="list-group list-group-flush">
                            @foreach (var row in leftList)
                            {
                                var isSelected = row.Location?.Guid == selectedLocationId;
                                var isLocked = row.IsLocked;

                                <li class="list-group-item bg-transparent text-light"
                                    style="opacity:@(isLocked ? "0.45" : "1");">
                                    <div class="d-flex justify-content-between align-items-center gap-2">
                                        <div style="min-width:0;">
                                            <strong class="text-truncate d-block">@row.Title</strong>
                                            <div class="text-muted small">@row.Subtitle</div>

                                            @if (!isLocked && row.Progress is null)
                                            {
                                                <span class="badge bg-secondary mt-1">Not started</span>
                                            }
                                            else if (!isLocked && row.Progress?.IsCompleted == true)
                                            {
                                                <span class="badge bg-success mt-1">Completed</span>
                                            }
                                            else if (!isLocked && row.Progress is not null)
                                            {
                                                <span class="badge bg-info text-dark mt-1">
                                                    @row.Progress.TotalWins W / @row.Progress.TotalLosses L
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-dark mt-1">Locked</span>
                                            }
                                        </div>

                                        <button class="btn btn-sm @(isSelected ? "btn-primary" : "btn-outline-secondary")"
                                                disabled="@isLocked"
                                                @onclick="() => SelectLocation(row.Location!.Guid)">
                                            @(isSelected ? "Selected" : "Open")
                                        </button>
                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                </div>

                <!-- RIGHT: detail -->
                <div class="card-like dng-panel">
                    <div class="dng-panel-head">
                        @if (selectedLocation is null)
                        {
                            <h3 class="m-0">Location</h3>
                            <p class="text-muted m-0 small">Pick a location on the left.</p>
                        }
                        else
                        {
                            <h3 class="m-0">@LocName(selectedLocation)</h3>
                            <div class="text-muted small">
                                Recommended level @selectedLocation.MinLevel–@selectedLocation.MaxLevel
                                · @selectedLocation.Element
                            </div>
                        }
                    </div>

                    <div class="dng-panel-body panel-scroll">
                        @if (selectedLocation is null)
                        {
                            <div class="text-muted">—</div>
                        }
                        else
                        {
                            <div class="mt-2">
                                @if (selectedProgress is null)
                                {
                                    <span class="badge bg-secondary">Not started</span>
                                }
                                else if (selectedProgress.IsCompleted)
                                {
                                    <span class="badge bg-success">Completed</span>
                                }
                                else
                                {
                                    <span class="badge bg-info text-dark">
                                        @selectedProgress.TotalWins W / @selectedProgress.TotalLosses L
                                    </span>
                                }
                            </div>

                            <hr />

                            <h5>Orders (3)</h5>
                            <p class="text-muted small mb-2">Select an order to fight it.</p>

                            @if (encounters.Count == 0)
                            {
                                <div class="text-muted">No encounters rolled yet.</div>
                            }
                            else
                            {
                                <div class="d-flex flex-column gap-2">
                                    @foreach (var e in encounters)
                                    {
                                        <div class="card-like d-flex justify-content-between align-items-center gap-3"
                                             style="background:rgba(255,255,255,0.04);padding:.75rem 1rem;">
                                            <div class="d-flex align-items-center gap-2" style="min-width:0;">
                                                @if (!string.IsNullOrWhiteSpace(e.ImagePath))
                                                {
                                                    <img src="@e.ImagePath"
                                                         style="width:40px;height:40px;object-fit:cover;border-radius:8px;flex-shrink:0;" />
                                                }
                                                else
                                                {
                                                    <div style="width:40px;height:40px;border-radius:8px;background:rgba(255,255,255,0.06);flex-shrink:0;"></div>
                                                }
                                                <div style="min-width:0;">
                                                    <div class="fw-bold text-truncate">@e.Name</div>
                                                    <div class="text-muted small">Lv @e.BaseLevel · @e.Element · Slot @e.SlotIndex</div>
                                                </div>
                                            </div>

                                            <a class="btn btn-primary btn-sm flex-shrink-0"
                                               href="@($"/expeditions/{selectedLocation.Guid}/fight/{e.SlotIndex}")">
                                                Fight
                                            </a>
                                        </div>
                                    }
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(LocDesc(selectedLocation)))
                            {
                                <hr />
                                <div class="text-muted small">@LocDesc(selectedLocation)</div>
                            }
                        }
                    </div>
                </div>

            </div>
        </div>

        <!-- ================= BOTTOM 20% ================= -->
        <div class="dng-fight-bottom">
            <div class="card-like dng-panel">
                <div class="dng-panel-head">
                    <div class="fw-bold">Achievements</div>
                    <div class="text-muted small">
                        @(selectedLocation is null ? "Pick a location above." : $"For: {LocName(selectedLocation)}")
                    </div>
                </div>

                <div class="dng-panel-body panel-scroll">
                    @if (selectedLocation is null)
                    {
                        <div class="text-muted">—</div>
                    }
                    else if (locationAchievements.Count == 0)
                    {
                        <div class="text-muted">No achievements defined for this location.</div>
                    }
                    else
                    {
                        @foreach (var a in locationAchievements)
                        {
                            <div class="ach-row">
                                <div class="ach-title">@a.Title</div>

                                @if (!string.IsNullOrWhiteSpace(a.Description))
                                {
                                    <div class="ach-meta text-muted small">@a.Description</div>
                                }

                                @if (a.IsCompleted)
                                {
                                    <span class="badge bg-success mt-2">Completed</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark mt-2">
                                        @a.Current / @a.Required
                                    </span>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

    </div>
}

@code {
    private bool isLoading = true;
    private PlayerProfile? player;

    private List<Location> _allLocations = new();
    private List<PlayerExpeditionProgress> progress = new();

    private Guid? selectedLocationId;
    private Location? selectedLocation;
    private PlayerExpeditionProgress? selectedProgress;

    private List<EncounterVm> encounters = new();
    private List<MercenaryTemplate> _allOrders = new();
    private Dictionary<Guid, MercenaryTemplate> _orderById = new();

    private List<LeftLocationRow> leftList = new();

    private sealed class LeftLocationRow
    {
        public Location? Location { get; set; }
        public PlayerExpeditionProgress? Progress { get; set; }
        public bool IsLocked { get; set; }
        public string Title { get; set; } = "";
        public string Subtitle { get; set; } = "";
    }

    private sealed class EncounterVm
    {
        public int SlotIndex { get; set; }
        public Guid TemplateId { get; set; }
        public string Name { get; set; } = "";
        public int BaseLevel { get; set; }
        public string Element { get; set; } = "";
        public string? ImagePath { get; set; }
    }

    private List<AchievementVm> locationAchievements = new();

    private sealed record AchievementVm(
        string Title,
        string? Description,
        bool IsCompleted,
        int Current,
        int Required
    );

    private readonly Dictionary<(string, Guid, string), LocalizedText> _locByKey = new();

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;

        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = await UserManager.GetUserAsync(auth.User);
            if (user is null) return;

            await using var db = await DbFactory.CreateDbContextAsync();

            player = await db.Players.FirstOrDefaultAsync(p => p.UserId == user.Id);
            if (player is null) return;

            progress = await db.PlayerExpeditionProgresses
                .Where(p => p.PlayerId == player.Guid)
                .ToListAsync();

            _allLocations = await db.Locations
                .OrderBy(l => l.UnlockOrder)
                .ToListAsync();

            _allOrders = await db.MercenaryTemplates
                .OrderBy(x => x.BaseLevel).ThenBy(x => x.Code)
                .ToListAsync();

            _orderById = _allOrders.ToDictionary(x => x.Guid);

            var maxCompleted = progress
                .Where(p => p.IsCompleted)
                .Join(_allLocations, p => p.LocationId, l => l.Guid, (p, l) => l.UnlockOrder)
                .DefaultIfEmpty(0)
                .Max();

            var maxUnlockedOrder = maxCompleted + 1;

            var unlocked = _allLocations
                .Where(l => l.UnlockOrder <= maxUnlockedOrder)
                .OrderBy(l => l.UnlockOrder)
                .ToList();

            var last5 = unlocked.TakeLast(5).ToList();

            var nextLocked = _allLocations
                .Where(l => l.UnlockOrder > maxUnlockedOrder)
                .OrderBy(l => l.UnlockOrder)
                .Take(2)
                .ToList();

            var leftIds = last5.Concat(nextLocked).Select(x => x.Guid).Distinct().ToList();
            await LoadLocalizationsAsync(db, nameof(Location), leftIds);

            leftList = new();

            foreach (var l in last5)
            {
                var pr = progress.FirstOrDefault(p => p.LocationId == l.Guid);
                leftList.Add(new LeftLocationRow
                {
                    Location = l,
                    Progress = pr,
                    IsLocked = false,
                    Title = LocName(l),
                    Subtitle = $"Recommended level {l.MinLevel}–{l.MaxLevel}"
                });
            }

            foreach (var l in nextLocked)
            {
                leftList.Add(new LeftLocationRow
                {
                    Location = l,
                    Progress = null,
                    IsLocked = true,
                    Title = LocName(l),
                    Subtitle = "Locked"
                });
            }

            var first = last5.FirstOrDefault();
            if (first is not null)
                await SelectLocationWithDb(db, first.Guid);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SelectLocation(Guid id)
    {
        selectedLocationId = id;
        await using var db = await DbFactory.CreateDbContextAsync();
        await SelectLocationWithDb(db, id);
    }

    private async Task SelectLocationWithDb(AppDbContextMercenariesAndBeasts db, Guid id)
    {
        selectedLocationId = id;

        selectedLocation = _allLocations.FirstOrDefault(l => l.Guid == id)
            ?? await db.Locations.FirstOrDefaultAsync(l => l.Guid == id);

        if (selectedLocation is null)
        {
            encounters = new();
            locationAchievements = new();
            StateHasChanged();
            return;
        }

        await LoadLocalizationsAsync(db, nameof(Location), new List<Guid> { id });

        var pr = await GetOrCreateProgressAsync(db, player!.Guid, id);
        selectedProgress = pr;

        // Ensure 3 orders are rolled and persisted
        await EnsureEncountersAsync(db, pr);

        // Build encounter VMs for slots 1–3
        var orderIds = new[] { pr.EncounterOrder1TemplateId, pr.EncounterOrder2TemplateId, pr.EncounterOrder3TemplateId }
            .Where(x => x.HasValue).Select(x => x!.Value).Distinct().ToList();

        await LoadLocalizationsAsync(db, nameof(MercenaryTemplate), orderIds);

        encounters = new();
        AddEncounterVm(1, pr.EncounterOrder1TemplateId);
        AddEncounterVm(2, pr.EncounterOrder2TemplateId);
        AddEncounterVm(3, pr.EncounterOrder3TemplateId);

        locationAchievements = BuildAchievementVms(pr.Achievements);

        StateHasChanged();
    }

    private async Task<PlayerExpeditionProgress> GetOrCreateProgressAsync(
        AppDbContextMercenariesAndBeasts db,
        Guid playerId,
        Guid locationId)
    {
        var pr = await db.PlayerExpeditionProgresses
            .Include(p => p.Achievements)
                .ThenInclude(a => a.Achievement)
            .FirstOrDefaultAsync(p => p.PlayerId == playerId && p.LocationId == locationId);

        if (pr is null)
        {
            pr = new PlayerExpeditionProgress
            {
PlayerId = playerId,
                LocationId = locationId,
                IsCompleted = false,
                LastUpdatedUtc = DateTime.UtcNow
            };
            db.PlayerExpeditionProgresses.Add(pr);
            await db.SaveChangesAsync();
            progress.Add(pr); // update local list
        }

        // Seed achievements from DB definitions if none yet
        if (pr.Achievements.Count == 0)
        {
            var defs = await db.ExpeditionAchievements
                .Where(d => d.LocationId == locationId)
                .OrderBy(d => d.Index)
                .Take(5)
                .ToListAsync();

            if (defs.Count > 0)
            {
                var baseTier = Math.Clamp((selectedLocation!.MinLevel / 5) + 1, 1, 10);
                var rng = new Random(pr.Guid.GetHashCode());

                foreach (var def in defs)
                {
                    var tier = Math.Clamp(baseTier + rng.Next(0, 3), 1, 10);
                    pr.Achievements.Add(new PlayerExpeditionAchievement
                    {
ProgressId = pr.Guid,
                        PlayerId = playerId,
                        AchievementId = def.Guid,
                        Code = def.Code,
                        DifficultyTier = tier,
                        Required = 1 + tier,
                        Current = 0,
                        IsCompleted = false
                    });
                }
                await db.SaveChangesAsync();
            }
        }

        return pr;
    }

    private async Task EnsureEncountersAsync(AppDbContextMercenariesAndBeasts db, PlayerExpeditionProgress pr)
    {
        if (pr.EncounterOrder1TemplateId.HasValue &&
            pr.EncounterOrder2TemplateId.HasValue &&
            pr.EncounterOrder3TemplateId.HasValue)
            return;

        if (_allOrders.Count < 3)
            return; // not enough orders seeded yet

        var seed = HashCode.Combine(player!.Guid, pr.LocationId);
        var rng = new Random(seed);

        var picks = _allOrders.OrderBy(_ => rng.Next()).Take(3).ToList();

        pr.EncounterOrder1TemplateId ??= picks[0].Guid;
        pr.EncounterOrder2TemplateId ??= picks[1].Guid;
        pr.EncounterOrder3TemplateId ??= picks[2].Guid;
        pr.EncounterRolledUtc = DateTime.UtcNow;
        pr.LastUpdatedUtc = DateTime.UtcNow;

        await db.SaveChangesAsync();
    }

    private void AddEncounterVm(int slot, Guid? templateId)
    {
        if (!templateId.HasValue) return;

        _orderById.TryGetValue(templateId.Value, out var mt);
        if (mt is null) return;

        encounters.Add(new EncounterVm
        {
            SlotIndex = slot,
            TemplateId = templateId.Value,
            Name = OrderName(templateId.Value),
            BaseLevel = mt.BaseLevel,
            Element = mt.Element.ToString(),
            ImagePath = mt.ImagePath
        });
    }

    private List<AchievementVm> BuildAchievementVms(IEnumerable<PlayerExpeditionAchievement> achievements)
    {
        return achievements.Select(a => new AchievementVm(
            Title: a.Achievement?.NameEn is { Length: > 0 } n ? n : a.Code,
            Description: a.Achievement?.DescriptionEn is { Length: > 0 } d
                ? $"{d} (Tier {a.DifficultyTier})"
                : $"Tier {a.DifficultyTier}",
            IsCompleted: a.IsCompleted,
            Current: a.Current,
            Required: a.Required
        )).ToList();
    }

    // ===== Localization helpers =====

    private async Task LoadLocalizationsAsync(AppDbContextMercenariesAndBeasts db, string entityType, List<Guid> ids)
    {
        if (ids.Count == 0) return;
        var locs = await db.LocalizedTexts
            .Where(x => x.EntityType == entityType && ids.Contains(x.EntityId))
            .ToListAsync();
        foreach (var l in locs)
            _locByKey[(l.EntityType, l.EntityId, l.Culture)] = l;
    }

    private string LocName(Location loc)   => Localize(nameof(Location),          loc.Guid,        "Name",        loc.NameEn);
    private string LocDesc(Location loc)   => Localize(nameof(Location),          loc.Guid,        "Description", loc.DescriptionEn ?? "");
    private string OrderName(Guid id)
    {
        var fallback = _orderById.TryGetValue(id, out var mt) ? (mt.NameEn ?? "Unknown Order") : "Unknown Order";
        return Localize(nameof(MercenaryTemplate), id, "Name", fallback);
    }

    private string Localize(string entityType, Guid entityId, string field, string fallback)
    {
        var culture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
        if (!_locByKey.TryGetValue((entityType, entityId, culture), out var loc))
            return fallback;
        var text = field == "Name" ? loc.Name : field == "Description" ? loc.Description : null;
        return string.IsNullOrWhiteSpace(text) ? fallback : text!;
    }
}
