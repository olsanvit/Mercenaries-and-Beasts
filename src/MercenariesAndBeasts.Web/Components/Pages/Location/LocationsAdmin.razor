@page "/locations-admin"
@using System.Globalization
@using MercenariesAndBeasts.Domain.Utils
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

<h1>@S["Locations"]</h1>
<ImagePreviewer @ref="imagePreviewer" />

@if (isLoading)
{
    <p>Loading...</p>
}
else
{
    <div class="mb-3">
        <button class="btn btn-primary" @onclick="NewLocation">@S["NewLocation"]</button>
        <button class="btn btn-secondary" @onclick="() =>GenerateNextLocation(false)">
            @S["AiGenLocation"]
        </button>
        <div class="input-group">
        <input class="form-control dungeon-input"
       @bind="manualLocationName"
       placeholder="Enter location name…" />

        <button class="btn btn-primary"
                disabled="@IsManualGenerateDisabled"
                @onclick="async () => await GenerateNextLocation(true)">
            Generate Location (Manual)
        </button>
    </div>

    </div>
    @if (!locations.Any())
    {
        <p>No locations yet.</p>
    }
    else
    {
        <div class="dungeons-table-wrap">
    <table class="table table-dark table-stages">
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Element</th>
                    <th>Unlock Order</th>
                    <th>Level range</th>
        <th>Stages</th> @* nový sloupec *@
        <th>Image</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var loc in locations)
            {
                <tr>
                        <td title="@loc.Code">@loc.Code</td>
                        <td title="@LocalizationExtensions.NameForCurrentCulture(loc)" class="location-name ellipsis">@LocalizationExtensions.NameForCurrentCulture(loc)</td>
                        <td>@loc.Element</td>
                        <td>@loc.UnlockOrder</td>
                    <td>@loc.MinLevel - @loc.MaxLevel</td> <td>
            @(loc.Stages?.Count ?? 0)
            <button class="btn btn-sm btn-outline-info ms-2"
                    @onclick="() => ToggleDungeonStages(loc.Id)">
                @(expandedLocationIds.Contains(loc.Id) ? "Hide" : "Show")
            </button>
        </td>
         <td>
        @if (!string.IsNullOrEmpty(loc.ImagePath))
        {
            <img src="@loc.ImagePath"
                 alt="@loc.NameEn"
                 class="location-thumb me-2"
                 @onclick="() => ShowImage(loc.ImagePath!)" />
        }

        <button class="btn btn-sm btn-outline-info"
                disabled="@IsGeneratingImageFor(loc.Id)"
                @onclick="() => GenerateImageForLocation(loc)">
            @if (IsGeneratingImageFor(loc.Id))
            {
                <span>Generating…</span>
            }
            else
            {
                <span>Generate image</span>
            }
        </button>
    </td>
                    <td>
                        <button class="btn btn-sm btn-secondary me-1" @onclick="() => EditLocation(loc)">Edit</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteLocation(loc.Id)">Delete</button>
                    </td>
                </tr>
                @if (expandedLocationIds.Contains(loc.Id))
    {
                    <tr class="table-secondary dungeon-detail-row">
            <td colspan="8">
                        <td class="location-name">@LocalizationExtensions.DescriptionForCurrentCulture(loc)</td>
                @if (loc.Stages == null || loc.Stages.Count == 0)
                {
                    <em>No stages defined.</em>
                }
                else
                {
                    <div class="accordion" id="acc-@loc.Id">
                        <div class="accordion-item bg-dark text-light">
                            <h2 class="accordion-header" id="heading-@loc.Id">
                                <button class="accordion-button collapsed"
                                        type="button"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#collapse-@loc.Id"
                                        aria-expanded="false"
                                        aria-controls="collapse-@loc.Id">
                                    Stages &amp; monsters
                                </button>
                            </h2>
                            <div id="collapse-@loc.Id"
                                 class="accordion-collapse collapse show"
                                 aria-labelledby="heading-@loc.Id">
                                <div class="accordion-body">
                                    <table class="table table-sm table-dark mb-0 table-stages">
    <thead>
        <tr>
            <th class="num">#</th>
            <th class="stage-type">Stage type</th>
            <th class="wrap">Monster</th>
            <th class="num">Level</th>
            <th class="wrap">Element</th>
            <th class="num">HP</th>
            <th class="num">Attack</th>
            <th class="num">Defense</th>
            <th class="num">Speed</th>
            <th class="num">CritChance</th>
            <th class="num">CritMultiplier</th>
            <th class="num">ElementalDamageBonus</th>
            <th class="num">ElementalResistance</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in loc.Stages.OrderBy(s => s.StageNumber))
        {
            <tr>
                <td class="num">@s.StageNumber</td>
                <td class="stage-type">@s.Difficulty</td>

                <td class="wrap"
                    title="@LocalizationExtensions.NameForCurrentCulture(s.Enemy)">
                    @LocalizationExtensions.NameForCurrentCulture(s.Enemy)
                </td>

                <td class="num">@s.Enemy?.BaseLevel</td>
                <td class="wrap">@s.Enemy?.Element</td>

                <td class="num">@s.Enemy?.BaseStats?.MaxHp</td>
                <td class="num">@s.Enemy?.BaseStats?.Attack</td>
                <td class="num">@s.Enemy?.BaseStats?.Defense</td>
                <td class="num">@s.Enemy?.BaseStats?.Speed</td>
                <td class="num">@s.Enemy?.BaseStats?.CritChance</td>
                <td class="num">@s.Enemy?.BaseStats?.CritMultiplier</td>
                <td class="num">@s.Enemy?.BaseStats?.ElementalDamageBonus</td>
                <td class="num">@s.Enemy?.BaseStats?.ElementalResistance</td>
            </tr>
        }
    </tbody>
</table>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </td>
        </tr>
    }
            }
            </tbody>
        </table>
    </div>
    }
}

@if (editModel is not null)
{
    <hr />
    <h2>@(editModel.Id == Guid.Empty ? "Create location" : "Edit location")</h2>

    <EditForm Model="@editModel" OnValidSubmit="Save">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-2">
            <label class="form-label">Code</label>
            <InputText class="form-control" @bind-Value="editModel.Code" />
        </div>

        <div class="mb-2">
            <label class="form-label">Name (EN)</label>
            <InputText class="form-control" @bind-Value="editModel.NameEn" />
        </div>

        <div class="mb-2">
            <label class="form-label">Min level</label>
            <InputNumber class="form-control" @bind-Value="editModel.MinLevel" />
        </div>

        <div class="mb-3">
            <label class="form-label">Max level</label>
            <InputNumber class="form-control" @bind-Value="editModel.MaxLevel" />
        </div>

        <button type="submit" class="btn btn-success me-2">Save</button>
        <button type="button" class="btn btn-outline-secondary" @onclick="CancelEdit">Cancel</button>
    </EditForm>
}

@code {
    private bool isLoading = true;
    private List<Location> locations = new();
    private Location? editModel;
    private string manualLocationName = string.Empty;
    private bool IsManualGenerateDisabled =>
        isLoading || string.IsNullOrWhiteSpace(manualLocationName);

    protected override async Task OnInitializedAsync()
    {
        await LoadLocations();
    }

    private async Task LoadLocations()
    {
        isLoading = true;

        try
        {
            locations = await Db.Locations
                .Include(x => x.Stages).ThenInclude(x => x.Enemy)
                .OrderBy(l => l.MinLevel)
                .ThenBy(l => l.Code)
                .ToListAsync();

            // přeložení názvů (bez pádu stránky při chybě)
            await EnsureLocalizationAsync();

            Toasts.Success("Locations loaded", $"Loaded {locations.Count} locations.");
        }
        catch (Exception ex)
        {
            Toasts.Error("Failed to load locations", ex.Message);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void NewLocation()
    {
        editModel = new Location
        {
            MinLevel = 1,
            MaxLevel = 5
        };
    }

    private void EditLocation(Location loc)
    {
        // kopie, ať nehýbeš rovnou trackovaným
        editModel = new Location
        {
            Id = loc.Id,
            Code = loc.Code,
            NameEn = loc.NameEn,
            MinLevel = loc.MinLevel,
            MaxLevel = loc.MaxLevel
        };
    }

private async Task EnsureLocalizationAsync()
{
    try
    {
        bool anyChanges = false;

        foreach (var loc in locations)
        {
            bool needsLocationLocalization =
                string.IsNullOrWhiteSpace(loc.NameCs) ||
                string.IsNullOrWhiteSpace(loc.NameDe);

            if (needsLocationLocalization)
            {
                var locNames = await DungeonAi.GenerateLocalizedNamesAsync(
                    entityKind: "location",
                    nameEn: loc.NameEn,
                    descriptionEn: loc.DescriptionEn
                );

                if (locNames != null)
                {
                    loc.NameEn        = locNames.NameEn;
                    loc.NameCs        = locNames.NameCs;
                    loc.NameDe        = locNames.NameDe;
                    loc.DescriptionEn = locNames.DescriptionEn;
                    loc.DescriptionCs = locNames.DescriptionCs;
                    loc.DescriptionDe = locNames.DescriptionDe;

                    Db.Locations.Update(loc);
                    anyChanges = true;
                }
            }

            // enemies
            foreach (var stage in loc.Stages)
            {
                var m = stage.Enemy;
                if (m == null) continue;

                bool needsMonsterLocalization =
                    string.IsNullOrWhiteSpace(m.NameCs) ||
                    string.IsNullOrWhiteSpace(m.NameDe);

                if (needsMonsterLocalization)
                {
                    var locM = await DungeonAi.GenerateLocalizedNamesAsync(
                        entityKind: "mercenary",
                        nameEn: m.NameEn,
                        descriptionEn: m.DescriptionEn
                    );

                    if (locM != null)
                    {
                        m.NameEn        = locM.NameEn;
                        m.NameCs        = locM.NameCs;
                        m.NameDe        = locM.NameDe;
                        m.DescriptionEn = locM.DescriptionEn;
                        m.DescriptionCs = locM.DescriptionCs;
                        m.DescriptionDe = locM.DescriptionDe;

                        Db.MercenaryTemplates.Update(m);
                        anyChanges = true;
                    }
                }
            }
        }

        if (anyChanges)
        {
            await Db.SaveChangesAsync();
            Toasts.Success("Localization updated", "Some names/descriptions were translated.");
        }
    }
    catch (Exception ex)
    {
        // nechci zbourat stránku kvůli lokalizaci
        Toasts.Error("Localization failed", ex.Message);
    }
}
    private async Task Save()
    {
        if (editModel is null)
        return;

    try
    {
        if (editModel.Id == Guid.Empty)
        {
            editModel.Id = Guid.NewGuid();
            Db.Locations.Add(editModel);
        }
        else
        {
            var existing = await Db.Locations.FirstOrDefaultAsync(l => l.Id == editModel.Id);
            if (existing is null)
            {
                Toasts.Error("Save failed", "Location not found.");
                return;
            }

            existing.Code     = editModel.Code;
            existing.NameEn   = editModel.NameEn;
            existing.MinLevel = editModel.MinLevel;
            existing.MaxLevel = editModel.MaxLevel;
        }

        await Db.SaveChangesAsync();
        editModel = null;
        await LoadLocations();

        Toasts.Success("Location saved", "The location has been saved successfully.");
    }
    catch (Exception ex)
    {
        Toasts.Error("Failed to save location", ex.Message);
    }
    }

    private HashSet<Guid> expandedLocationIds = new();

    private void ToggleDungeonStages(Guid locationId)
    {
        if (expandedLocationIds.Contains(locationId))
            expandedLocationIds.Remove(locationId);
        else
            expandedLocationIds.Add(locationId);
    }
    private async Task DeleteLocation(Guid id)
    {
        try
    {
        var loc = await Db.Locations.FirstOrDefaultAsync(l => l.Id == id);
        if (loc is null)
        {
            Toasts.Error("Delete failed", "Location not found.");
            return;
        }

        Db.Locations.Remove(loc);
        await Db.SaveChangesAsync();
        await LoadLocations();

        Toasts.Success("Location deleted", loc.NameEn);
    }
    catch (Exception ex)
    {
        Toasts.Error("Failed to delete location", ex.Message);
    }
    }

    private void CancelEdit()
    {
        editModel = null;
    }
    private async Task GenerateNextLocation(bool current)
    {
        isLoading = true;

    try
    {
        string locationName;
        var newLocation = new Location();

        var lastLocation = await Db.Locations
            .OrderByDescending(d => d.UnlockOrder)
            .FirstOrDefaultAsync();

        if (lastLocation is null)
        {
            newLocation.MinLevel = 1;
            newLocation.MaxLevel = 5;
        }
        else
        {
            newLocation.MinLevel = lastLocation.MinLevel;
            newLocation.MaxLevel = lastLocation.MaxLevel;
        }

        if (!current)
        {
            locationName = lastLocation?.NameEn ?? "Bausia";
        }
        else
        {
            locationName = manualLocationName.Trim();
            newLocation.NameEn = locationName;
        }

        var generated = await DungeonAi.GenerateNextLocationAsync(lastLocation, newLocation, current);
        if (generated is null)
        {
            Toasts.Error("AI generation failed", "No location was generated.");
            return;
        }

        int nextUnlockOrder = lastLocation is null
            ? 1
            : lastLocation.UnlockOrder + 1;

        var location = new Location
        {
            Id           = Guid.NewGuid(),
            Code         = $"DUN_{generated.NameEn.ToUpper()}",
            NameEn       = generated.NameEn,
            DescriptionEn = generated.DescriptionEn,
            Element      = Enum.TryParse<ElementType>(generated.Element.ToString(), true, out var el)
                            ? el
                            : ElementType.None,
            MinLevel     = generated.MinLevel,
            MaxLevel     = generated.MaxLevel,
            UnlockOrder  = nextUnlockOrder
        };

        Db.Locations.Add(location);

        foreach (var st in generated.Stages.OrderBy(s => s.StageNumber))
        {
            var m = st.Mercenary;

            var merc = new MercenaryTemplate
            {
                Id          = Guid.NewGuid(),
                Code        = $"{location.Code}_{m.NameEn.ToUpper()}",
                NameEn      = m.NameEn,
                DescriptionEn = m.DescriptionEn,
                Element     = Enum.TryParse<ElementType>(m.Element.ToString(), true, out var el1)
                              ? el1
                              : ElementType.None,
                BaseLevel   = m.BaseLevel,
                BaseStats   = new StatBlock
                {
                    MaxHp                = m.Stats.MaxHp,
                    Attack               = m.Stats.Attack,
                    Defense              = m.Stats.Defense,
                    Speed                = m.Stats.Speed,
                    CritChance           = m.Stats.CritChance,
                    CritMultiplier       = m.Stats.CritMultiplier,
                    ElementalDamageBonus = m.Stats.ElementalDamageBonus,
                    ElementalResistance  = m.Stats.ElementalResistance
                }
            };

            Db.MercenaryTemplates.Add(merc);

            var stage = new ExpeditionStage
            {
                Id         = Guid.NewGuid(),
                Code       = $"{location.Code}_{st.StageNumber}",
                LocationId = location.Id,
                StageNumber = st.StageNumber,
                Difficulty = Enum.TryParse<ExpeditionStageType>(
                                st.StageType.ToString(),
                                ignoreCase: true,
                                out var stType)
                                ? stType
                                : ExpeditionStageType.ES1_Novice,
                EnemyId = merc.Id
            };

            Db.ExpeditionStages.Add(stage);
        }

        await Db.SaveChangesAsync();
        await LoadLocations();

        Toasts.Success("Location created", location.NameEn);
    }
    catch (Exception ex)
    {
        Toasts.Error("Failed to generate location", ex.Message);
    }
    finally
    {
        isLoading = false;
    }
}
private Guid? imageGeneratingLocationId;

private bool IsGeneratingImageFor(Guid id)
    => imageGeneratingLocationId.HasValue && imageGeneratingLocationId.Value == id;

private async Task GenerateImageForLocation(Location loc)
{
    if (IsGeneratingImageFor(loc.Id))
        return;

    imageGeneratingLocationId = loc.Id;
    StateHasChanged();

    try
    {
        var path = await ImageAi.GenerateLocationImageAsync(loc);
        if (string.IsNullOrEmpty(path))
        {
            Toasts.Error("Image generation failed", "AI did not return any image.");
            return;
        }

        var dbLoc = await Db.Locations.FirstAsync(l => l.Id == loc.Id);
        dbLoc.ImagePath = path;

        await Db.SaveChangesAsync();
        await LoadLocations();

        Toasts.Success("Image generated", loc.NameEn);
    }
    catch (Exception ex)
    {
        Toasts.Error("Failed to generate image", ex.Message);
    }
    finally
    {
        imageGeneratingLocationId = null;
        StateHasChanged();
    }
}
private ImagePreviewer? imagePreviewer;

private void ShowImage(string url)
{
    imagePreviewer?.Open(url);
}
  
}