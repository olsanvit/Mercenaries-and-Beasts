@page "/locations-admin"
@using System.Globalization
@using System.Reflection
@using Microsoft.EntityFrameworkCore
@using MercenariesAndBeasts.Domain.Combat
@using MercenariesAndBeasts.Domain.Items
@using MercenariesAndBeasts.Domain.Localization
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer

<PageTitle>Locations Admin — Mercenaries & Beasts</PageTitle>

<div class="ui-page-header ui-anim-fade-up">
    <h3><i class="bi bi-compass"></i> Locations Admin</h3>
</div>

<div class="ui-panel ui-anim-fade-up mb-3">
    <div class="fw-bold mb-2">Localization coverage <span class="text-muted small fw-normal">(locales: @_localeCount)</span></div>
    <div class="row g-2">
        <div class="col-md-6">
            <div class="text-muted small mb-1">Locations</div>
            <div>@_locationHaveRows / @_locationMaxRows rows
                (@(_locationMaxRows == 0 ? "0" : ((100.0 * _locationHaveRows / _locationMaxRows).ToString("0.0")))%)
                — full: <span class="@(_locationFullyLocalized == _locationTotal ? "text-success" : "text-warning")">@_locationFullyLocalized / @_locationTotal</span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="text-muted small mb-1">Orders (MercenaryTemplates)</div>
            <div>@_orderHaveRows / @_orderMaxRows rows
                (@(_orderMaxRows == 0 ? "0" : ((100.0 * _orderHaveRows / _orderMaxRows).ToString("0.0")))%)
                — full: <span class="@(_orderFullyLocalized == _orderTotal ? "text-success" : "text-warning")">@_orderFullyLocalized / @_orderTotal</span>
                — items: @_orderWithItemTemplates / @_orderTotal
            </div>
        </div>
    </div>
</div>

<ImagePreviewer @ref="imagePreviewer" />

@if (isLoading)
{
    <PageLoadingSpinner />
}
else
{
    <div class="mb-3">
        <button class="btn btn-primary" @onclick="NewLocation">New Location</button>

        <button class="btn btn-secondary ms-2"
                @onclick="() => GenerateNextLocation(false)">
            Generate Location (AI)
        </button>

        <div class="input-group mt-2">
            <input class="form-control"
                   @bind="manualLocationName"
                   placeholder="Enter location name…" />

            <button class="btn btn-primary"
                    disabled="@IsManualGenerateDisabled"
                    @onclick="async () => await GenerateNextLocation(true)">
                Generate (Manual Name)
            </button>
        </div>
    </div>

    @if (!locations.Any())
    {
        <p>No locations yet.</p>
    }
    else
    {
        <!-- ✅ scroll wrapper for MAIN table -->
       <div class="table-scroll-x">
        <table class="table table-dark table-fixed w-100">
        <thead>
            <tr>
                <th>Code</th>
                <th>Name (EN)</th>
                <th>Element</th>
                <th>Unlock</th>
                <th>Levels</th>
                <th>Stages</th>
                <th>Orders: items</th>
                <th>Image</th>
                <th></th>
            </tr>
        </thead>

        <tbody>
                    @foreach (var loc in locations)
                    {
                        var stages = loc.Stages ?? new List<ExpeditionStage>();

                        var orderNames = stages
                            .Select(s => s.Enemy?.NameEn)
                            .Where(n => !string.IsNullOrWhiteSpace(n))
                            .Select(n => n!)
                            .Distinct()
                            .ToList();

                        var orderHaveItems = orderNames.Count(n => _orderItemNames.Contains(n));
                        var orderTotal = orderNames.Count;

                        <tr>
                            <td>@loc.Code</td>
                            <td>@loc.NameEn</td>
                            <td>@loc.Element</td>
                            <td>@loc.UnlockOrder</td>
                            <td>@loc.MinLevel – @loc.MaxLevel</td>

                            <td>
                                @(loc.Stages?.Count ?? 0)
                                <button class="btn btn-sm btn-outline-info ms-1"
                                        @onclick="() => ToggleLocationStages(loc.Guid)">
                                    @(expandedLocationIds.Contains(loc.Guid) ? "Hide" : "Show")
                                </button>
                            </td>

                            <td>
                                @if (orderTotal == 0)
                                {
                                    <span class="text-muted">—</span>
                                }
                                else
                                {
                                    <span>@orderHaveItems/@orderTotal</span>
                                }
                            </td>

                            <td>
                                @if (!string.IsNullOrEmpty(loc.ImagePath))
                                {
                                    <img src="@loc.ImagePath"
                                         style="max-height:70px; cursor:pointer;"
                                         @onclick="() => ShowImage(loc.ImagePath!)" />
                                }

                                <button class="btn btn-sm btn-outline-info ms-1"
                                        disabled="@IsGeneratingImageFor(loc.Guid)"
                                        @onclick="() => GenerateImageForLocation(loc)">
                                    @if (IsGeneratingImageFor(loc.Guid))
                                    {
                                        <span>Generating…</span>
                                    }
                                    else
                                    {
                                        <span>Generate image</span>
                                    }
                                </button>
                            </td>

                            <td class="text-end">
                                <button class="btn btn-sm btn-secondary"
                                        @onclick="() => EditLocation(loc)">
                                    Edit
                                </button>
                                <button class="btn btn-sm btn-danger ms-1"
                                        @onclick="() => ConfirmDeleteLocation(loc.Guid)">
                                    Delete
                                </button>
                            </td>
                        </tr>

                        @if (expandedLocationIds.Contains(loc.Guid))
{
   <tr class="location-detail-row">
    <td colspan="9" style="max-width:0;">
        <div class="mb-2 location-description">@loc.DescriptionEn</div>

            <div class="table-scroll-x inner-scroll">
                <table class="table table-sm table-dark align-middle text-nowrap mb-0 inner-wide">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Difficulty</th>
                            <th>Enemy (Order)</th>
                            <th>Has item</th>
                            <th>Level</th>
                            <th>Element</th>
                            @foreach (var col in StatColumns)
                            {
                                <th>@col.Header</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in (loc.Stages ?? []).OrderBy(s => s.StageNumber))
                        {
                            var m = s.Enemy;
                            var hasItem = m is not null
                                && !string.IsNullOrWhiteSpace(m.NameEn)
                                && _orderItemNames.Contains(m.NameEn);

                            <tr>
                                <td>@s.StageNumber</td>
                                <td>@s.Difficulty</td>
                                <td>@m?.NameEn</td>
                                <td>@(m is null ? "—" : (hasItem ? "✓" : "—"))</td>
                                <td>@m?.BaseLevel</td>
                                <td>@m?.Element</td>
                                @foreach (var col in StatColumns)
                                {
                                    <td>@FormatStat(col.GetValue(m?.BaseStats))</td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </td>
    </tr>
}
                    }
                </tbody>
            </table>
        </div>
    }
}

@if (editModel is not null)
{
    <hr />
    <h3>@(editModel.Guid == Guid.Empty ? "Create Location" : "Edit Location")</h3>

    <EditForm Model="@editModel" OnValidSubmit="Save">
        <FluentValidationValidator />
        <ValidationSummary />

        <div class="mb-2">
            <label>Code</label>
            <InputText class="form-control" @bind-Value="editModel.Code" />
        </div>

        <div class="mb-2">
            <label>Name (EN)</label>
            <InputText class="form-control" @bind-Value="editModel.NameEn" />
        </div>

        <div class="mb-2">
            <label>Min level</label>
            <InputNumber class="form-control" @bind-Value="editModel.MinLevel" />
        </div>

        <div class="mb-2">
            <label>Max level</label>
            <InputNumber class="form-control" @bind-Value="editModel.MaxLevel" />
        </div>

        <button class="btn btn-success">Save</button>
        <button type="button" class="btn btn-outline-secondary ms-2"
                @onclick="CancelEdit">Cancel</button>
    </EditForm>
}

<ConfirmDialog @ref="_confirmDialog" />

@code {
    private ConfirmDialog _confirmDialog = default!;
    private Guid _pendingDeleteId;

    private bool isLoading = true;
    private List<Location> locations = new();
    private Location? editModel;

    private string manualLocationName = "";
    private bool IsManualGenerateDisabled => isLoading || string.IsNullOrWhiteSpace(manualLocationName);

    private HashSet<Guid> expandedLocationIds = new();

    // ===== Order -> has ItemTemplate (by NameEn match) =====
    private HashSet<string> _orderItemNames = new(StringComparer.Ordinal);

    // ===== Localization stats =====
    private int _localeCount => LocalizationConfig.SupportedLocales.Length;

    private int _locationTotal;
    private int _locationMaxRows;
    private int _locationHaveRows;
    private int _locationFullyLocalized;

    private int _orderTotal;
    private int _orderMaxRows;
    private int _orderHaveRows;
    private int _orderFullyLocalized;
    private int _orderWithItemTemplates;

    protected override async Task OnInitializedAsync()
        => await LoadLocations();

    private async Task LoadLocations()
    {
        isLoading = true;

        await using var Db = await DbFactory.CreateDbContextAsync();
        try
        {
            locations = await Db.Locations
                .Include(x => x.Stages)
                    .ThenInclude(x => x.Enemy)
                .OrderBy(x => x.UnlockOrder)
                .ToListAsync();

            await LoadOrderItemPresenceAsync();
            await LoadLocalizationStatsAsync();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadOrderItemPresenceAsync()
    {
        var orderNames = locations
            .SelectMany(l => l.Stages ?? new List<ExpeditionStage>())
            .Select(s => s.Enemy?.NameEn)
            .Where(n => !string.IsNullOrWhiteSpace(n))
            .Select(n => n!)
            .Distinct()
            .ToList();

        if (orderNames.Count == 0)
        {
            _orderItemNames = new HashSet<string>(StringComparer.Ordinal);
            return;
        }

        await using var Db = await DbFactory.CreateDbContextAsync();

        var itemNames = await Db.ItemTemplates
            .Where(t => t.NameEn != null && orderNames.Contains(t.NameEn))
            .Select(t => t.NameEn!)
            .Distinct()
            .ToListAsync();

        _orderItemNames = new HashSet<string>(itemNames, StringComparer.Ordinal);
    }

    private async Task LoadLocalizationStatsAsync()
    {
        var locales = LocalizationConfig.SupportedLocales;

        var locationIds = locations.Select(l => l.Guid).ToList();

        var orderIds = locations
            .SelectMany(l => l.Stages ?? new List<ExpeditionStage>())
            .Select(s => s.EnemyId)
            .Distinct()
            .ToList();

        _locationTotal = locationIds.Count;
        _orderTotal = orderIds.Count;

        _locationMaxRows = _locationTotal * _localeCount;
        _orderMaxRows = _orderTotal * _localeCount;

        if (_locationTotal == 0)
        {
            _locationHaveRows = 0;
            _locationFullyLocalized = 0;
        }
        else
        {
            await using var Db = await DbFactory.CreateDbContextAsync();
            var locCounts = await Db.LocalizedTexts
                .Where(x => x.EntityType == nameof(Location)
                            && locationIds.Contains(x.EntityId)
                            && locales.Contains(x.Culture)
                            && x.Name != null && x.Name != "")
                .GroupBy(x => x.EntityId)
                .Select(g => new { EntityId = g.Key, Cnt = g.Count() })
                .ToListAsync();

            _locationHaveRows = locCounts.Sum(x => x.Cnt);
            _locationFullyLocalized = locCounts.Count(x => x.Cnt >= _localeCount);
        }

        if (_orderTotal == 0)
        {
            _orderHaveRows = 0;
            _orderFullyLocalized = 0;
            _orderWithItemTemplates = 0;
        }
        else
        {
            await using var Db = await DbFactory.CreateDbContextAsync();
            var orderCounts = await Db.LocalizedTexts
                .Where(x => x.EntityType == nameof(MercenaryTemplate)
                            && orderIds.Contains(x.EntityId)
                            && locales.Contains(x.Culture)
                            && x.Name != null && x.Name != "")
                .GroupBy(x => x.EntityId)
                .Select(g => new { EntityId = g.Key, Cnt = g.Count() })
                .ToListAsync();

            _orderHaveRows = orderCounts.Sum(x => x.Cnt);
            _orderFullyLocalized = orderCounts.Count(x => x.Cnt >= _localeCount);

            _orderWithItemTemplates = locations
                .SelectMany(l => l.Stages ?? new List<ExpeditionStage>())
                .Select(s => s.Enemy?.NameEn)
                .Where(n => !string.IsNullOrWhiteSpace(n))
                .Select(n => n!)
                .Distinct()
                .Count(n => _orderItemNames.Contains(n));
        }
    }

    private void NewLocation()
        => editModel = new Location { MinLevel = 1, MaxLevel = 5 };

    private void EditLocation(Location loc)
        => editModel = new Location
        {
            Guid = loc.Guid,
            Code = loc.Code,
            NameEn = loc.NameEn,
            MinLevel = loc.MinLevel,
            MaxLevel = loc.MaxLevel,
            UnlockOrder = loc.UnlockOrder,
            Element = loc.Element,
            DescriptionEn = loc.DescriptionEn,
            ImagePath = loc.ImagePath
        };

    private async Task Save()
    {
        if (editModel is null) return;

        try
        {
            await using var Db = await DbFactory.CreateDbContextAsync();
            bool isNew = editModel.Guid == Guid.Empty;
            if (isNew)
            {
                editModel.Guid = Guid.NewGuid();
                Db.Locations.Add(editModel);
            }
            else
            {
                var existing = await Db.Locations.FirstOrDefaultAsync(x => x.Guid == editModel.Guid);
                if (existing is null)
                    return;

                existing.Code = editModel.Code;
                existing.NameEn = editModel.NameEn;
                existing.MinLevel = editModel.MinLevel;
                existing.MaxLevel = editModel.MaxLevel;
                existing.UnlockOrder = editModel.UnlockOrder;
            }

            await Db.SaveChangesAsync();
            Toasts.Success("Uloženo", isNew ? "Lokace byla úspěšně přidána." : "Lokace byla úspěšně upravena.");
            editModel = null;
            await LoadLocations();
        }
        catch (Exception ex)
        {
            Toasts.Error("Chyba", $"Nepodařilo se uložit: {ex.Message}");
        }
    }

    private void CancelEdit() => editModel = null;

    private async Task ConfirmDeleteLocation(Guid id)
    {
        _pendingDeleteId = id;
        var confirmed = await _confirmDialog.ShowAsync(
            "Smazat záznam",
            "Opravdu chcete smazat tuto lokaci? Tato akce je nevratná.");
        if (confirmed)
            await DeleteLocation(_pendingDeleteId);
    }

    private async Task DeleteLocation(Guid id)
    {
        try
        {
            await using var Db = await DbFactory.CreateDbContextAsync();
            var loc = await Db.Locations.FindAsync(id);
            if (loc is null) return;

            Db.Locations.Remove(loc);
            await Db.SaveChangesAsync();
            Toasts.Success("Smazáno", "Lokace byla úspěšně smazána.");
            await LoadLocations();
        }
        catch (Exception ex)
        {
            Toasts.Error("Chyba", $"Nepodařilo se smazat: {ex.Message}");
        }
    }

    private void ToggleLocationStages(Guid id)
    {
        if (!expandedLocationIds.Add(id))
            expandedLocationIds.Remove(id);
    }

    private async Task GenerateNextLocation(bool manual)
    {
        isLoading = true;
        StateHasChanged();

        await using var Db = await DbFactory.CreateDbContextAsync();
        try
        {
            var last = await Db.Locations
                .OrderByDescending(x => x.UnlockOrder)
                .FirstOrDefaultAsync();

            var loc = new Location
            {
                NameEn = manual ? manualLocationName.Trim() : last?.NameEn ?? "Unknown",
                MinLevel = last?.MinLevel ?? 1,
                MaxLevel = last?.MaxLevel ?? 5
            };

            await DungeonAi.GenerateNextLocationAsync(last!, loc, true, "", CancellationToken.None);

            await LoadLocations();
            Toasts.Success("Location created", loc.NameEn);
        }
        catch (Exception ex)
        {
            Toasts.Error("AI generation failed", ex.Message);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private Guid? imageGeneratingLocationId;
    private bool IsGeneratingImageFor(Guid id) => imageGeneratingLocationId == id;

    private async Task GenerateImageForLocation(Location loc)
    {
        imageGeneratingLocationId = loc.Guid;
        StateHasChanged();

        await using var Db = await DbFactory.CreateDbContextAsync();
        try
        {
            var path = await ImageAi.GenerateLocationImageAsync(loc);
            if (!string.IsNullOrEmpty(path))
            {
                loc.ImagePath = path;
                await Db.SaveChangesAsync();
                Toasts.Success("Obrázek vygenerován", loc.NameEn);
            }
        }
        catch (Exception ex)
        {
            Toasts.Error("Image generation failed", ex.Message);
        }
        finally
        {
            imageGeneratingLocationId = null;
            await LoadLocations();
        }
    }

    private ImagePreviewer? imagePreviewer;
    private void ShowImage(string url) => imagePreviewer?.Open(url);

    private sealed record StatCol(string Header, Func<StatBlock?, object?> GetValue);
    private static readonly List<StatCol> StatColumns = BuildStatColumns();

    private static List<StatCol> BuildStatColumns()
    {
        var props = typeof(StatBlock).GetProperties(BindingFlags.Instance | BindingFlags.Public)
            .Where(p => p.CanRead &&
                        (p.PropertyType == typeof(int) ||
                         p.PropertyType == typeof(long) ||
                         p.PropertyType == typeof(float) ||
                         p.PropertyType == typeof(double)))
            .ToList();

        return props.Select(p => new StatCol(p.Name, sb => sb is null ? null : p.GetValue(sb))).ToList();
    }

    private static string FormatStat(object? v) => v?.ToString() ?? "-";
}