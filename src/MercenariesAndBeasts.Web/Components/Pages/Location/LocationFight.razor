@page "/expeditions/{LocationId:guid}/fight/{SlotIndex:int}"
@using System.Globalization
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using MercenariesAndBeasts.Infrastructure
@using MercenariesAndBeasts.Domain
@using MercenariesAndBeasts.Domain.Players
@using MercenariesAndBeasts.Domain.Progress
@using MercenariesAndBeasts.Domain.Enums
@using MercenariesAndBeasts.Domain.User
@using MercenariesAndBeasts.Infrastructure.Fights
@using MercenariesAndBeasts.Infrastructure.Players

@inject IDbContextFactory<AppDbContextMercenariesAndBeasts> DbFactory
@inject UserManager<AppUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject FightHistoryService FightHistoryService

@attribute [Authorize]
@rendermode InteractiveServer

@if (isLoading)
{
    <PageLoadingSpinner />
}
else if (player is null || location is null)
{
    <div class="card-like">
        <div class="alert alert-danger mb-0">Missing player or location.</div>
    </div>
}
else if (enemy is null)
{
    <div class="card-like">
        <div class="alert alert-danger mb-2">Order not found for slot @SlotIndex.</div>
        <a class="btn btn-outline-secondary" href="/expeditions">Back</a>
    </div>
}
else
{
    <div class="card-like">
        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
            <div>
                <h3 class="m-0">@LocName(location)</h3>
                <div class="text-muted small">Slot @SlotIndex</div>
            </div>
            <a class="btn btn-outline-secondary" href="/expeditions">Back</a>
        </div>

        <hr />

        <div class="fw-bold mb-2">Enemy Order</div>
        <div class="card-like mb-3" style="background:rgba(255,255,255,0.04);">
            <div class="d-flex align-items-center gap-3">
                @if (!string.IsNullOrWhiteSpace(enemy.ImagePath))
                {
                    <img src="@enemy.ImagePath"
                         style="width:56px;height:56px;object-fit:cover;border-radius:8px;flex-shrink:0;" />
                }
                else
                {
                    <div style="width:56px;height:56px;border-radius:8px;background:rgba(255,255,255,0.06);flex-shrink:0;"></div>
                }
                <div>
                    <div class="fw-bold">@EnemyName()</div>
                    <div class="text-muted small">Lv @enemy.BaseLevel · @enemy.Element</div>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 mb-3">
            <button class="btn btn-primary"
                    disabled="@hasResolved"
                    @onclick="RunFightAsync">
                Fight
            </button>
        </div>

        @if (hasResolved)
        {
            <hr />
            <h4 class="m-0 @(didWin ? "text-success" : "text-danger")">
                @(didWin ? "⚔️ Victory" : "💀 Defeat")
            </h4>
            <div class="text-muted small mt-1">@resultText</div>

            <hr />
            <div class="fw-bold mb-2">Loot</div>
            <ul class="mb-0 text-muted small">
                @foreach (var l in lootLines)
                {
                    <li>@l</li>
                }
            </ul>

            <div class="mt-3">
                <a class="btn btn-primary" href="/expeditions">Back to Locations</a>
            </div>
        }
    </div>
}

@code {
    [Parameter] public Guid LocationId { get; set; }
    [Parameter] public int SlotIndex { get; set; }  // 1..3

    private bool isLoading = true;

    private string? _userId;
    private PlayerProfile? player;
    private Location? location;
    private PlayerExpeditionProgress? progress;
    private MercenaryTemplate? enemy;

    private bool hasResolved = false;
    private bool didWin = false;
    private string resultText = "";
    private List<string> lootLines = new();

    private List<LocalizedText> _locLocs = new();
    private List<LocalizedText> _orderLocs = new();

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;

        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = await UserManager.GetUserAsync(auth.User);
            if (user is null) return;

            _userId = user.Id;

            await using var db = await DbFactory.CreateDbContextAsync();

            player = await db.Players.FirstOrDefaultAsync(p => p.UserId == user.Id);
            if (player is null) return;

            location = await db.Locations.FirstOrDefaultAsync(l => l.Guid == LocationId);
            if (location is null) return;

            progress = await db.PlayerExpeditionProgresses
                .FirstOrDefaultAsync(p => p.PlayerId == player.Guid && p.LocationId == location.Guid);

            if (progress is null)
            {
                progress = new PlayerExpeditionProgress
                {
PlayerId = player.Guid,
                    LocationId = location.Guid,
                    IsCompleted = false,
                    LastUpdatedUtc = DateTime.UtcNow
                };
                db.PlayerExpeditionProgresses.Add(progress);
                await db.SaveChangesAsync();
            }

            // Resolve the template ID for this slot (1–3)
            var templateId = SlotIndex switch
            {
                1 => progress.EncounterOrder1TemplateId,
                2 => progress.EncounterOrder2TemplateId,
                3 => progress.EncounterOrder3TemplateId,
                _ => null
            };

            if (templateId.HasValue)
            {
                enemy = await db.MercenaryTemplates
                    .AsNoTracking()
                    .FirstOrDefaultAsync(x => x.Guid == templateId.Value);
            }

            await LoadLocationLocalizationsAsync(db, new List<Guid> { location.Guid });

            if (enemy is not null)
                await LoadOrderLocalizationsAsync(db, new List<Guid> { enemy.Guid });
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RunFightAsync()
    {
        if (hasResolved || player is null || location is null || progress is null || enemy is null)
            return;

        hasResolved = true;
        lootLines = new();

        await using var db = await DbFactory.CreateDbContextAsync();

        var pr = await db.PlayerExpeditionProgresses
            .FirstOrDefaultAsync(p => p.PlayerId == player.Guid && p.LocationId == location.Guid);

        if (pr is null)
        {
            didWin = false;
            resultText = "Progress not found.";
            return;
        }

        // Deterministic RNG seeded by player + location + slot + enemy
        var seed = HashCode.Combine(player.Guid, location.Guid, SlotIndex, enemy.Guid);
        var rng = new Random(seed);
        didWin = rng.NextDouble() < 0.55;

        if (didWin)
        {
            resultText = $"You defeated {EnemyName()}! The slot will be replaced.";

            // Replace this specific slot with a new random order
            var pool = await db.MercenaryTemplates.Select(x => x.Guid).ToListAsync();
            if (pool.Count > 1)
            {
                var rerollRng = new Random(HashCode.Combine(player.Guid, location.Guid, SlotIndex, DateTime.UtcNow.Ticks));
                var newId = pool.Where(id => id != enemy.Guid).OrderBy(_ => rerollRng.Next()).First();

                if (SlotIndex == 1) pr.EncounterOrder1TemplateId = newId;
                else if (SlotIndex == 2) pr.EncounterOrder2TemplateId = newId;
                else if (SlotIndex == 3) pr.EncounterOrder3TemplateId = newId;
            }

            pr.TotalWins++;
        }
        else
        {
            resultText = $"You lost to {EnemyName()}. The order remains.";
            pr.TotalLosses++;
        }

        pr.LastUpdatedUtc = DateTime.UtcNow;
        await db.SaveChangesAsync();

        // Record fight in history (synthetic FightResult from manual RNG fight)
        var syntheticResult = new FightResult
        {
            DidWin = didWin,
            Summary = resultText,
            LogLines = new List<string>(),
            LootItems = new List<LootItem>()
        };
        _ = await FightHistoryService.RecordExpeditionFightAsync(
            player.Guid,
            LocationId,        // nearest context reference
            syntheticResult,
            seed);

        // Generate and apply upgrade resource loot on win
        if (didWin && _userId is not null)
        {
            var lootRng = new Random(HashCode.Combine(player.Guid, location.Guid, SlotIndex, enemy.Guid) ^ 0x1337_BEEF);
            var resourceTypes = (ItemUpgradeResourceType[])Enum.GetValues(typeof(ItemUpgradeResourceType));
            var count = lootRng.Next(1, 3); // 1 or 2 items
            var lootItems = new List<LootItem>(count);

            for (var i = 0; i < count; i++)
            {
                var type = resourceTypes[lootRng.Next(resourceTypes.Length)];
                var qty  = lootRng.Next(1, 11);
                lootItems.Add(new LootItem(type, qty));
                lootLines.Add($"+{qty}× {type}");
            }

            await ApplyLootAsync(db, _userId, lootItems);
        }
        else
        {
            lootLines.Add("No loot.");
        }

        StateHasChanged();
    }

    private static async Task ApplyLootAsync(
        AppDbContextMercenariesAndBeasts db,
        string userId,
        List<LootItem> lootItems)
    {
        var types = lootItems.Select(x => x.ResourceType).Distinct().ToList();

        var resources = await db.ItemUpgradeResources
            .Where(r => types.Contains(r.Type))
            .ToListAsync();

        if (resources.Count == 0) return;

        foreach (var loot in lootItems)
        {
            var resource = resources.FirstOrDefault(r => r.Type == loot.ResourceType);
            if (resource is null) continue;

            var inv = await db.UserInventoryItems
                .FirstOrDefaultAsync(x => x.UserId == userId && x.ItemTemplateId == resource.ItemTemplateId);

            if (inv is null)
            {
                db.UserInventoryItems.Add(new UserInventoryItem
                {
UserId = userId,
                    ItemTemplateId = resource.ItemTemplateId,
                    Quantity = loot.Quantity
                });
            }
            else
            {
                inv.Quantity += loot.Quantity;
            }
        }

        await db.SaveChangesAsync();
    }

    private string EnemyName()
    {
        if (enemy is null) return "—";
        return Localize(_orderLocs, nameof(MercenaryTemplate), enemy.Guid, "Name", enemy.NameEn);
    }

    private async Task LoadLocationLocalizationsAsync(AppDbContextMercenariesAndBeasts db, List<Guid> ids)
    {
        if (ids.Count == 0) { _locLocs = new(); return; }
        _locLocs = await db.LocalizedTexts
            .Where(x => x.EntityType == nameof(Location) && ids.Contains(x.EntityId))
            .ToListAsync();
    }

    private async Task LoadOrderLocalizationsAsync(AppDbContextMercenariesAndBeasts db, List<Guid> ids)
    {
        if (ids.Count == 0) { _orderLocs = new(); return; }
        _orderLocs = await db.LocalizedTexts
            .Where(x => x.EntityType == nameof(MercenaryTemplate) && ids.Contains(x.EntityId))
            .ToListAsync();
    }

    private string LocName(Location l)
        => Localize(_locLocs, nameof(Location), l.Guid, "Name", l.NameEn);

    private static string Localize(List<LocalizedText> cache, string entityType, Guid entityId, string field, string fallback)
    {
        var culture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
        var loc = cache.FirstOrDefault(x => x.EntityType == entityType && x.EntityId == entityId && x.Culture == culture);
        if (loc is null) return fallback;
        var text = field == "Name" ? loc.Name : field == "Description" ? loc.Description : null;
        return string.IsNullOrWhiteSpace(text) ? fallback : text!;
    }
}